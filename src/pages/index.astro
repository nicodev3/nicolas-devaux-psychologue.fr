---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import ApprochesSection from "../components/ApprochesSection.astro";
import ConsultationRoomGallery from "../components/ConsultationRoomGallery.astro";
import FAQSection from "../components/FAQSection.astro";
import HorairesTarifsSection from "../components/HorairesTarifsSection.astro";
import HomeLatestArticles from "../components/HomeLatestArticles.astro";
import HomeProfessionNotice from "../components/HomeProfessionNotice.astro";
import BookingFab from "../components/BookingFab.astro";
import { SITE_TITLE, SITE_DESCRIPTION, NEARBY_CITIES } from "../consts";

const isProd = import.meta.env.PROD;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Comment prendre rendez-vous ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Vous pouvez prendre rendez-vous via Doctolib depuis la page d'accueil (bloc d'introduction, section Horaires et tarifs ou lien en pied de page). Les consultations se déroulent uniquement sur rendez-vous, le lundi, le mardi et le vendredi de 8h à 20h.",
      },
    },
    {
      "@type": "Question",
      name: "Quelle est la durée d'une séance ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: 'Les consultations individuelles et vidéo durent 45 minutes. Les consultations de couple et les séances MOSAIC durent 1 heure. Dans le cadre du dispositif "Mon Soutien Psy", les séances durent 30 minutes.',
      },
    },
    {
      "@type": "Question",
      name: "Les séances sont-elles remboursées ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: 'Les consultations de psychologie ne sont pas remboursées par la Sécurité Sociale, mais de nombreuses mutuelles proposent une prise en charge partielle ou totale. Le dispositif "Mon Soutien Psy" permet également un remboursement sous certaines conditions.',
      },
    },
    {
      "@type": "Question",
      name: "Comment choisir entre les différentes approches ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Chaque approche a ses spécificités. Lors de notre premier entretien, nous déterminerons ensemble la méthode la plus adaptée à vos besoins. Mon approche intégrative me permet d'adapter le traitement à votre situation unique.",
      },
    },
    {
      "@type": "Question",
      name: "Combien de séances sont nécessaires ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "La durée varie selon vos besoins et objectifs. Certaines difficultés peuvent être résolues en quelques séances, tandis que d'autres nécessitent un accompagnement plus long. Nous évaluons régulièrement l'évolution et ajustons ensemble le rythme des consultations.",
      },
    },
    {
      "@type": "Question",
      name: "Proposez-vous des consultations en ligne ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Oui, je propose des consultations vidéo pour les personnes qui ne peuvent pas se déplacer ou préfèrent ce format. Les séances en ligne respectent la même confidentialité qu'au cabinet.",
      },
    },
    {
      "@type": "Question",
      name: "Le cabinet est-il accessible depuis les villes voisines ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `Oui. Le cabinet est à Sceaux, à proximité de ${NEARBY_CITIES}. Des consultations en visioconférence sont également possibles si vous préférez ne pas vous déplacer.`,
      },
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    {isProd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
  </head>
  <body class="bg-surface-page" data-home-reveal-page>
    <Header suppressMobileBookingCta />
    <main class="page-shell">
      <div data-home-reveal="hero">
        <HeroSection />
      </div>
      <div data-home-reveal="approches">
        <ApprochesSection />
      </div>
      <div data-home-reveal="cabinet">
        <ConsultationRoomGallery />
      </div>
      <div data-home-reveal="faq">
        <FAQSection />
      </div>
      <div data-home-reveal="horaires">
        <HorairesTarifsSection />
      </div>
      <div data-home-reveal="articles">
        <HomeLatestArticles />
      </div>
      <div data-home-reveal="notice">
        <HomeProfessionNotice />
      </div>
    </main>
    <BookingFab />
    <Footer />
    <script>
      import "../scripts/home-reveal.ts";
    </script>
  </body>
</html>

---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Card from "../components/Card.astro";
import SideBar from "../components/SideBar.astro";
import { Schema } from "astro-seo-schema";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { Image } from "astro:assets";
import PsychologueImage from "../assets/psychologue-adulte.png";
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <Schema
      item={{
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Nicolas Devaux - Psychologue à Sceaux",
        alternateName: "Cabinet de psychologie à Sceaux",
        description:
          "Psychologue et psychothérapeute à Sceaux. Thérapies psychodynamique, Cognitive et Comportementale, ACT et pleine conscience. Accompagnement psychologique personnalisé pour adultes et adolescents. Consultations sur rendez-vous.",
        image: ["https://www.psychologue-sceaux.fr/nicolas-devaux.jpg"],
        url: "https://nicolas-devaux-psychologue.fr",
        telephone: "0629341367",
        email: "ndevaux@gmail.com",
        address: {
          "@type": "PostalAddress",
          streetAddress: "63 rue Houdan",
          addressLocality: "Sceaux",
          postalCode: "92330",
          addressCountry: "FR",
        },
        geo: {
          "@type": "GeoCoordinates",
          latitude: "48.7783502",
          longitude: "2.2918735",
        },
        openingHours: "Mo-Sa 08:00-20:00",
        priceRange: "70€",
        paymentAccepted: "Espèces, Chèques, Virements bancaires",
        currenciesAccepted: "EUR",
      }}
    />
  </head>
  <body class="bg-gradient-to-r from-blue-50 to-white">
    <Header />
    <main class="container flex flex-col xl:flex-row gap-5 xl:gap-32 xl:py-8">
      <div class="xl:w-2/3">
                <!-- Section Hero avec image intégrée -->
        <div class="bg-white rounded-xl shadow-md p-8 mb-12 border border-gray-100">
          <div class="grid lg:grid-cols-3 gap-8 items-center">
            <!-- Contenu textuel -->
            <div class="lg:col-span-2">
              <h1 class="text-4xl md:text-5xl font-bold text-tertiary mb-6 leading-tight">
                Psychologue à Sceaux
              </h1>
              <p class="text-lg text-gray-700 leading-relaxed">
                <strong class="text-tertiary">Psychologue clinicien</strong> diplômé de l'<strong>Université Paris Cité</strong> (anciennement Paris 7 Denis-Diderot),
                psychothérapeute, je vous accueille dans mon cabinet situé au <strong>63 rue Houdan</strong>,
                au cœur de la rue piétonne de Sceaux. Je propose un accompagnement personnalisé
                aux enfants, adolescents, adultes, couples, dans un cadre bienveillant
                et confidentiel.
              </p>
            </div>
            
            <!-- Image du psychologue -->
            <div class="lg:col-span-1 flex justify-center lg:justify-end">
              <div class="bg-gray-50 p-4 rounded-2xl border border-gray-200 max-w-xs">
                <Image
                  src={PsychologueImage}
                  alt="Nicolas Devaux, Psychologue à Sceaux"
                  class="rounded-xl w-full"
                  loading="eager"
                />
              </div>
            </div>
          </div>
        </div>

        <!-- Bandeau publics et motifs (design amélioré) -->
        <div class="mb-12">
          <div class="relative rounded-2xl p-6 md:p-8 bg-white border border-gray-100 shadow-md">
            <div class="absolute inset-0 rounded-2xl pointer-events-none bg-gradient-to-r from-primary/5 via-secondary/5 to-tertiary/5"></div>
            <div class="relative grid md:grid-cols-2 gap-8 items-stretch">
              <!-- Publics -->
              <div class="min-h-[200px] h-full flex flex-col">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-8 h-8 rounded-full bg-tertiary/10 flex items-center justify-center text-tertiary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                      <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0z"/>
                      <path fill-rule="evenodd" d="M12 14c-4.418 0-8 2.239-8 5v1a1 1 0 001 1h14a1 1 0 001-1v-1c0-2.761-3.582-5-8-5z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                  <h3 class="text-lg font-semibold text-tertiary">Publics accueillis</h3>
                </div>
                <div class="flex flex-wrap gap-2 mb-2">
                  <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm">Enfants</span>
                  <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm">Adolescents</span>
                  <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm">Adultes</span>
                  <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm">Couples</span>
                  <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm">Visioconsultation</span>
                </div>
                <p class="text-sm text-gray-600 mt-auto">Consultations au cabinet de Sceaux et en visioconsultation.</p>
              </div>

              <!-- Motifs -->
              <div class="min-h-[200px] h-full flex flex-col">
                <div class="flex items-center gap-3 mb-3">
                  <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                      <path d="M12 3a9 9 0 100 18 9 9 0 000-18zM11 7h2v6h-2V7zm0 8h2v2h-2v-2z"/>
                    </svg>
                  </div>
                  <h3 class="text-lg font-semibold text-tertiary">Motifs fréquents</h3>
                </div>
                <ul class="grid sm:grid-cols-2 gap-2 text-sm">
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Difficultés parentales</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Conflits de couple</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Communication</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Anxiété</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Stress</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Dépression</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Estime de soi</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Trauma • Deuil</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">TOC • Phobies</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Sommeil</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Burn‑out</li>
                  <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg">Préparation aux examens</li>
                </ul>
              </div>
            </div>
          </div>
        </div>

                <!-- Section Approche intégrative -->
        <div class="mb-12">
          <div class="bg-white rounded-xl shadow-md p-8 border border-gray-100">
            <h2 class="text-2xl font-bold text-tertiary mb-6">Une approche intégrative centrée sur la personne</h2>
            
            <p class="text-gray-700 leading-relaxed mb-6">
              Ma pratique repose sur une approche intégrative, combinant différentes
              méthodes thérapeutiques pour répondre au mieux à vos besoins
              spécifiques. Je m'appuie notamment sur :
            </p>

            <ul class="space-y-4 text-gray-700">
              <li>
                <strong class="text-tertiary">La psychothérapie psychodynamique</strong> : pour explorer les
                conflits internes et les expériences passées influençant votre vie actuelle.
              </li>
              <li>
                <strong class="text-tertiary">Les thérapies cognitives et comportementales (TCC)</strong> :
                pour identifier et modifier les schémas de pensée et de comportement
                problématiques.
              </li>
              <li>
                <strong class="text-tertiary">La thérapie d'acceptation et d'engagement (ACT)</strong> : pour
                développer la flexibilité psychologique et agir en accord avec vos valeurs
                profondes.
              </li>
              <li>
                <strong class="text-tertiary">La thérapie centrée sur les émotions (TCE)</strong> : pour
                explorer et transformer les émotions difficiles, améliorer l'expression émotionnelle
                et renforcer les liens relationnels.
              </li>
              <li>
                <strong class="text-tertiary">La pleine conscience (MBCT et MBSR)</strong> : pour développer
                une meilleure conscience du moment présent et gérer plus efficacement le stress
                et les émotions difficiles.
              </li>
            </ul>
          </div>
        </div>

        <!-- Section Difficultés -->
        <div class="mb-12">
          <div class="bg-white rounded-xl shadow-md p-8 border border-gray-100">
            <h2 class="text-2xl font-bold text-tertiary mb-6">Pour quelles difficultés consulter ?</h2>
            
            <p class="text-gray-700 leading-relaxed mb-6">
              Je vous accompagne dans diverses problématiques, telles que :
            </p>

            <ul class="list-disc list-inside space-y-2 text-gray-700">
              <li>Troubles de l'humeur, anxiété, dépression, phobies, TOC</li>
              <li>Difficultés relationnelles, professionnelles ou familiales</li>
              <li>Traumatismes, deuils, gestion du stress</li>
              <li>Problèmes de confiance en soi, estime de soi, parentalité, sexualité</li>
              <li>Addictions, troubles du comportement, difficultés scolaires</li>
              <li>Problèmes de couple</li>
              <li>Situations de harcèlement ou de violence</li>
            </ul>
          </div>
        </div>

        <section class="mb-12">
          <h2 class="mb-6 text-2xl md:text-3xl">
            Les différentes approches proposées au cabinet de psychologie de
            Sceaux
          </h2>
          <div class="grid xl:grid-cols-2 gap-8">
            <Card
              url="/psychotherapie/"
              image={(await import("../assets/psychotherapie.png")).default}
              title="Psychothérapie psychodynamique"
              content="Les psychothérapies psychodynamiques explorent les conflits internes et les expériences passées pour comprendre et traiter les troubles émotionnels"
            />

            <Card
              url="/therapie-acceptation-et-engagement/"
              image={(await import("../assets/acceptation-engagement.png"))
                .default}
              title="Thérapie d'Acceptation et d'Engagement (ACT)"
              content="La thérapie ACT (Acceptation et Engagement) encourage l'acceptation des émotions difficiles tout en s'engageant vers des actions alignées avec ses valeurs."
            />

            <Card
              url="/therapie-pleine-conscience/"
              image={(await import("../assets/mbct.png")).default}
              title="Mindfulness Based Cognitive Therapy (MBCT)"
              content="La MBCT (Thérapie cognitive basée sur la pleine conscience) combine méditation et techniques cognitives pour prévenir les rechutes dépressives et gérer le stress."
            />

            <Card
              url="/therapie-cognitive-et-comportementale/"
              image={(await import("../assets/tcc.png")).default}
              title="Thérapies cognitives et comportementales (TCC)"
              content="La TCC (Thérapie cognitive et comportementale) utilise des techniques cognitives pour traiter les troubles émotionnels et comportementaux."
            />

            <Card
              url="/blog/therapie-integrative-comportementale-couple/"
              image={(await import("../assets/soutien-psy.webp")).default}
              title="Thérapies de couple (IBCT)"
              content="Apaiser les cycles de conflit, renforcer l’intimité et la coopération grâce à l’IBCT et des outils de l’ACT."
            />
          </div>
        </section>

        <!-- Section FAQ -->
        <section class="mb-12">
          <h2 class="mb-8 text-2xl md:text-3xl text-center text-tertiary">Questions fréquentes</h2>
          
          <div class="max-w-4xl mx-auto space-y-6">
            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Comment prendre rendez-vous ?</h3>
              <p class="text-gray-700 leading-relaxed">
                Vous pouvez prendre rendez-vous facilement via <strong>Doctolib</strong> en cliquant sur le bouton "Prendre rendez-vous" ci-dessus. 
                Les consultations se déroulent uniquement sur rendez-vous, du lundi au samedi de 8h à 20h.
              </p>
            </div>

            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Quelle est la durée d'une séance ?</h3>
              <p class="text-gray-700 leading-relaxed">
                Les séances individuelles durent <strong>45 minutes</strong>, les consultations de couple <strong>50 minutes</strong>. 
                Les séances avec les enfants sont plus courtes (<strong>30 minutes</strong>) car cette durée est plus adaptée à leur rythme et à leur capacité d'attention.
                <br><br>
                Dans le cadre du dispositif "Mon Soutien Psy", les séances sont également de <strong>30 minutes</strong> afin de garantir la pérennité de cette offre pour un maximum de personnes.
              </p>
            </div>

            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Les séances sont-elles remboursées ?</h3>
              <p class="text-gray-700 leading-relaxed">
                Les consultations de psychologie ne sont pas remboursées par la Sécurité Sociale, mais de nombreuses 
                <strong>mutuelles proposent une prise en charge</strong> partielle ou totale. Le dispositif "Mon Soutien Psy" 
                permet également un remboursement sous certaines conditions.
              </p>
            </div>

            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Comment choisir entre les différentes approches ?</h3>
              <p class="text-gray-700 leading-relaxed">
                Chaque approche a ses spécificités. Lors de notre premier entretien, nous déterminerons ensemble 
                la méthode la plus adaptée à vos besoins. Mon approche intégrative me permet d'adapter le traitement 
                à votre situation unique.
              </p>
            </div>

            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Combien de séances sont nécessaires ?</h3>
              <p class="text-gray-700 leading-relaxed">
                La durée varie selon vos besoins et objectifs. Certaines difficultés peuvent être résolues en quelques séances, 
                tandis que d'autres nécessitent un accompagnement plus long. Nous évaluons régulièrement l'évolution 
                et ajustons ensemble le rythme des consultations.
              </p>
            </div>

            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-6 border border-gray-100">
              <h3 class="text-lg font-semibold text-tertiary mb-3">Proposez-vous des consultations en ligne ?</h3>
              <p class="text-gray-700 leading-relaxed">
                Oui, je propose des <strong>consultations vidéo</strong> pour les personnes qui ne peuvent pas se déplacer 
                ou préfèrent ce format. Les séances en ligne sont tout aussi efficaces et respectent la même confidentialité.
              </p>
            </div>
          </div>
        </section>

        <section class="mb-12">
          <h2 class="mb-6 text-2xl md:text-3xl text-center">Horaires et tarifs</h2>
          
          <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
            <!-- Carte Tarifs -->
            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-8 border border-gray-100">
              <div class="flex items-center mb-6">
                <div class="bg-gray-50 p-3 rounded-full mr-4">
                  <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-tertiary">Tarifs des consultations</h3>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                  <span class="text-gray-700">Consultation individuelle</span>
                  <span class="text-xl font-bold text-tertiary">70€</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                  <span class="text-gray-700">Consultation de couple</span>
                  <span class="text-xl font-bold text-tertiary">110€</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                  <span class="text-gray-700">Consultation vidéo</span>
                  <span class="text-xl font-bold text-tertiary">70€</span>
                </div>
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                  <span class="text-gray-700">Mon Soutien Psy*</span>
                  <span class="text-xl font-bold text-tertiary">50€</span>
                </div>

              </div>
              
              <div class="mt-4 p-3 bg-blue-50 rounded-lg">
                <p class="text-sm text-blue-800">
                  <strong>*Mon Soutien Psy :</strong> Ces séances remboursées ne peuvent être prises qu'avec mon accord préalable. 
                  <a href="https://www.ameli.fr/assure/remboursements/rembourse/remboursement-seance-psychologue-mon-soutien-psy" target="_blank" rel="noopener noreferrer" class="underline hover:no-underline">
                    Plus d'infos sur le site officiel
                  </a>.
                </p>
              </div>
              
              <div class="mt-3 p-3 bg-blue-50 rounded-lg">
                <p class="text-sm text-blue-800">
                  <strong>💳 Paiement :</strong> Chèques, espèces et virement bancaire. Cartes bancaires non acceptées.
                </p>
              </div>
            </div>

            <!-- Carte Horaires -->
            <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow duration-300 p-8 border border-gray-100">
              <div class="flex items-center mb-6">
                <div class="bg-gray-50 p-3 rounded-full mr-4">
                  <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-tertiary">Horaires d'ouverture</h3>
              </div>
              
              <div class="space-y-3">
                <div class="flex justify-between items-center py-2 border-b border-gray-100">
                  <span class="text-gray-700">Lundi - Samedi</span>
                  <span class="font-semibold text-tertiary">8h00 - 20h00</span>
                </div>
                <div class="flex justify-between items-center py-2">
                  <span class="text-gray-700">Dimanche</span>
                  <span class="text-red-600 font-semibold">Fermé</span>
                </div>
              </div>
              
              <div class="mt-4 p-3 bg-green-50 rounded-lg">
                <p class="text-sm text-green-800">
                  <strong>📅 Prise de rendez-vous :</strong> Consultations sur rendez-vous uniquement. Réservez facilement via Doctolib.
                </p>
              </div>
            </div>
          </div>

          <!-- Informations complémentaires -->
          <div class="mt-8 bg-gradient-to-r from-secondary/30 to-primary/20 rounded-xl p-6 max-w-4xl mx-auto">
            <div class="flex items-start">
              <div class="bg-yellow-100 p-2 rounded-full mr-4 flex-shrink-0">
                <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-tertiary mb-2">Informations importantes</h4>
                <p class="text-gray-700 text-sm leading-relaxed">
                  Les séances de psychologie et de psychothérapie ne sont pas remboursées par la Sécurité Sociale, 
                  mais de nombreuses mutuelles proposent une prise en charge partielle ou totale. 
                  N'hésitez pas à vous renseigner auprès de votre complémentaire santé.
                </p>
              </div>
            </div>
          </div>
        </section>
      </div>
      <SideBar />
    </main>
    <Footer />
  </body>
</html>

---
import Layout from "../layouts/BlogPost.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { Image, Picture } from "astro:assets";
import MosaicImage from "../assets/emdr-therapie-mosaic.webp";
import MosaicSchemaImage from "../assets/blog/infographie-mosaic.webp";
import EmotionRegionsImage from "../assets/blog/cerveau-regions-emotion-fr.webp";
import MosaicFormationImage from "../assets/logo-mosaic.svg";
import MosaicPractitionerPdf from "../assets/Ici-votre-praticien-MOSAIC.pdf?url";
import { buttonClasses } from "../components/ui/button";
import { DOCTOLIB_BOOKING_URL, NEARBY_CITIES } from "../consts";

const isProd = import.meta.env.PROD;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Qu'est-ce que la thérapie EMDR-MOSAIC ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "MOSAIC signifie Mouvements Oculaires et Stimulations Alternées pour l'Intégration Cérébrale. Comme l'EMDR, cette approche utilise les stimulations bilatérales alternées, avec une logique orientée vers les solutions et l'apaisement plutôt que vers l'exposition prolongée au souvenir douloureux.",
      },
    },
    {
      "@type": "Question",
      name: "Combien coûte une séance EMDR-MOSAIC ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Une séance EMDR-MOSAIC dure 1 heure et coûte 90 €. Le détail des tarifs est disponible sur la page Tarifs du site.",
      },
    },
    {
      "@type": "Question",
      name: "Peut-on faire une séance EMDR-MOSAIC en ligne ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Oui, selon la situation. Les séances ont lieu au cabinet à Sceaux, et des consultations en visioconférence peuvent être proposées après évaluation, notamment si vous êtes éloigné du cabinet.",
      },
    },
    {
      "@type": "Question",
      name: "Combien de séances faut-il ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Cela dépend de la nature de la difficulté, de son ancienneté, de vos ressources actuelles et de votre situation globale. L'évaluation initiale permet d'estimer un cadre de travail, sans promesse de résultat en un nombre de séances donné.",
      },
    },
    {
      "@type": "Question",
      name: "Faut-il revivre le traumatisme pendant les séances ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Non, pas au sens d'une exposition prolongée et détaillée. Le travail porte d'abord sur la situation limitante telle qu'elle est vécue aujourd'hui, puis sur l'état interne désiré, sans nécessiter un récit exhaustif de l'événement.",
      },
    },
    {
      "@type": "Question",
      name: "Quelle différence entre l'EMDR et MOSAIC ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Les deux approches partagent l'usage des stimulations bilatérales alternées. L'EMDR travaille classiquement avec le souvenir traumatique cible, tandis que MOSAIC met davantage l'accent sur l'expérience corporelle de la solution et les ressources de la personne.",
      },
    },
  ],
};

const mosaicCtaPrimary = buttonClasses({
  variant: "primary",
  size: "lg",
  className: "w-full justify-center sm:w-auto",
});
const mosaicCtaSecondary = buttonClasses({
  variant: "secondary",
  size: "lg",
  className: "w-full justify-center sm:w-auto",
});
---

<Layout
  title="Thérapie EMDR-MOSAIC à Sceaux"
  description="Séances EMDR-MOSAIC à Sceaux pour les vécus traumatiques, blocages émotionnels et difficultés psychologiques."
  pubDate={new Date("March 07 2026")}
  showDate={false}
>
  {isProd && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <section class="flex flex-col gap-8 xl:gap-10">
    <p>
      La thérapie <strong>
        <a
          href="https://www.therapiemosaic.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-link">MOSAIC</a
        ></strong
      >, parfois appelée <strong>EMDR-MOSAIC</strong> en raison de sa proximité avec
      l'EMDR, fait partie des approches spécifiques que je peux proposer au cabinet lorsque
      la difficulté est liée à une mémoire douloureuse, à un vécu traumatique ou à
      une réaction émotionnelle qui reste trop intense malgré le temps écoulé. Je
      suis formé à la thérapie MOSAIC de référence auprès du Dr Stéphanie Khalfa.
    </p>
    <p>
      MOSAIC signifie <strong
        >Mouvements Oculaires et Stimulations Alternées pour l'Intégration
        Cérébrale</strong
      >. Cette approche récente utilise les stimulations bilatérales alternées,
      comme dans l'EMDR, avec une logique orientée vers les solutions et
      l'apaisement. Cette méthode, développée en 2019 par Guillaume Poupard
      (psychologue clinicien, docteur en psychopathologie) et Stéphanie Khalfa
      (chercheuse en neurosciences et psychologue), s'appuie sur des connaissances actuelles en
      psychologie et neurosciences pour faciliter la transformation des
      souvenirs difficiles.
    </p>
    <p>
      Si vous cherchez une aide pour un traumatisme ou pour un souvenir qui
      reste envahissant, l'objectif est clair : <strong
        >apaiser la détresse sans vous replonger longuement dans la douleur du
        souvenir</strong
      >.
    </p>

    <div class="my-2">
      <Picture
        src={MosaicImage}
        alt="Thérapie MOSAIC"
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        loading="lazy"
        decoding="async"
        class="mx-auto"
      />
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="01 — Indications" title="Dans quels cas cette approche peut être utile ?" />
      <p>
        La thérapie MOSAIC peut être indiquée lorsqu'un événement ou un souvenir
        reste associé à une détresse importante, à un sentiment de blocage ou à
        une hyperréactivité émotionnelle.
      </p>
      <ul>
        <li>Souvenirs douloureux ou traumatiques.</li>
        <li>Stress persistant après un événement difficile.</li>
        <li>Réactions émotionnelles envahissantes ou disproportionnées.</li>
        <li>
          Blocages qui se répètent malgré un travail de compréhension déjà
          engagé.
        </li>
      </ul>
      <p>
        L'indication se décide toujours au cas par cas, après évaluation
        clinique.
      </p>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="02 — Définition" title="MOSAIC : définition simple" />
      <p>
        La thérapie MOSAIC vise à activer des ressources déjà présentes chez la
        personne, notamment à travers des sensations corporelles de sécurité,
        d'apaisement ou de solidité.
      </p>
      <p>
        Au lieu de rester centrée sur le problème et sur son historique, la
        méthode travaille aussi sur ce qui aide déjà, sur ce que vous souhaitez
        ressentir à la place, et sur la manière de stabiliser ce nouvel état
        dans votre vie quotidienne.
      </p>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="03 — EMDR" title="Différence entre l'EMDR et MOSAIC" />
      <p>
        L'EMDR et MOSAIC partagent l'usage des stimulations bilatérales
        alternées. La différence principale tient au point d'entrée
        thérapeutique.
      </p>
      <ul>
        <li>
          L'EMDR travaille classiquement avec le souvenir traumatique cible.
        </li>
        <li>
          MOSAIC met davantage l'accent sur l'expérience corporelle de la
          solution.
        </li>
      </ul>
      <p>
        En pratique, de nombreuses personnes décrivent MOSAIC comme une approche
        plus douce, tout en restant active et structurée.
      </p>
    </div>

    <div class="my-2">
      <Image
        src={MosaicSchemaImage}
        alt="Schéma simplifié de la thérapie MOSAIC"
      />
      <p class="mt-2 text-sm text-ink-tertiary">
        Illustration : modèle simplifié du fonctionnement de la thérapie MOSAIC.
      </p>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="04 — Déroulement" title="Comment se déroule l'accompagnement ?" />
      <p>
        Les premières séances permettent de comprendre votre demande, de
        vérifier si cette approche est adaptée et de définir un cadre clair. Le
        travail thérapeutique se fait ensuite de manière progressive et
        structurée.
      </p>
      <ol>
        <li>
          <strong>Entretien MOSAIC :</strong> définition de la situation limitante,
          des objectifs et de l'état interne désiré.
        </li>
        <li>
          <strong>Boucle de reconnexion :</strong> renforcement progressif de l'état
          recherché avec stimulations bilatérales alternées.
        </li>
        <li>
          <strong>Projection des bénéfices :</strong> travail sur les changements
          concrets attendus dans le quotidien.
        </li>
        <li>
          <strong>Intégration :</strong> débriefing et exercice simple entre les séances
          pour stabiliser le travail.
        </li>
      </ol>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="05 — Neurosciences" title="Ce que disent les neurosciences" />
      <p>
        Les recherches sur le psychotraumatisme et l'EMDR montrent l'implication
        de réseaux cérébraux liés à la peur, à la mémoire contextuelle, à la
        régulation émotionnelle et à la conscience de soi.
      </p>
      <ul>
        <li>Amygdale : détection de la menace.</li>
        <li>Hippocampe : mémoire contextuelle.</li>
        <li>Cortex préfrontal : régulation émotionnelle.</li>
        <li>
          Insula, précuneus, cingulaire : intégration multisensorielle et
          conscience de soi.
        </li>
      </ul>
      <p>
        Les stimulations bilatérales alternées semblent moduler ces réseaux et
        favoriser une reconsolidation de la mémoire traumatique avec moins de
        charge émotionnelle.
      </p>
    </div>

    <div class="my-2">
      <Picture
        src={EmotionRegionsImage}
        alt="Régions cérébrales impliquées dans la régulation émotionnelle"
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        loading="lazy"
        decoding="async"
      />
      <p class="mt-2 text-sm text-ink-tertiary">
        Illustration : principales régions cérébrales impliquées dans la
        régulation émotionnelle.
      </p>
    </div>

    <div>
      <SectionHeading
        class="mb-4"
        eyebrow="06 — Efficacité"
        title="Efficacité : ce qu'on peut dire avec rigueur"
      />
      <ul>
        <li>
          L'EMDR est une thérapie validée scientifiquement pour le trouble de
          stress post-traumatique.
        </li>
        <li>
          MOSAIC est une approche plus récente. Son corpus de recherche propre
          reste moins développé que celui de l'EMDR et ne permet pas de leur
          attribuer aujourd'hui le même niveau de validation.
        </li>
      </ul>
      <p>
        Pour comprendre précisément leurs points communs et leurs différences,
        consultez le comparatif <a href="/blog/therapie-mosaic/" class="text-link"
          >MOSAIC ou EMDR</a
        >.
      </p>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="07 — Patients" title="Pourquoi des patients choisissent MOSAIC" />
      <ul>
        <li>
          Vouloir une approche active sans exposition prolongée à la douleur.
        </li>
        <li>Retrouver un sentiment de sécurité intérieure.</li>
        <li>
          Avancer à un rythme respectueux, avec des outils concrets entre les
          séances.
        </li>
      </ul>
    </div>

    <div>
      <SectionHeading
        class="mb-4"
        eyebrow="08 — Intégration"
        title="Quelle place parmi les autres approches du cabinet ?"
      />
      <p>
        La thérapie MOSAIC n'est pas systématiquement la bonne porte d'entrée.
        Selon votre situation, il peut être plus pertinent de commencer par une
        <a href="/psychotherapie/" class="text-link">psychothérapie</a> ou par une
        approche de <a href="/tcc-troisieme-vague/" class="text-link"
          >TCC de 3e vague</a
        >.
      </p>
      <p>
        Elle s'inscrit donc dans une logique d'accompagnement intégratif :
        l'approche retenue dépend de votre demande, de votre histoire et de vos
        objectifs.
      </p>
    </div>

    <div>
      <SectionHeading
        class="mb-4"
        eyebrow="09 — Cadre"
        title="Mon cadre actuel d'accompagnement en thérapie MOSAIC"
      />
      <p>
        Je suis formé à la <strong>thérapie MOSAIC de référence</strong>. Cette
        formation me permet d'appliquer le protocole de référence pour
        accompagner les mémoires douloureuses, les situations émotionnellement
        intenses et le stress.
      </p>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="10 — Consultations" title="Consultation EMDR-MOSAIC à Sceaux et en ligne : tarif et rendez-vous" />
      <p>
        Je vous reçois au cabinet à <strong>Sceaux</strong> et propose aussi, selon
        la situation, des séances en
        <a href="/psychologue-en-ligne/" class="text-link">consultation en ligne</a>.
      </p>
      <p>
        Une séance EMDR-MOSAIC dure <strong>1 heure</strong> et coûte
        <strong>90 €</strong>. Le détail des tarifs est disponible sur la page
        <a href="/tarifs/" class="text-link">Tarifs</a>.
      </p>
      <p>
        Le cabinet est accessible pour les personnes habitant Sceaux et les
        villes voisines comme {NEARBY_CITIES.replace(" et ", ", ")} ou Le
        Plessis-Robinson.
      </p>
      <div class="mt-2 flex flex-col gap-3 sm:flex-row">
        <a
          href={DOCTOLIB_BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class={mosaicCtaPrimary}
          data-track-doctolib
          data-track-location="Therapie MOSAIC consultations"
        >
          Prendre rendez-vous pour une séance EMDR-MOSAIC
        </a>
        <a href="/consulter/" class={mosaicCtaSecondary}>
          Savoir si cette approche est adaptée
        </a>
      </div>
    </div>

    <div>
      <SectionHeading class="mb-4" eyebrow="11 — FAQ" title="Questions fréquentes" />
      <h3 class="font-display typo-display-md text-ink-primary">La thérapie MOSAIC est-elle reconnue ?</h3>
      <p>
        MOSAIC est enseignée et pratiquée par des professionnels formés, mais
        elle est plus récente que l'EMDR et dispose d'un corpus de recherche
        propre moins développé. Elle ne doit donc pas être présentée comme
        bénéficiant aujourd'hui du même niveau de validation scientifique.
      </p>

      <h3 class="font-display typo-display-md text-ink-primary">Combien coûte une séance EMDR-MOSAIC ?</h3>
      <p>
        Une séance dure 1 heure et coûte 90 €. Le détail des tarifs et des modalités
        de paiement est disponible sur la page <a href="/tarifs/" class="text-link">Tarifs</a>.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">Peut-on faire une séance EMDR-MOSAIC en ligne ?</h3>
      <p>
        Oui, selon la situation. Les séances ont lieu au cabinet à Sceaux, et des
        séances en <a href="/psychologue-en-ligne/" class="text-link">visioconférence</a>
        peuvent être proposées après évaluation, notamment si vous êtes éloigné du cabinet.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">Combien de séances faut-il ?</h3>
      <p>
        Cela dépend de la nature du trauma, de son ancienneté, de vos ressources
        actuelles et de votre situation globale. L'évaluation initiale permet
        d'estimer un cadre de travail.
      </p>

      <h3 class="font-display typo-display-md text-ink-primary">
        Peut-on faire MOSAIC si on a déjà suivi une thérapie EMDR ?
      </h3>
      <p>
        Oui. Les deux approches peuvent être complémentaires selon vos besoins.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">La thérapie MOSAIC est-elle douloureuse ou éprouvante ?</h3>
      <p>
        MOSAIC est conçue pour éviter l'exposition prolongée à la douleur du souvenir. L'approche travaille davantage sur l'état interne recherché et les ressources que sur le récit détaillé du traumatisme. La plupart des personnes décrivent les séances comme exigeantes mais soutenables, et souvent apaisantes en fin de session. Si une séance est trop intense, le rythme peut être ajusté.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">Faut-il revivre le traumatisme pendant les séances ?</h3>
      <p>
        Non, pas au sens d'une exposition prolongée et détaillée. MOSAIC n'oblige pas à raconter l'intégralité de l'événement traumatique. Le travail porte d'abord sur la <em>situation limitante</em> telle qu'elle est vécue aujourd'hui, puis sur l'état interne désiré. Cette logique orientée vers la solution permet de traiter la charge émotionnelle sans nécessiter un récit exhaustif.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">MOSAIC convient-elle en cas d'anxiété sans traumatisme clairement identifié ?</h3>
      <p>
        Oui. MOSAIC ne se limite pas aux traumatismes au sens strict. Elle peut être utile lorsque des réactions émotionnelles restent disproportionnées ou envahissantes, même sans événement traumatique identifié — anxiété persistante, blocages récurrents, hyperréactivité relationnelle. L'évaluation clinique préalable permet de déterminer si l'approche est indiquée dans votre situation spécifique.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">La thérapie MOSAIC peut-elle être combinée avec d'autres approches ?</h3>
      <p>
        Oui. MOSAIC s'intègre dans une logique d'accompagnement intégratif. Selon votre situation, elle peut être proposée en complément d'une <a href="/psychotherapie/" class="text-link">psychothérapie</a>, d'un suivi en <a href="/therapie-acceptation-et-engagement/" class="text-link">ACT</a>, ou d'une <a href="/therapie-couple/" class="text-link">thérapie de couple</a> lorsque les mémoires douloureuses ont une dimension relationnelle.
      </p>
    </div>

    <div class="border border-border-strong rounded-xl bg-secondary/40 p-5">
      <SectionHeading class="mb-4" eyebrow="12 — Ressources" title="Pour aller plus loin" />
      <p class="mb-3">
        Pour préparer votre démarche, vous pouvez aussi consulter :
      </p>
      <ul class="list-disc list-inside space-y-2 mb-4">
        <li>
          <a href="/psychotherapie/" class="text-link"
            >Approches thérapeutiques au cabinet</a
          >
        </li>
        <li>
          <a href="/consulter/" class="text-link"
            >Consulter un psychologue à Sceaux</a
          >
        </li>
        <li>
          <a href="/blog/pourquoi-consulter-psychologue/" class="text-link"
            >Pourquoi consulter un psychologue ?</a
          >
        </li>
        <li>
          <a href="/blog/therapie-mosaic/" class="text-link"
            >MOSAIC ou EMDR : quelles différences ?</a
          >
        </li>
      </ul>
      <p class="mb-3">Ressources complémentaires :</p>
      <ul class="list-disc list-inside space-y-2 mb-4">
        <li>
          <a
            href="https://www.therapiemosaic.com"
            target="_blank"
            rel="noopener noreferrer"
            class="text-link">Site officiel therapiemosaic.com</a
          >
        </li>
        <li>
          <a
            href="https://www.therapiemosaic.com/formations/mosaic-de-reference-1759841379915"
            target="_blank"
            rel="noopener noreferrer"
            class="text-link">Formation MOSAIC de référence</a
          >
        </li>
      </ul>
      <p class="mb-3">Document pratique :</p>
      <a
        href={MosaicPractitionerPdf}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-surface-raised border border-border-strong rounded-lg p-4 hover:shadow-lg transition-shadow"
      >
        <div class="flex flex-col items-center gap-2">
          <div class="flex h-28 w-20 items-center justify-center rounded border border-border-strong bg-linear-to-br from-surface-muted to-border-subtle">
            <svg
              class="h-6 w-6 text-ink-secondary"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2Z"></path>
              <path d="M14 2v6h6"></path>
            </svg>
          </div>
          <span class="text-sm font-medium text-ink-secondary text-center"
            >Ici votre praticien MOSAIC</span
          >
        </div>
      </a>
    </div>

    <div class="border-t border-border-subtle pt-10 mt-10 flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center">
      <p class="typo-meta text-ink-tertiary uppercase tracking-wider">Affiliations &amp; méthodes</p>
      <Image
        src={MosaicFormationImage}
        alt="Thérapie MOSAIC — référence de formation"
        class="h-6 w-auto opacity-90"
        loading="lazy"
      />
    </div>
  </section>
</Layout>

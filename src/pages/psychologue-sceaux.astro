---
import Layout from "../layouts/BlogPost.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { buttonClasses } from "../components/ui/button";
import {
  CABINET_ADDRESS_LINE,
  DOCTOLIB_BOOKING_URL,
  GOOGLE_MAPS_CABINET_URL,
  GOOGLE_MAPS_EMBED_URL,
  LEGAL_ENTITY_NAME,
  NEARBY_CITIES,
  RPPS_NUMBER,
  SERVED_CITIES_LABEL,
  SIRET_NUMBER,
  CONTACT_EMAIL,
  OPENING_HOURS_SCHEMA,
  OPENING_HOURS_TEXT,
} from "../consts";

const title = "Psychologue à Sceaux";
const description =
  "Psychologue à Sceaux : cabinet rue Houdan, proche RER Robinson. Adultes, adolescents et couples.";

const isProd = import.meta.env.PROD;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Où se trouve le cabinet de psychologie à Sceaux ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `Le cabinet est situé au ${CABINET_ADDRESS_LINE}, dans le centre-ville, à quelques minutes à pied des gares RER B Robinson et Sceaux. Le parking Penthièvre se trouve sur la même rue.`,
      },
    },
    {
      "@type": "Question",
      name: "Quelles consultations sont proposées au cabinet de Sceaux ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Le cabinet propose des consultations individuelles pour adultes et adolescents, des séances MOSAIC, des thérapies de couple, des consultations en visioconférence et des groupes de pleine conscience et de gestion du stress.",
      },
    },
    {
      "@type": "Question",
      name: "Comment prendre rendez-vous avec un psychologue à Sceaux ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `La prise de rendez-vous se fait en ligne via Doctolib. Les consultations ont lieu uniquement sur rendez-vous, ${OPENING_HOURS_TEXT}.`,
      },
    },
    {
      "@type": "Question",
      name: "Recevez-vous des patients des villes voisines de Sceaux ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `Oui. Le cabinet reçoit des personnes habitant Sceaux et les communes voisines : ${NEARBY_CITIES} ou Le Plessis-Robinson. Des consultations en ligne sont également possibles si vous préférez ne pas vous déplacer.`,
      },
    },
    {
      "@type": "Question",
      name: "Quels sont les tarifs des consultations ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "La consultation individuelle est à 80 €, la séance MOSAIC à 90 € et la consultation de couple à 110 €. Le détail des tarifs et des durées est disponible sur la page Tarifs.",
      },
    },
  ],
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService", "MedicalBusiness"],
  "@id": "https://nicolas-devaux-psychologue.fr/psychologue-sceaux/#cabinet",
  name: "Nicolas Devaux, psychologue à Sceaux",
  legalName: LEGAL_ENTITY_NAME,
  url: "https://nicolas-devaux-psychologue.fr/psychologue-sceaux/",
  telephone: "+33629341367",
  email: CONTACT_EMAIL,
  taxID: SIRET_NUMBER,
  identifier: [
    {
      "@type": "PropertyValue",
      propertyID: "RPPS",
      value: RPPS_NUMBER,
    },
    {
      "@type": "PropertyValue",
      propertyID: "SIRET",
      value: SIRET_NUMBER,
    },
  ],
  address: {
    "@type": "PostalAddress",
    streetAddress: "63 rue Houdan",
    addressLocality: "Sceaux",
    postalCode: "92330",
    addressRegion: "Île-de-France",
    addressCountry: "FR",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 48.7764,
    longitude: 2.2903,
  },
  hasMap: GOOGLE_MAPS_CABINET_URL,
  areaServed: [
    { "@type": "City", name: "Sceaux" },
    { "@type": "City", name: "Le Plessis-Robinson" },
    { "@type": "City", name: "Antony" },
    { "@type": "City", name: "Bourg-la-Reine" },
    { "@type": "City", name: "Châtenay-Malabry" },
    { "@type": "City", name: "Fontenay-aux-Roses" },
    { "@type": "City", name: "Bagneux" },
    { "@type": "City", name: "Cachan" },
    { "@type": "City", name: "L'Haÿ-les-Roses" },
    { "@type": "AdministrativeArea", name: "Hauts-de-Seine" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "€€",
  makesOffer: [
    {
      "@type": "Offer",
      name: "Consultation individuelle",
      price: 80,
      priceCurrency: "EUR",
      url: "https://nicolas-devaux-psychologue.fr/tarifs/",
    },
    {
      "@type": "Offer",
      name: "Séance MOSAIC",
      price: 90,
      priceCurrency: "EUR",
      url: "https://nicolas-devaux-psychologue.fr/tarifs/",
    },
    {
      "@type": "Offer",
      name: "Consultation de couple",
      price: 110,
      priceCurrency: "EUR",
      url: "https://nicolas-devaux-psychologue.fr/tarifs/",
    },
    {
      "@type": "Offer",
      name: "Participation aux groupes de pleine conscience",
      price: 30,
      priceCurrency: "EUR",
      url: "https://nicolas-devaux-psychologue.fr/tarifs/",
    },
  ],
  sameAs: [
    "https://www.doctolib.fr/psychologue/sceaux/nicolas-devaux-sceaux",
    "https://www.linkedin.com/in/nicodev3/",
  ],
};

const primaryCtaClasses = buttonClasses({
  variant: "primary",
  size: "lg",
  className: "w-full justify-center sm:w-auto",
});

const secondaryCtaClasses = buttonClasses({
  variant: "secondary",
  size: "lg",
  className: "w-full justify-center sm:w-auto",
});
---

<Layout title={title} description={description} pubDate={new Date("May 24 2026")} showDate={false}>
  <!--email_off-->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <!--/email_off-->
  {isProd && <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <section class="space-y-10">
    <header class="space-y-5">
      <p class="typo-eyebrow">Cabinet de psychologie à Sceaux (92330)</p>
      <p class="typo-body-lg text-ink-secondary">
        Je suis <a href="/nicolas-devaux-psychologue/" class="text-link">Nicolas Devaux</a>, psychologue
        clinicien. Je reçois au cabinet, au <strong class="text-ink-primary">{CABINET_ADDRESS_LINE}</strong>,
        pour des consultations destinées aux adultes, adolescents et couples — en présentiel ou en
        visioconférence.
      </p>
      <p class="typo-body text-ink-secondary">
        Le cabinet est situé dans le centre de Sceaux, à quelques minutes des gares RER B
        <strong class="text-ink-primary">Robinson</strong> et
        <strong class="text-ink-primary">Sceaux</strong>, et facilement accessible depuis Le
        Plessis-Robinson et les communes voisines.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={DOCTOLIB_BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class={primaryCtaClasses}
          data-track-doctolib
          data-track-location="Psychologue Sceaux intro"
        >
          Prendre rendez-vous
        </a>
        <a href={GOOGLE_MAPS_CABINET_URL} target="_blank" rel="noopener noreferrer" class={secondaryCtaClasses}>
          Voir l'itinéraire
        </a>
      </div>
    </header>

    <section class="space-y-4">
      <SectionHeading eyebrow="01 — Localisation" title="Un psychologue dans le centre de Sceaux" />
      <p>
        Le cabinet est installé rue Houdan, dans un secteur calme du centre-ville de Sceaux. Cette
        adresse est pratique si vous habitez Sceaux, mais aussi si vous venez des communes limitrophes :
        {NEARBY_CITIES}, Le Plessis-Robinson, Bagneux ou Cachan.
      </p>
      <p>
        Vous pouvez venir à pied depuis le centre de Sceaux, en RER B (arrêts Robinson ou Sceaux), ou en
        voiture — le parking Penthièvre, rue Houdan, se trouve à proximité immédiate.
      </p>
      <p>
        Les consultations se font uniquement sur rendez-vous. Lors du premier entretien, nous clarifions
        votre demande et définissons ensemble le cadre de travail le plus adapté.
      </p>
    </section>

    <section class="space-y-4">
      <SectionHeading eyebrow="02 — Zone desservie" title="Psychologue à Sceaux et alentours" />
      <p>
        De nombreuses personnes consultent depuis Sceaux et les villes voisines des Hauts-de-Seine. Le
        cabinet accueille notamment des patients venant de : {SERVED_CITIES_LABEL}.
      </p>
      <p>
        Si vous recherchez un psychologue près de Sceaux, du Plessis-Robinson ou d'Antony, cette page
        détaille l'accès au cabinet, les modalités de consultation et les approches proposées.
      </p>
    </section>

    <section class="space-y-4">
      <SectionHeading eyebrow="03 — Consultations" title="Les consultations proposées au cabinet" />
      <p>
        Selon votre demande, plusieurs cadres de travail sont possibles. Chaque consultation est présentée
        en détail sur une page dédiée :
      </p>
      <ul>
        <li>
          <a href="/therapie-mosaic/" class="text-link">Thérapie MOSAIC à Sceaux</a> — pour les
          mémoires douloureuses, les vécus traumatiques et les réactions émotionnelles qui restent trop
          intenses.
        </li>
        <li>
          <a href="/therapie-couple/" class="text-link">Thérapie de couple à Sceaux</a> — pour les conflits
          répétés, les crises et les difficultés de communication.
        </li>
        <li>
          <a href="/psychologue-en-ligne/" class="text-link">Consultation avec un psychologue en ligne</a> —
          en visioconférence, si vous êtes éloigné de Sceaux ou que vous préférez ce format.
        </li>
        <li>
          <a href="/meditation-pleine-conscience-sceaux/" class="text-link"
            >Groupes de pleine conscience et gestion du stress</a
          > — des ateliers en petit groupe, en cycles de 8 séances.
        </li>
        <li>
          <a href="/psychotherapie/" class="text-link">Psychothérapie individuelle</a> — un accompagnement
          adapté à votre situation, à votre rythme et à vos objectifs.
        </li>
      </ul>
    </section>

    <section class="space-y-4">
      <SectionHeading eyebrow="04 — Accès" title="Accès au cabinet" />
      <p>
        <strong>Adresse :</strong> {CABINET_ADDRESS_LINE}.
      </p>
      <ul>
        <li><strong>RER B :</strong> gares Robinson ou Sceaux (ligne Paris – Robinson).</li>
        <li><strong>Bus :</strong> lignes desservant le centre de Sceaux (selon votre point de départ).</li>
        <li><strong>Voiture :</strong> parking Penthièvre, rue Houdan.</li>
      </ul>
      <div class="overflow-hidden rounded-xl border border-border-subtle bg-surface-muted">
        <iframe
          src={GOOGLE_MAPS_EMBED_URL}
          class="min-h-[280px] w-full border-0 md:min-h-[360px]"
          title={`Carte du cabinet — ${CABINET_ADDRESS_LINE}`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
      <p>
        Pour préparer votre venue, consultez aussi la page
        <a href="/consulter/" class="text-link">Consulter</a> (premier rendez-vous, durée des séances,
        visioconférence).
      </p>
    </section>

    <section class="space-y-4">
      <SectionHeading eyebrow="05 — Pratique" title="Horaires, tarifs et rendez-vous" />
      <p>
        Les consultations ont lieu le lundi, le mardi et le vendredi de 8h à 19h, et un samedi matin sur deux, sur rendez-vous. Les séances
        individuelles durent 45 minutes ; les séances de couple et les séances MOSAIC durent 1 heure.
      </p>
      <p>
        Les tarifs détaillés sont sur la page <a href="/tarifs/" class="text-link">Tarifs</a>. La réservation
        se fait en ligne via Doctolib.
      </p>
      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          href={DOCTOLIB_BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class={primaryCtaClasses}
          data-track-doctolib
          data-track-location="Psychologue Sceaux pratique"
        >
          Prendre rendez-vous au cabinet
        </a>
        <a href="/consulter/" class={secondaryCtaClasses}>Préparer votre première consultation</a>
      </div>
    </section>

    <section class="space-y-4">
      <SectionHeading eyebrow="06 — FAQ" title="Questions fréquentes" />

      <h3 class="font-display typo-display-md text-ink-primary">Où se trouve le cabinet de psychologie à Sceaux ?</h3>
      <p>
        Le cabinet est situé au {CABINET_ADDRESS_LINE}, dans le centre-ville, à quelques minutes à pied des
        gares RER B Robinson et Sceaux. Le parking Penthièvre se trouve sur la même rue.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">
        Quelles consultations sont proposées au cabinet de Sceaux ?
      </h3>
      <p>
        Le cabinet propose des consultations individuelles pour adultes et adolescents, des séances
        <a href="/therapie-mosaic/" class="text-link">MOSAIC</a>, des
        <a href="/therapie-couple/" class="text-link">thérapies de couple</a>, des
        <a href="/psychologue-en-ligne/" class="text-link">consultations en visioconférence</a> et des
        <a href="/meditation-pleine-conscience-sceaux/" class="text-link"
          >groupes de pleine conscience et de gestion du stress</a
        >.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">
        Comment prendre rendez-vous avec un psychologue à Sceaux ?
      </h3>
      <p>
        La prise de rendez-vous se fait en ligne via Doctolib. Les consultations ont lieu uniquement sur
        rendez-vous, {OPENING_HOURS_TEXT}.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">
        Recevez-vous des patients des villes voisines de Sceaux ?
      </h3>
      <p>
        Oui. Le cabinet reçoit des personnes habitant Sceaux et les communes voisines : {NEARBY_CITIES} ou
        Le Plessis-Robinson. Des consultations en ligne sont également possibles si vous préférez ne pas vous
        déplacer.
      </p>

      <h3 class="font-display typo-display-md mt-5 text-ink-primary">Quels sont les tarifs des consultations ?</h3>
      <p>
        La consultation individuelle est à 80 €, la séance MOSAIC à 90 € et la consultation de couple à
        110 €. Le détail des tarifs et des durées est disponible sur la page
        <a href="/tarifs/" class="text-link">Tarifs</a>.
      </p>
    </section>
  </section>
</Layout>

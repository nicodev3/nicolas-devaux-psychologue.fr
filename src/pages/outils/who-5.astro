---
import FormLayout from "../../layouts/FormLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buttonClasses } from "../../components/ui/button";

const title = "WHO-5 — Indice de bien-être de l'OMS";
const description =
  "Passez en ligne le WHO-5, questionnaire validé de l'OMS pour évaluer votre bien-être mental au cours des deux dernières semaines.";

const SCALE = [
  [0, "À aucun moment"],
  [1, "De temps en temps"],
  [2, "Moins de la moitié du temps"],
  [3, "Plus de la moitié du temps"],
  [4, "La plupart du temps"],
  [5, "Tout le temps"],
] as const;
---

<FormLayout title={title} description={description}>
  <div x-data="who5Form" class="w-full">
    <div class="sticky top-14 z-20 mb-6 md:top-18" x-show="!submitted">
      <div class="rounded-lg border border-border-subtle bg-surface-page/95 px-4 py-3 backdrop-blur-sm">
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-xs font-medium text-ink-tertiary">Progression</span>
          <span class="font-ui text-xs font-medium text-ink-secondary">
            <span x-text="answeredCount"></span>/5
          </span>
        </div>
        <div class="h-2 w-full rounded-full bg-surface-muted">
          <div class="h-2 rounded-full bg-brand transition-all duration-300" :style="`width: ${progress}%`"></div>
        </div>
      </div>
    </div>

    <header class="mb-10 md:mb-12">
      <p class="typo-eyebrow mb-3 md:mb-4">WHO-5</p>
      <h1 class="font-display typo-h1 mb-2 text-pretty text-ink-primary md:mb-3">
        Indice de bien-être de l'OMS
      </h1>
      <p class="mb-6 text-sm text-ink-tertiary">
        World Health Organization Five Well-Being Index
      </p>

      <div class="rounded-xl border border-border-subtle bg-secondary/40 p-5 md:p-6">
        <SectionHeading class="mb-4" eyebrow="01 — Consignes" title="Instructions" />
        <p class="mb-4 text-sm leading-relaxed text-ink-secondary">
          Veuillez indiquer, pour chacune des cinq affirmations, celle qui se rapproche le plus de ce que vous avez
          ressenti au cours des <strong>2 dernières semaines</strong>. Plus le chiffre est élevé, meilleur est votre
          bien-être.
        </p>
        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
          {
            SCALE.map(([n, label]) => (
              <div class="flex items-start gap-2.5">
                <span class="font-ui flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-strong bg-surface-raised text-xs font-medium text-tertiary">
                  {n}
                </span>
                <span class="leading-snug text-ink-secondary">{label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <p class="mt-4 flex items-center gap-1.5 text-xs text-ink-tertiary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4M12 8h.01"></path>
        </svg>
        Vos réponses sont sauvegardées automatiquement dans votre navigateur. Vous pouvez reprendre le questionnaire
        plus tard.
      </p>
    </header>

    <div id="results" x-show="submitted" class="print-results mb-8 rounded-xl border border-border-subtle p-8">
      <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-start">
        <div>
          <SectionHeading class="mb-1" eyebrow="02 — Synthèse" title="Résultats" />
          <p class="text-sm text-ink-tertiary">WHO-5 — Indice de bien-être de l'OMS</p>
        </div>
        <div class="no-print flex shrink-0 gap-2">
          <button
            onclick="window.print()"
            type="button"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className: "gap-1.5 font-normal normal-case text-ink-secondary",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M17 17h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2m2 4h6a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2Zm8-12V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4h10Z"
              ></path>
            </svg>
            Imprimer
          </button>
          <button
            type="button"
            @click="reset()"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className:
                "gap-1.5 border-danger bg-danger-surface font-normal normal-case text-danger hover:bg-border-subtle",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15"
              ></path>
            </svg>
            Recommencer
          </button>
        </div>
      </div>

      <p class="mb-6 rounded-lg bg-secondary/40 p-4 text-sm text-ink-secondary">
        Ces résultats sont destinés à être partagés avec votre psychologue. Un score bas peut indiquer un bien-être
        mental fragile et justifier une exploration plus approfondie.
        <strong>Ils ne constituent pas un diagnostic.</strong>
      </p>

      <div
        x-show="percentageScore < 50"
        x-cloak
        class="mb-6 rounded-xl border border-orange-200 bg-orange-50 p-4 text-sm text-orange-800"
        role="status"
      >
        Un score inférieur à 50 sur 100 peut indiquer un bien-être médiocre et justifier une évaluation complémentaire
        (par exemple avec le <a href="/outils/phq-9-gad-7/" class="text-link font-medium">PHQ-9 et le GAD-7</a>).
      </div>

      <div class="mb-8 rounded-xl border border-border-subtle p-5">
        <h3 class="typo-display-md mb-1 text-ink-primary">Score de bien-être</h3>
        <p class="mb-4 text-xs text-ink-tertiary">Score brut sur 25 · Score en pourcentage sur 100</p>
        <div class="mb-4 flex flex-wrap items-end gap-4">
          <div>
            <span class="font-display text-4xl text-ink-primary" x-text="rawScore"></span>
            <span class="text-lg text-ink-tertiary">/25</span>
          </div>
          <div>
            <span class="font-display text-4xl text-ink-primary" x-text="percentageScore"></span>
            <span class="text-lg text-ink-tertiary">%</span>
          </div>
          <span
            class="rounded-full px-2.5 py-1 text-xs font-medium"
            :class="wellbeingBadgeClass"
            x-text="wellbeingLabel"
          ></span>
        </div>
        <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
          <div
            class="h-3 rounded-full transition-all duration-700"
            :class="wellbeingBarClass"
            :style="`width: ${percentageScore}%`"
          ></div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-red-100 px-2.5 py-1 font-medium text-red-700">0–28 % : Très faible</span>
        <span class="rounded-full bg-orange-100 px-2.5 py-1 font-medium text-orange-700">29–48 % : Faible</span>
        <span class="rounded-full bg-yellow-100 px-2.5 py-1 font-medium text-yellow-700">49–68 % : Modéré</span>
        <span class="rounded-full bg-lime-100 px-2.5 py-1 font-medium text-lime-700">69–88 % : Bon</span>
        <span class="rounded-full bg-green-100 px-2.5 py-1 font-medium text-green-700">89–100 % : Très bon</span>
      </div>
    </div>

    <form id="form-container" @submit.prevent="submit()" x-show="!submitted">
      <div class="mb-6 overflow-hidden rounded-xl border border-border-subtle">
        <div class="border-b border-border-subtle bg-secondary/50 px-6 py-4">
          <h3 class="typo-display-md m-0 text-ink-primary">Cinq affirmations</h3>
        </div>
        <div class="divide-y divide-border-subtle">
          <template x-for="(question, qi) in questions" :key="qi">
            <div
              class="px-4 py-4 transition-colors duration-150 sm:px-6"
              :class="answers[qi + 1] >= 0 ? 'bg-green-50/40' : ''"
            >
              <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
                <p class="m-0 flex-1 text-sm leading-relaxed text-ink-secondary">
                  <span class="mr-1.5 font-medium text-ink-tertiary" x-text="(qi + 1) + '.'"></span>
                  <span x-text="question"></span>
                </p>
                <div class="flex shrink-0 flex-wrap gap-1.5">
                  <template x-for="scale in [0, 1, 2, 3, 4, 5]" :key="scale">
                    <label class="cursor-pointer select-none">
                      <input
                        type="radio"
                        :name="'q' + (qi + 1)"
                        :value="scale"
                        x-model.number="answers[qi + 1]"
                        @change="saveAnswers()"
                        class="sr-only"
                      />
                      <span
                        class="font-ui flex h-9 w-9 items-center justify-center rounded-full border-2 text-sm font-medium transition-all duration-150"
                        :class="scaleClass(answers[qi + 1], scale)"
                        x-text="scale"
                      ></span>
                    </label>
                  </template>
                </div>
              </div>
            </div>
          </template>
        </div>
      </div>

      <div
        x-show="showWarning"
        x-transition
        class="mb-6 flex items-start gap-2 rounded-xl border border-info-border bg-info-surface p-4 text-sm text-info-ink"
      >
        <span
          class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-info-border bg-surface-raised text-info-ink"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
        </span>
        <span>
          <strong>Questionnaire incomplet :</strong>
          vous avez répondu à <span x-text="answeredCount"></span> question(s) sur 5. Veuillez répondre à toutes les
          questions pour obtenir vos résultats.
        </span>
      </div>

      <div class="mb-8 text-center">
        <button
          type="submit"
          class={buttonClasses({ variant: "primary", size: "lg", className: "gap-2 normal-case" })}
        >
          Calculer mes résultats
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <footer class="mt-4 border-t border-border-subtle pt-6 text-xs leading-relaxed text-ink-tertiary">
      <p>
        WHO-5 : Bech, P., Olsen, L.R., Kjoller, M. &amp; Rasmussen, N.K. (2003). Measuring well-being rather than
        absence of distress symptoms. <em>Psychotherapy and Psychosomatics</em>, 72(5), 268–274.
      </p>
      <p class="mt-2">
        WHO Collaborating Centre for Mental Health. (1998). WHO (Five) Well-Being Index. Psychiatric Research Unit,
        WHO Collaborating Centre for Mental Health, Frederiksborg, Denmark.
      </p>
    </footer>
  </div>
</FormLayout>

<style>
  @media print {
    header,
    footer,
    nav,
    .no-print,
    #form-container {
      display: none !important;
    }
    .print-results {
      display: block !important;
    }
    body {
      background: white !important;
    }
  }
</style>

<script is:inline>
document.addEventListener('alpine:init', () => {
  const QUESTIONS = [
    "Je me suis senti(e) bien et de bonne humeur.",
    "Je me suis senti(e) calme et détendu(e).",
    "Je me suis senti(e) actif(ve) et vigoureux(se).",
    "Je me suis réveillé(e) en me sentant frais(che) et disposé(e).",
    "Ma vie quotidienne a été remplie de choses qui m'intéressent.",
  ];

  Alpine.data('who5Form', () => ({
    questions: QUESTIONS,
    answers: new Array(6).fill(-1),
    submitted: false,
    showWarning: false,

    get answeredCount() {
      let count = 0;
      for (let i = 1; i <= 5; i++) {
        if (this.answers[i] >= 0) count++;
      }
      return count;
    },

    get progress() {
      return Math.round((this.answeredCount / 5) * 100);
    },

    get rawScore() {
      let total = 0;
      for (let i = 1; i <= 5; i++) total += this.answers[i];
      return total;
    },

    get percentageScore() {
      return this.rawScore * 4;
    },

    get wellbeingLevel() {
      const pct = this.percentageScore;
      if (pct <= 28) return 'very-low';
      if (pct <= 48) return 'low';
      if (pct <= 68) return 'moderate';
      if (pct <= 88) return 'good';
      return 'very-good';
    },

    get wellbeingLabel() {
      const labels = {
        'very-low': 'Très faible',
        low: 'Faible',
        moderate: 'Modéré',
        good: 'Bon',
        'very-good': 'Très bon',
      };
      return labels[this.wellbeingLevel];
    },

    get wellbeingBadgeClass() {
      const level = this.wellbeingLevel;
      if (level === 'very-low') return 'bg-red-100 text-red-700';
      if (level === 'low') return 'bg-orange-100 text-orange-700';
      if (level === 'moderate') return 'bg-yellow-100 text-yellow-700';
      if (level === 'good') return 'bg-lime-100 text-lime-700';
      return 'bg-green-100 text-green-700';
    },

    get wellbeingBarClass() {
      const level = this.wellbeingLevel;
      if (level === 'very-low') return 'bg-red-500';
      if (level === 'low') return 'bg-orange-500';
      if (level === 'moderate') return 'bg-yellow-400';
      if (level === 'good') return 'bg-lime-400';
      return 'bg-green-400';
    },

    scaleClass(answer, scale) {
      return answer === scale
        ? 'border-brand bg-brand text-brand-ink-on shadow-sm'
        : 'border-border-strong text-ink-tertiary hover:border-brand hover:text-brand cursor-pointer';
    },

    saveAnswers() {
      try { localStorage.setItem('who-5', JSON.stringify(this.answers)); } catch (e) {}
    },

    submit() {
      if (this.answeredCount < 5) {
        this.showWarning = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      this.submitted = true;
      this.saveAnswers();
      this.$nextTick(() => {
        const el = document.getElementById('results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    },

    reset() {
      if (!confirm('Voulez-vous recommencer le questionnaire ? Toutes vos réponses seront perdues.')) return;
      this.answers = new Array(6).fill(-1);
      this.submitted = false;
      this.showWarning = false;
      try { localStorage.removeItem('who-5'); } catch (e) {}
      window.scrollTo({ top: 0, behavior: 'smooth' });
    },

    init() {
      try {
        const saved = localStorage.getItem('who-5');
        if (saved) {
          const data = JSON.parse(saved);
          if (Array.isArray(data) && data.length === 6) this.answers = data;
        }
      } catch (e) {}
    },
  }));
});
</script>

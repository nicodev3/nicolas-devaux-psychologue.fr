---
import FormLayout from "../../layouts/FormLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buttonClasses } from "../../components/ui/button";

const title = "FSCRS — Autocritique et auto-apaisement";
const description =
  "Passez le FSCRS en ligne : 22 items pour explorer l'autocritique et la capacité à se rassurer.";

const SCALE = [
  [0, "Pas du tout comme moi"],
  [1, "Un peu comme moi"],
  [2, "Modérément comme moi"],
  [3, "Assez comme moi"],
  [4, "Extrêmement comme moi"],
] as const;
---

<FormLayout title={title} description={description}>
  <div x-data="fscrsForm" class="w-full">
    <div class="sticky top-14 z-20 mb-6 md:top-18" x-show="!submitted">
      <div class="rounded-lg border border-border-subtle bg-surface-page/95 px-4 py-3 backdrop-blur-sm">
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-xs font-medium text-ink-tertiary">Progression</span>
          <span class="font-ui text-xs font-medium text-ink-secondary">
            <span x-text="answeredCount"></span>/22
          </span>
        </div>
        <div class="h-2 w-full rounded-full bg-surface-muted">
          <div class="h-2 rounded-full bg-brand transition-all duration-300" :style="`width: ${progress}%`"></div>
        </div>
      </div>
    </div>

    <header class="mb-10 md:mb-12">
      <p class="typo-eyebrow mb-3 md:mb-4">FSCRS</p>
      <h1 class="font-display typo-h1 mb-2 text-pretty text-ink-primary md:mb-3">
        Autocritique et auto-apaisement
      </h1>
      <p class="mb-6 text-sm text-ink-tertiary">
        Forms of Self-Criticising/Attacking &amp; Self-Reassuring Scale
      </p>

      <div class="rounded-xl border border-border-subtle bg-secondary/40 p-5 md:p-6">
        <SectionHeading class="mb-4" eyebrow="01 — Consignes" title="Instructions" />
        <p class="mb-4 text-sm leading-relaxed text-ink-secondary">
          Quand les choses tournent mal dans notre vie ou ne se passent pas comme nous l'espérions, et que nous
          sentons que nous aurions pu faire mieux, nous avons parfois des pensées et des sentiments négatifs et
          autocritiques. Ces pensées peuvent prendre la forme de sentiments d'infériorité ou d'inutilité. Cependant,
          les gens peuvent aussi essayer d'être bienveillants envers eux-mêmes.
        </p>
        <p class="mb-4 text-sm leading-relaxed text-ink-secondary">
          Ci-dessous se trouve une série de pensées et de sentiments que les gens éprouvent parfois. Lisez chaque
          affirmation attentivement et indiquez dans quelle mesure elle vous correspond, en pensant à la situation
          <strong>« Quand les choses tournent mal pour moi… »</strong>
        </p>
        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
          {
            SCALE.map(([n, label]) => (
              <div class="flex items-start gap-2.5">
                <span class="font-ui flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-strong bg-surface-raised text-xs font-medium text-tertiary">
                  {n}
                </span>
                <span class="leading-snug text-ink-secondary">{label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <p class="mt-4 flex items-center gap-1.5 text-xs text-ink-tertiary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4M12 8h.01"></path>
        </svg>
        Vos réponses sont sauvegardées automatiquement dans votre navigateur. Vous pouvez reprendre le questionnaire
        plus tard.
      </p>
    </header>

    <div id="results" x-show="submitted" class="print-results mb-8 rounded-xl border border-border-subtle p-8">
      <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-start">
        <div>
          <SectionHeading class="mb-1" eyebrow="02 — Synthèse" title="Résultats" />
          <p class="text-sm text-ink-tertiary">FSCRS — Autocritique et auto-apaisement</p>
        </div>
        <div class="no-print flex shrink-0 gap-2">
          <button
            onclick="window.print()"
            type="button"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className: "gap-1.5 font-normal normal-case text-ink-secondary",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M17 17h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2m2 4h6a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2Zm8-12V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4h10Z"
              ></path>
            </svg>
            Imprimer
          </button>
          <button
            type="button"
            @click="reset()"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className:
                "gap-1.5 border-danger bg-danger-surface font-normal normal-case text-danger hover:bg-border-subtle",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15"
              ></path>
            </svg>
            Recommencer
          </button>
        </div>
      </div>

      <p class="mb-6 rounded-lg bg-secondary/40 p-4 text-sm text-ink-secondary">
        Ces résultats explorent trois dimensions de votre relation à vous-même face aux difficultés : sentiment
        d'inadéquation, hostilité envers soi et capacité à se rassurer. Ils sont destinés à être partagés avec votre
        psychologue.
        <strong>Ils ne constituent pas un diagnostic.</strong>
      </p>

      <div class="mb-8 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border-subtle p-5 sm:col-span-2">
          <h3 class="typo-display-md mb-1 text-ink-primary">Autocritique globale</h3>
          <p class="mb-4 text-xs text-ink-tertiary">Soi inadéquat + Soi haï · Score sur 56</p>
          <div class="mb-4 flex flex-wrap items-end gap-4">
            <div>
              <span class="font-display text-4xl text-ink-primary" x-text="criticismScore"></span>
              <span class="text-lg text-ink-tertiary">/56</span>
            </div>
            <span
              class="rounded-full px-2.5 py-1 text-xs font-medium"
              :class="criticismBadgeClass"
              x-text="criticismLabel"
            ></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
            <div
              class="h-3 rounded-full transition-all duration-700"
              :class="criticismBarClass"
              :style="`width: ${criticismPercent}%`"
            ></div>
          </div>
        </div>

        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">Soi inadéquat</p>
          <p class="mb-2 text-sm text-ink-secondary">Sentiment d'échec et d'insuffisance</p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="isScore"></span><span class="text-base text-ink-tertiary">/36</span>
          </p>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-surface-muted">
            <div class="h-2 rounded-full bg-red-400 transition-all duration-700" :style="`width: ${isPercent}%`"></div>
          </div>
        </div>

        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">Soi haï</p>
          <p class="mb-2 text-sm text-ink-tertiary">Hostilité, dégoût ou désir de se punir</p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="hsScore"></span><span class="text-base text-ink-tertiary">/20</span>
          </p>
          <div class="mt-3 h-2 overflow-hidden rounded-full bg-surface-muted">
            <div class="h-2 rounded-full bg-red-500 transition-all duration-700" :style="`width: ${hsPercent}%`"></div>
          </div>
        </div>

        <div class="rounded-xl border border-border-subtle p-4 sm:col-span-2">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">Soi apaisé</p>
          <p class="mb-2 text-sm text-ink-secondary">Capacité à se rassurer et à se soutenir</p>
          <div class="mb-3 flex flex-wrap items-end gap-3">
            <p class="font-display text-2xl text-ink-primary">
              <span x-text="rsScore"></span><span class="text-base text-ink-tertiary">/32</span>
            </p>
            <span
              class="rounded-full px-2.5 py-1 text-xs font-medium"
              :class="reassuranceBadgeClass"
              x-text="reassuranceLabel"
            ></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
            <div
              class="h-3 rounded-full transition-all duration-700"
              :class="reassuranceBarClass"
              :style="`width: ${rsPercent}%`"
            ></div>
          </div>
        </div>
      </div>

      <p class="mb-4 text-sm text-ink-secondary">
        En savoir plus sur la
        <a href="/therapie-fondee-compassion/" class="text-link font-medium">thérapie fondée sur la compassion (CFT)</a>,
        une approche qui travaille notamment l'autocritique et l'auto-compassion.
      </p>

      <div class="flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-green-100 px-2.5 py-1 font-medium text-green-700">Soi apaisé élevé = plus d'auto-soutien</span>
        <span class="rounded-full bg-red-100 px-2.5 py-1 font-medium text-red-700">Autocritique élevée = plus de difficulté face aux échecs</span>
      </div>
      <p class="mt-3 text-xs text-ink-tertiary">
        Les seuils affichés sont indicatifs. Il n'existe pas de coupure diagnostique officielle pour le FSCRS.
      </p>
    </div>

    <form id="form-container" @submit.prevent="submit()" x-show="!submitted">
      <div class="mb-6 overflow-hidden rounded-xl border border-border-subtle">
        <div class="border-b border-border-subtle bg-secondary/50 px-6 py-4">
          <h3 class="typo-display-md m-0 text-ink-primary">22 affirmations</h3>
          <p class="mb-0 mt-1 text-sm text-ink-tertiary">Quand les choses tournent mal pour moi…</p>
        </div>
        <div class="divide-y divide-border-subtle">
          <template x-for="(question, qi) in questions" :key="qi">
            <div
              class="px-4 py-4 transition-colors duration-150 sm:px-6"
              :class="answers[qi + 1] >= 0 ? 'bg-green-50/40' : ''"
            >
              <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
                <p class="m-0 flex-1 text-sm leading-relaxed text-ink-secondary">
                  <span class="mr-1.5 font-medium text-ink-tertiary" x-text="(qi + 1) + '.'"></span>
                  <span x-text="question"></span>
                </p>
                <div class="flex shrink-0 flex-wrap gap-1">
                  <template x-for="scale in [0, 1, 2, 3, 4]" :key="scale">
                    <label class="cursor-pointer select-none">
                      <input
                        type="radio"
                        :name="'q' + (qi + 1)"
                        :value="scale"
                        x-model.number="answers[qi + 1]"
                        @change="saveAnswers()"
                        class="sr-only"
                      />
                      <span
                        class="font-ui flex h-8 w-8 items-center justify-center rounded-full border-2 text-xs font-medium transition-all duration-150 sm:h-9 sm:w-9 sm:text-sm"
                        :class="scaleClass(answers[qi + 1], scale)"
                        x-text="scale"
                      ></span>
                    </label>
                  </template>
                </div>
              </div>
            </div>
          </template>
        </div>
      </div>

      <div
        x-show="showWarning"
        x-transition
        class="mb-6 flex items-start gap-2 rounded-xl border border-info-border bg-info-surface p-4 text-sm text-info-ink"
      >
        <span
          class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-info-border bg-surface-raised text-info-ink"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
        </span>
        <span>
          <strong>Questionnaire incomplet :</strong>
          vous avez répondu à <span x-text="answeredCount"></span> question(s) sur 22. Veuillez répondre à toutes les
          questions pour obtenir vos résultats.
        </span>
      </div>

      <div class="mb-8 text-center">
        <button
          type="submit"
          class={buttonClasses({ variant: "primary", size: "lg", className: "gap-2 normal-case" })}
        >
          Calculer mes résultats
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <footer class="mt-4 border-t border-border-subtle pt-6 text-xs leading-relaxed text-ink-tertiary">
      <p>
        FSCRS : Gilbert, P., Clarke, M., Hempel, S., Miles, J.N.V., &amp; Irons, C. (2004). Criticising and reassuring
        oneself: An exploration of forms, styles and reasons in female students.
        <em>British Journal of Clinical Psychology</em>, 43(1), 31–50.
      </p>
      <p class="mt-2">
        Version française : Gheysen, F., Katis, S., Lee, M., &amp; Delamillieure, P. (2015). Revalidation par Leboeuf,
        I., Mahanga, J., Rusinek, S., Delamillieure, P., Gheysen, F., Andreotti, E., &amp; Antoine, P. (2020).
        Validation of the French version of the Forms of Self-Criticizing/Attacking and Self-Reassuring Scale.
        <em>Stress and Health</em>, 36(1), 31–36.
      </p>
      <p class="mt-2">
        Reproduction soumise à autorisation de la Compassionate Mind Foundation. Contact :
        <a href="https://www.compassionatemind.co.uk/" class="text-link">compassionatemind.co.uk</a>.
      </p>
    </footer>
  </div>
</FormLayout>

<style>
  @media print {
    header,
    footer,
    nav,
    .no-print,
    #form-container {
      display: none !important;
    }
    .print-results {
      display: block !important;
    }
    body {
      background: white !important;
    }
  }
</style>

<script is:inline>
document.addEventListener('alpine:init', () => {
  const QUESTIONS = [
    "Je suis facilement déçu(e) de moi-même.",
    "Il y a une partie de moi qui me rabaisse.",
    "Je suis capable de me rappeler les aspects positifs de moi-même.",
    "J'ai du mal à contrôler ma colère et ma frustration envers moi-même.",
    "Je trouve facile de me pardonner.",
    "Il y a une partie de moi qui sent qu'elle n'est pas assez bonne.",
    "Je me sens accablé(e) par mes pensées autocritiques.",
    "J'aime toujours être moi.",
    "Je suis devenu(e) si en colère contre moi-même que je veux me faire du mal ou m'injurer.",
    "J'éprouve un sentiment de dégoût envers moi-même.",
    "Je peux encore me sentir aimable et acceptable.",
    "Je cesse de me soucier de moi.",
    "Il m'est facile de m'aimer.",
    "Je me souviens de mes échecs et j'y repense sans cesse.",
    "Je m'insulte.",
    "Je suis doux(ce) et bienveillant(e) envers moi-même.",
    "Je n'arrive pas à accepter les échecs et les revers sans me sentir inadéquat(e).",
    "Je pense que je mérite mon autocritique.",
    "Je suis capable de prendre soin de moi et de m'occuper de moi.",
    "Il y a une partie de moi qui veut se débarrasser des aspects de moi que je n'aime pas.",
    "Je m'encourage pour l'avenir.",
    "Je n'aime pas être moi.",
  ];

  const IS_ITEMS = [1, 2, 4, 6, 7, 14, 17, 18, 20];
  const HS_ITEMS = [9, 10, 12, 15, 22];
  const RS_ITEMS = [3, 5, 8, 11, 13, 16, 19, 21];

  Alpine.data('fscrsForm', () => ({
    questions: QUESTIONS,
    answers: new Array(23).fill(-1),
    submitted: false,
    showWarning: false,

    sumItems(items) {
      let total = 0;
      for (const idx of items) total += this.answers[idx];
      return total;
    },

    percent(score, max) {
      return Math.round((score / max) * 100);
    },

    criticismLevel(percent) {
      if (percent <= 33) return 'low';
      if (percent <= 66) return 'moderate';
      return 'high';
    },

    reassuranceLevel(percent) {
      if (percent <= 33) return 'low';
      if (percent <= 66) return 'moderate';
      return 'high';
    },

    get answeredCount() {
      let count = 0;
      for (let i = 1; i <= 22; i++) {
        if (this.answers[i] >= 0) count++;
      }
      return count;
    },

    get progress() {
      return Math.round((this.answeredCount / 22) * 100);
    },

    get isScore() {
      return this.sumItems(IS_ITEMS);
    },

    get hsScore() {
      return this.sumItems(HS_ITEMS);
    },

    get rsScore() {
      return this.sumItems(RS_ITEMS);
    },

    get criticismScore() {
      return this.isScore + this.hsScore;
    },

    get isPercent() {
      return this.percent(this.isScore, 36);
    },

    get hsPercent() {
      return this.percent(this.hsScore, 20);
    },

    get rsPercent() {
      return this.percent(this.rsScore, 32);
    },

    get criticismPercent() {
      return this.percent(this.criticismScore, 56);
    },

    get criticismLevelValue() {
      return this.criticismLevel(this.criticismPercent);
    },

    get reassuranceLevelValue() {
      return this.reassuranceLevel(this.rsPercent);
    },

    get criticismLabel() {
      const labels = {
        low: 'Autocritique faible',
        moderate: 'Autocritique modérée',
        high: 'Autocritique élevée',
      };
      return labels[this.criticismLevelValue];
    },

    get reassuranceLabel() {
      const labels = {
        low: 'Auto-apaisement faible',
        moderate: 'Auto-apaisement modéré',
        high: 'Auto-apaisement élevé',
      };
      return labels[this.reassuranceLevelValue];
    },

    get criticismBadgeClass() {
      const level = this.criticismLevelValue;
      if (level === 'low') return 'bg-green-100 text-green-700';
      if (level === 'moderate') return 'bg-yellow-100 text-yellow-700';
      return 'bg-red-100 text-red-700';
    },

    get criticismBarClass() {
      const level = this.criticismLevelValue;
      if (level === 'low') return 'bg-green-400';
      if (level === 'moderate') return 'bg-yellow-400';
      return 'bg-red-500';
    },

    get reassuranceBadgeClass() {
      const level = this.reassuranceLevelValue;
      if (level === 'low') return 'bg-red-100 text-red-700';
      if (level === 'moderate') return 'bg-yellow-100 text-yellow-700';
      return 'bg-green-100 text-green-700';
    },

    get reassuranceBarClass() {
      const level = this.reassuranceLevelValue;
      if (level === 'low') return 'bg-red-400';
      if (level === 'moderate') return 'bg-yellow-400';
      return 'bg-green-400';
    },

    scaleClass(answer, scale) {
      return answer === scale
        ? 'border-brand bg-brand text-brand-ink-on shadow-sm'
        : 'border-border-strong text-ink-tertiary hover:border-brand hover:text-brand cursor-pointer';
    },

    saveAnswers() {
      try { localStorage.setItem('fscrs', JSON.stringify(this.answers)); } catch (e) {}
    },

    submit() {
      if (this.answeredCount < 22) {
        this.showWarning = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      this.submitted = true;
      this.saveAnswers();
      this.$nextTick(() => {
        const el = document.getElementById('results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    },

    reset() {
      if (!confirm('Voulez-vous recommencer le questionnaire ? Toutes vos réponses seront perdues.')) return;
      this.answers = new Array(23).fill(-1);
      this.submitted = false;
      this.showWarning = false;
      try { localStorage.removeItem('fscrs'); } catch (e) {}
      window.scrollTo({ top: 0, behavior: 'smooth' });
    },

    init() {
      try {
        const saved = localStorage.getItem('fscrs');
        if (saved) {
          const data = JSON.parse(saved);
          if (Array.isArray(data) && data.length === 23) this.answers = data;
        }
      } catch (e) {}
    },
  }));
});
</script>

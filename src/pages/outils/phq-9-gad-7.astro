---
import FormLayout from "../../layouts/FormLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buttonClasses } from "../../components/ui/button";

const title = "PHQ-9 et GAD-7 — Dépistage dépression et anxiété";
const description =
  "Passez en ligne le PHQ-9 et le GAD-7, questionnaires validés pour évaluer les symptômes dépressifs et anxieux au cours des deux dernières semaines.";

const SCALE = [
  [0, "Pas du tout"],
  [1, "Plusieurs jours"],
  [2, "Plus de la moitié du temps"],
  [3, "Presque tous les jours"],
] as const;
---

<FormLayout title={title} description={description}>
  <div x-data="phqGadForm" class="w-full">
    <div class="sticky top-14 z-20 mb-6 md:top-[4.5rem]" x-show="!submitted">
      <div class="rounded-lg border border-border-subtle bg-surface-page/95 px-4 py-3 backdrop-blur-sm">
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-xs font-medium text-ink-tertiary">Progression</span>
          <span class="font-ui text-xs font-medium text-ink-secondary">
            <span x-text="answeredCount"></span>/16
          </span>
        </div>
        <div class="h-2 w-full rounded-full bg-surface-muted">
          <div class="h-2 rounded-full bg-brand transition-all duration-300" :style="`width: ${progress}%`"></div>
        </div>
      </div>
    </div>

    <header class="mb-10 md:mb-12">
      <p class="typo-eyebrow mb-3 md:mb-4">PHQ-9 · GAD-7</p>
      <h1 class="font-display typo-h1 mb-2 text-pretty text-ink-primary md:mb-3">
        Dépistage dépression et anxiété
      </h1>
      <p class="mb-6 text-sm text-ink-tertiary">
        Questionnaire sur la santé du patient (PHQ-9) et échelle d'anxiété généralisée (GAD-7)
      </p>

      <div class="rounded-xl border border-border-subtle bg-secondary/40 p-5 md:p-6">
        <SectionHeading class="mb-4" eyebrow="01 — Consignes" title="Instructions" />
        <p class="mb-4 text-sm leading-relaxed text-ink-secondary">
          Au cours des <strong>2 dernières semaines</strong>, selon quelle fréquence avez-vous été gêné(e) par les
          problèmes suivants ?
        </p>
        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
          {
            SCALE.map(([n, label]) => (
              <div class="flex items-start gap-2.5">
                <span class="font-ui flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-strong bg-surface-raised text-xs font-medium text-tertiary">
                  {n}
                </span>
                <span class="leading-snug text-ink-secondary">{label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <p class="mt-4 flex items-center gap-1.5 text-xs text-ink-tertiary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4M12 8h.01"></path>
        </svg>
        Vos réponses sont sauvegardées automatiquement dans votre navigateur. Vous pouvez reprendre le questionnaire
        plus tard.
      </p>
    </header>

    <div id="results" x-show="submitted" class="print-results mb-8 rounded-xl border border-border-subtle p-8">
      <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-start">
        <div>
          <SectionHeading class="mb-1" eyebrow="02 — Synthèse" title="Résultats" />
          <p class="text-sm text-ink-tertiary">PHQ-9 et GAD-7 — Dépistage dépression et anxiété</p>
        </div>
        <div class="no-print flex shrink-0 gap-2">
          <button
            onclick="window.print()"
            type="button"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className: "gap-1.5 font-normal normal-case text-ink-secondary",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M17 17h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2m2 4h6a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2Zm8-12V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4h10Z"
              ></path>
            </svg>
            Imprimer
          </button>
          <button
            type="button"
            @click="reset()"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className:
                "gap-1.5 border-danger bg-danger-surface font-normal normal-case text-danger hover:bg-border-subtle",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15"
              ></path>
            </svg>
            Recommencer
          </button>
        </div>
      </div>

      <p class="mb-6 rounded-lg bg-secondary/40 p-4 text-sm text-ink-secondary">
        Ces résultats sont destinés à être partagés avec votre psychologue. Un score élevé indique une présence plus
        marquée de symptômes dépressifs ou anxieux.
        <strong>Ils ne constituent pas un diagnostic.</strong>
      </p>

      <div
        x-show="answers[9] >= 1"
        x-cloak
        class="mb-6 rounded-xl border border-danger bg-danger-surface p-4 text-sm text-danger"
        role="alert"
      >
        <strong>Attention :</strong> vous avez indiqué des pensées liées à la mort ou à vous faire du mal. Si vous êtes en
        détresse, contactez le <strong>3114</strong> (numéro national de prévention du suicide, disponible 24h/24) ou le
        <strong>15</strong> (SAMU). Vous pouvez aussi consulter un professionnel de santé sans attendre.
      </div>

      <div class="mb-8 grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border border-border-subtle p-5">
          <h3 class="typo-display-md mb-1 text-ink-primary">PHQ-9 — Symptômes dépressifs</h3>
          <p class="mb-4 text-xs text-ink-tertiary">Score total sur 27</p>
          <div class="mb-3 flex items-end gap-3">
            <span class="font-display text-4xl text-ink-primary" x-text="phqScore"></span>
            <span
              class="rounded-full px-2.5 py-1 text-xs font-medium"
              :class="severityBadgeClass(phqSeverity)"
              x-text="phqSeverityLabel"
            ></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
            <div
              class="h-3 rounded-full transition-all duration-700"
              :class="severityBarClass(phqSeverity)"
              :style="`width: ${Math.round(phqScore / 27 * 100)}%`"
            ></div>
          </div>
        </div>

        <div class="rounded-xl border border-border-subtle p-5">
          <h3 class="typo-display-md mb-1 text-ink-primary">GAD-7 — Symptômes anxieux</h3>
          <p class="mb-4 text-xs text-ink-tertiary">Score total sur 21</p>
          <div class="mb-3 flex items-end gap-3">
            <span class="font-display text-4xl text-ink-primary" x-text="gadScore"></span>
            <span
              class="rounded-full px-2.5 py-1 text-xs font-medium"
              :class="severityBadgeClass(gadSeverity)"
              x-text="gadSeverityLabel"
            ></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
            <div
              class="h-3 rounded-full transition-all duration-700"
              :class="severityBarClass(gadSeverity)"
              :style="`width: ${Math.round(gadScore / 21 * 100)}%`"
            ></div>
          </div>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-green-100 px-2.5 py-1 font-medium text-green-700">0–4 : Minimal</span>
        <span class="rounded-full bg-lime-100 px-2.5 py-1 font-medium text-lime-700">5–9 : Léger</span>
        <span class="rounded-full bg-yellow-100 px-2.5 py-1 font-medium text-yellow-700">10–14 : Modéré</span>
        <span class="rounded-full bg-orange-100 px-2.5 py-1 font-medium text-orange-700">15–19 : Mod. sévère</span>
        <span class="rounded-full bg-red-100 px-2.5 py-1 font-medium text-red-700">20+ : Sévère</span>
      </div>
    </div>

    <form id="form-container" @submit.prevent="submit()" x-show="!submitted">
      <template x-for="(section, si) in sections" :key="section.code">
        <div class="mb-6 overflow-hidden rounded-xl border border-border-subtle">
          <div class="border-b border-border-subtle bg-secondary/50 px-6 py-4">
            <p class="mb-0.5 text-xs font-medium uppercase tracking-wider text-ink-tertiary" x-text="section.label"></p>
            <h3 class="typo-display-md m-0 text-ink-primary" x-text="section.title"></h3>
          </div>
          <div class="divide-y divide-border-subtle">
            <template x-for="(question, qi) in section.questions" :key="si + '-' + qi">
              <div
                class="px-4 py-4 transition-colors duration-150 sm:px-6"
                :class="answers[section.startIdx + qi] >= 0 ? 'bg-green-50/40' : ''"
              >
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                  <p class="m-0 flex-1 text-sm leading-relaxed text-ink-secondary">
                    <span class="mr-1.5 font-medium text-ink-tertiary" x-text="(qi + 1) + '.'"></span>
                    <span x-text="question"></span>
                  </p>
                  <div class="flex shrink-0 gap-1.5">
                    <template x-for="scale in [0, 1, 2, 3]" :key="scale">
                      <label class="cursor-pointer select-none">
                        <input
                          type="radio"
                          :name="'q' + (section.startIdx + qi)"
                          :value="scale"
                          x-model.number="answers[section.startIdx + qi]"
                          @change="saveAnswers()"
                          class="sr-only"
                        />
                        <span
                          class="font-ui flex h-9 w-9 items-center justify-center rounded-full border-2 text-sm font-medium transition-all duration-150"
                          :class="scaleClass(answers[section.startIdx + qi], scale)"
                          x-text="scale"
                        ></span>
                      </label>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </template>

      <div
        x-show="showWarning"
        x-transition
        class="mb-6 flex items-start gap-2 rounded-xl border border-info-border bg-info-surface p-4 text-sm text-info-ink"
      >
        <span
          class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-info-border bg-surface-raised text-info-ink"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
        </span>
        <span>
          <strong>Questionnaire incomplet :</strong>
          vous avez répondu à <span x-text="answeredCount"></span> question(s) sur 16. Veuillez répondre à toutes les
          questions pour obtenir vos résultats.
        </span>
      </div>

      <div class="mb-8 text-center">
        <button
          type="submit"
          class={buttonClasses({ variant: "primary", size: "lg", className: "gap-2 normal-case" })}
        >
          Calculer mes résultats
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <footer class="mt-4 border-t border-border-subtle pt-6 text-xs leading-relaxed text-ink-tertiary">
      <p>
        PHQ-9 : Kroenke, K., Spitzer, R.L. &amp; Williams, J.B.W. (2001). The PHQ-9: Validity of a brief depression
        severity measure. <em>Journal of General Internal Medicine</em>, 16(9), 606–613.
      </p>
      <p class="mt-2">
        GAD-7 : Spitzer, R.L., Kroenke, K., Williams, J.B.W. &amp; Löwe, B. (2006). A brief measure for assessing
        generalized anxiety disorder. <em>Archives of Internal Medicine</em>, 166(10), 1092–1097.
      </p>
      <p class="mt-2">
        © Pfizer Inc. Patient Health Questionnaire (PHQ-9, GAD-7). Développé par les Drs Robert L. Spitzer, Janet B.W.
        Williams, Kurt Kroenke et leurs collègues. Reproduction autorisée sans permission.
      </p>
    </footer>
  </div>
</FormLayout>

<style>
  @media print {
    header,
    footer,
    nav,
    .no-print,
    #form-container {
      display: none !important;
    }
    .print-results {
      display: block !important;
    }
    body {
      background: white !important;
    }
  }
</style>

<script is:inline>
document.addEventListener('alpine:init', () => {
  const SECTIONS = [
    {
      code: 'phq',
      label: 'Section A',
      title: 'PHQ-9 — Symptômes dépressifs',
      startIdx: 1,
      questions: [
        "Peu d'intérêt ou de plaisir à faire les choses.",
        "Vous sentir triste, déprimé(e) ou désespéré(e).",
        "Difficultés à vous endormir, à rester endormi(e) ou trop dormir.",
        "Vous sentir fatigué(e) ou manquer d'énergie.",
        "Avoir peu d'appétit ou manger trop.",
        "Avoir une mauvaise opinion de vous-même — ou le sentiment d'être nul(le), ou d'avoir déçu votre famille ou d'autres personnes.",
        "Difficultés à vous concentrer sur des choses, comme lire le journal ou regarder la télévision.",
        "Bouger ou parler si lentement que les autres auraient pu le remarquer. Ou au contraire — être si agité(e) que vous avez eu du mal à tenir en place.",
        "Penser qu'il vaudrait mieux mourir ou envisager de vous faire du mal d'une manière ou d'une autre.",
      ],
    },
    {
      code: 'gad',
      label: 'Section B',
      title: 'GAD-7 — Symptômes anxieux',
      startIdx: 10,
      questions: [
        "Sentiment de nervosité, d'anxiété ou de tension.",
        "Incapable d'arrêter de vous inquiéter ou de contrôler vos inquiétudes.",
        "Inquiétudes excessives à propos de tout et de rien.",
        "Difficulté à vous détendre.",
        "Agitation telle qu'il est difficile de rester tranquille.",
        "Devenir facilement contrarié(e) ou irritable.",
        "Avoir peur que quelque chose d'épouvantable puisse arriver.",
      ],
    },
  ];

  Alpine.data('phqGadForm', () => ({
    sections: SECTIONS,
    answers: new Array(17).fill(-1),
    submitted: false,
    showWarning: false,

    get answeredCount() {
      let count = 0;
      for (let i = 1; i <= 16; i++) {
        if (this.answers[i] >= 0) count++;
      }
      return count;
    },

    get progress() {
      return Math.round((this.answeredCount / 16) * 100);
    },

    get phqScore() {
      let total = 0;
      for (let i = 1; i <= 9; i++) total += this.answers[i];
      return total;
    },

    get gadScore() {
      let total = 0;
      for (let i = 10; i <= 16; i++) total += this.answers[i];
      return total;
    },

    get phqSeverity() {
      return this.severityLevel(this.phqScore, true);
    },

    get gadSeverity() {
      return this.severityLevel(this.gadScore, false);
    },

    get phqSeverityLabel() {
      return this.severityLabel(this.phqSeverity);
    },

    get gadSeverityLabel() {
      return this.severityLabel(this.gadSeverity);
    },

    severityLevel(score, isPhq) {
      if (score <= 4) return 'minimal';
      if (score <= 9) return 'mild';
      if (score <= 14) return 'moderate';
      if (isPhq && score <= 19) return 'moderately-severe';
      return 'severe';
    },

    severityLabel(level) {
      const labels = {
        minimal: 'Minimal',
        mild: 'Léger',
        moderate: 'Modéré',
        'moderately-severe': 'Modérément sévère',
        severe: 'Sévère',
      };
      return labels[level] || level;
    },

    severityBadgeClass(level) {
      if (level === 'minimal') return 'bg-green-100 text-green-700';
      if (level === 'mild') return 'bg-lime-100 text-lime-700';
      if (level === 'moderate') return 'bg-yellow-100 text-yellow-700';
      if (level === 'moderately-severe') return 'bg-orange-100 text-orange-700';
      return 'bg-red-100 text-red-700';
    },

    severityBarClass(level) {
      if (level === 'minimal') return 'bg-green-400';
      if (level === 'mild') return 'bg-lime-400';
      if (level === 'moderate') return 'bg-yellow-400';
      if (level === 'moderately-severe') return 'bg-orange-500';
      return 'bg-red-500';
    },

    scaleClass(answer, scale) {
      return answer === scale
        ? 'border-brand bg-brand text-brand-ink-on shadow-sm'
        : 'border-border-strong text-ink-tertiary hover:border-brand hover:text-brand cursor-pointer';
    },

    saveAnswers() {
      try { localStorage.setItem('phq-gad-7', JSON.stringify(this.answers)); } catch (e) {}
    },

    submit() {
      if (this.answeredCount < 16) {
        this.showWarning = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      this.submitted = true;
      this.saveAnswers();
      this.$nextTick(() => {
        const el = document.getElementById('results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    },

    reset() {
      if (!confirm('Voulez-vous recommencer le questionnaire ? Toutes vos réponses seront perdues.')) return;
      this.answers = new Array(17).fill(-1);
      this.submitted = false;
      this.showWarning = false;
      try { localStorage.removeItem('phq-gad-7'); } catch (e) {}
      window.scrollTo({ top: 0, behavior: 'smooth' });
    },

    init() {
      try {
        const saved = localStorage.getItem('phq-gad-7');
        if (saved) {
          const data = JSON.parse(saved);
          if (Array.isArray(data) && data.length === 17) this.answers = data;
        }
      } catch (e) {}
    },
  }));
});
</script>

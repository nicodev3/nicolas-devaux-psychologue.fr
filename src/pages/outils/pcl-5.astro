---
import FormLayout from "../../layouts/FormLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { buttonClasses } from "../../components/ui/button";

const title = "PCL-5 — Symptômes de stress post-traumatique";
const description =
  "Passez en ligne le PCL-5, questionnaire validé pour évaluer les symptômes de stress post-traumatique au cours du dernier mois.";

const SCALE = [
  [0, "Pas du tout"],
  [1, "Un peu"],
  [2, "Modérément"],
  [3, "Beaucoup"],
  [4, "Extrêmement"],
] as const;
---

<FormLayout title={title} description={description}>
  <div x-data="pcl5Form" class="w-full">
    <div class="sticky top-14 z-20 mb-6 md:top-18" x-show="!submitted">
      <div class="rounded-lg border border-border-subtle bg-surface-page/95 px-4 py-3 backdrop-blur-sm">
        <div class="mb-1.5 flex items-center justify-between">
          <span class="text-xs font-medium text-ink-tertiary">Progression</span>
          <span class="font-ui text-xs font-medium text-ink-secondary">
            <span x-text="answeredCount"></span>/20
          </span>
        </div>
        <div class="h-2 w-full rounded-full bg-surface-muted">
          <div class="h-2 rounded-full bg-brand transition-all duration-300" :style="`width: ${progress}%`"></div>
        </div>
      </div>
    </div>

    <header class="mb-10 md:mb-12">
      <p class="typo-eyebrow mb-3 md:mb-4">PCL-5</p>
      <h1 class="font-display typo-h1 mb-2 text-pretty text-ink-primary md:mb-3">
        Symptômes de stress post-traumatique
      </h1>
      <p class="mb-6 text-sm text-ink-tertiary">
        PTSD Checklist for DSM-5
      </p>

      <div class="rounded-xl border border-border-subtle bg-secondary/40 p-5 md:p-6">
        <SectionHeading class="mb-4" eyebrow="01 — Consignes" title="Instructions" />
        <p class="mb-4 text-sm leading-relaxed text-ink-secondary">
          Voici une liste de difficultés que les gens éprouvent parfois suite à une <strong>expérience vraiment
          stressante</strong>. Pour chaque énoncé, indiquez dans quelle mesure ce problème vous a affecté au cours du
          <strong>dernier mois</strong>, en pensant à cette expérience.
        </p>
        <div class="grid grid-cols-1 gap-2 text-sm sm:grid-cols-2">
          {
            SCALE.map(([n, label]) => (
              <div class="flex items-start gap-2.5">
                <span class="font-ui flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-border-strong bg-surface-raised text-xs font-medium text-tertiary">
                  {n}
                </span>
                <span class="leading-snug text-ink-secondary">{label}</span>
              </div>
            ))
          }
        </div>
      </div>

      <p class="mt-4 flex items-center gap-1.5 text-xs text-ink-tertiary">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4M12 8h.01"></path>
        </svg>
        Vos réponses sont sauvegardées automatiquement dans votre navigateur. Vous pouvez reprendre le questionnaire
        plus tard.
      </p>
    </header>

    <div id="results" x-show="submitted" class="print-results mb-8 rounded-xl border border-border-subtle p-8">
      <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-start">
        <div>
          <SectionHeading class="mb-1" eyebrow="02 — Synthèse" title="Résultats" />
          <p class="text-sm text-ink-tertiary">PCL-5 — Symptômes de stress post-traumatique</p>
        </div>
        <div class="no-print flex shrink-0 gap-2">
          <button
            onclick="window.print()"
            type="button"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className: "gap-1.5 font-normal normal-case text-ink-secondary",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M17 17h2a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h2m2 4h6a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2Zm8-12V5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v4h10Z"
              ></path>
            </svg>
            Imprimer
          </button>
          <button
            type="button"
            @click="reset()"
            class={buttonClasses({
              variant: "secondary",
              size: "sm",
              className:
                "gap-1.5 border-danger bg-danger-surface font-normal normal-case text-danger hover:bg-border-subtle",
            })}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path
                d="M4 4v5h.582m15.356 2A8.001 8.001 0 0 0 4.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 0 1-15.357-2m15.357 2H15"
              ></path>
            </svg>
            Recommencer
          </button>
        </div>
      </div>

      <p class="mb-6 rounded-lg bg-secondary/40 p-4 text-sm text-ink-secondary">
        Ces résultats sont destinés à être partagés avec votre psychologue. Ils ne remplacent pas une évaluation
        clinique complète du trouble de stress post-traumatique.
        <strong>Ils ne constituent pas un diagnostic.</strong>
      </p>

      <div
        x-show="totalScore >= 33 || provisionalPtsd"
        x-cloak
        class="mb-6 rounded-xl border border-orange-200 bg-orange-50 p-4 text-sm text-orange-800"
        role="status"
      >
        <p x-show="totalScore >= 33" x-cloak class="mb-2">
          Un score total de 33 ou plus peut indiquer des symptômes significatifs de stress post-traumatique et
          justifie une consultation avec un professionnel de santé mentale.
        </p>
        <p x-show="provisionalPtsd" x-cloak>
          Selon les critères symptomatiques du DSM-5 (seuil ≥ 2 par item), un TSPT provisoire pourrait être envisagé.
          Seul un entretien clinique permet de confirmer ou d'infirmer ce diagnostic.
        </p>
        <p class="mt-2">
          <a href="/consulter/" class="text-link font-medium">Prendre rendez-vous</a> ·
          <a href="/therapie-mosaic/" class="text-link font-medium">Thérapie MOSAIC</a>
        </p>
      </div>

      <div class="mb-8 rounded-xl border border-border-subtle p-5">
        <h3 class="typo-display-md mb-1 text-ink-primary">Score global</h3>
        <p class="mb-4 text-xs text-ink-tertiary">Score total sur 80</p>
        <div class="mb-4 flex flex-wrap items-end gap-4">
          <div>
            <span class="font-display text-4xl text-ink-primary" x-text="totalScore"></span>
            <span class="text-lg text-ink-tertiary">/80</span>
          </div>
          <span
            class="rounded-full px-2.5 py-1 text-xs font-medium"
            :class="severityBadgeClass"
            x-text="severityLabel"
          ></span>
        </div>
        <div class="h-3 overflow-hidden rounded-full bg-surface-muted">
          <div
            class="h-3 rounded-full transition-all duration-700"
            :class="severityBarClass"
            :style="`width: ${severityPercent}%`"
          ></div>
        </div>
      </div>

      <div class="mb-8 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">Cluster B — Réexpérience</p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="clusterBScore"></span><span class="text-base text-ink-tertiary">/20</span>
          </p>
        </div>
        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">Cluster C — Évitement</p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="clusterCScore"></span><span class="text-base text-ink-tertiary">/8</span>
          </p>
        </div>
        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">
            Cluster D — Cognitions et humeur
          </p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="clusterDScore"></span><span class="text-base text-ink-tertiary">/28</span>
          </p>
        </div>
        <div class="rounded-xl border border-border-subtle p-4">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-ink-tertiary">
            Cluster E — Hyperactivation
          </p>
          <p class="font-display text-2xl text-ink-primary">
            <span x-text="clusterEScore"></span><span class="text-base text-ink-tertiary">/24</span>
          </p>
        </div>
      </div>

      <div class="flex flex-wrap gap-2 text-xs">
        <span class="rounded-full bg-green-100 px-2.5 py-1 font-medium text-green-700">0–20 : Minimal</span>
        <span class="rounded-full bg-lime-100 px-2.5 py-1 font-medium text-lime-700">21–32 : Léger</span>
        <span class="rounded-full bg-yellow-100 px-2.5 py-1 font-medium text-yellow-700">33–37 : Modéré</span>
        <span class="rounded-full bg-orange-100 px-2.5 py-1 font-medium text-orange-700">38–49 : Mod. sévère</span>
        <span class="rounded-full bg-red-100 px-2.5 py-1 font-medium text-red-700">50+ : Sévère</span>
      </div>
    </div>

    <form id="form-container" @submit.prevent="submit()" x-show="!submitted">
      <template x-for="(section, si) in sections" :key="section.code">
        <div class="mb-6 overflow-hidden rounded-xl border border-border-subtle">
          <div class="border-b border-border-subtle bg-secondary/50 px-6 py-4">
            <p class="mb-0.5 text-xs font-medium uppercase tracking-wider text-ink-tertiary" x-text="section.label"></p>
            <h3 class="typo-display-md m-0 text-ink-primary" x-text="section.title"></h3>
          </div>
          <div class="divide-y divide-border-subtle">
            <template x-for="(question, qi) in section.questions" :key="si + '-' + qi">
              <div
                class="px-4 py-4 transition-colors duration-150 sm:px-6"
                :class="answers[section.startIdx + qi] >= 0 ? 'bg-green-50/40' : ''"
              >
                <div class="flex flex-col gap-3 lg:flex-row lg:items-center">
                  <p class="m-0 flex-1 text-sm leading-relaxed text-ink-secondary">
                    <span class="mr-1.5 font-medium text-ink-tertiary" x-text="(section.startIdx + qi) + '.'"></span>
                    <span x-text="question"></span>
                  </p>
                  <div class="flex shrink-0 flex-wrap gap-1">
                    <template x-for="scale in [0, 1, 2, 3, 4]" :key="scale">
                      <label class="cursor-pointer select-none">
                        <input
                          type="radio"
                          :name="'q' + (section.startIdx + qi)"
                          :value="scale"
                          x-model.number="answers[section.startIdx + qi]"
                          @change="saveAnswers()"
                          class="sr-only"
                        />
                        <span
                          class="font-ui flex h-8 w-8 items-center justify-center rounded-full border-2 text-xs font-medium transition-all duration-150 sm:h-9 sm:w-9 sm:text-sm"
                          :class="scaleClass(answers[section.startIdx + qi], scale)"
                          x-text="scale"
                        ></span>
                      </label>
                    </template>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </template>

      <div
        x-show="showWarning"
        x-transition
        class="mb-6 flex items-start gap-2 rounded-xl border border-info-border bg-info-surface p-4 text-sm text-info-ink"
      >
        <span
          class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-info-border bg-surface-raised text-info-ink"
          aria-hidden="true"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 16v-4M12 8h.01"></path>
          </svg>
        </span>
        <span>
          <strong>Questionnaire incomplet :</strong>
          vous avez répondu à <span x-text="answeredCount"></span> question(s) sur 20. Veuillez répondre à toutes les
          questions pour obtenir vos résultats.
        </span>
      </div>

      <div class="mb-8 text-center">
        <button
          type="submit"
          class={buttonClasses({ variant: "primary", size: "lg", className: "gap-2 normal-case" })}
        >
          Calculer mes résultats
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>
    </form>

    <footer class="mt-4 border-t border-border-subtle pt-6 text-xs leading-relaxed text-ink-tertiary">
      <p>
        PCL-5 : Weathers, F.W., Litz, B.T., Keane, T.M., Palmieri, P.A., Marx, B.P., &amp; Schnurr, P.P. (2013). The PTSD
        Checklist for DSM-5 (PCL-5). National Center for PTSD.
      </p>
      <p class="mt-2">
        Version française : Ashbaugh, A.R., Houle-Johnson, S., Herbert, C., El-Hage, W., &amp; Brunet, A. (2016).
        Psychometric validation of the English and French versions of the Posttraumatic Stress Disorder Checklist for
        DSM-5 (PCL-5). <em>PLOS ONE</em>, 11(10), e0161645.
      </p>
      <p class="mt-2">
        Domaine public (Weathers et al., 2013). Version française utilisée avec l'autorisation du Laboratoire de
        Recherche sur les Psychotraumatismes, Centre de recherche Douglas (Alain Brunet).
      </p>
    </footer>
  </div>
</FormLayout>

<style>
  @media print {
    header,
    footer,
    nav,
    .no-print,
    #form-container {
      display: none !important;
    }
    .print-results {
      display: block !important;
    }
    body {
      background: white !important;
    }
  }
</style>

<script is:inline>
document.addEventListener('alpine:init', () => {
  const SECTIONS = [
    {
      code: 'b',
      label: 'Cluster B — DSM-5',
      title: 'Réexpérience',
      startIdx: 1,
      questions: [
        "Des souvenirs répétés, pénibles et involontaires de l'expérience stressante.",
        "Des rêves répétés et pénibles de l'expérience stressante.",
        "Se sentir soudainement comme si l'expérience stressante recommençait (comme si vous la vivez de nouveau).",
        "Être bouleversé(e) lorsque quelque chose vous rappelle l'expérience stressante.",
        "Réagir physiquement lorsque quelque chose vous rappelle l'expérience stressante (p. ex. avoir le cœur qui bat très fort, du mal à respirer, ou avoir des sueurs).",
      ],
    },
    {
      code: 'c',
      label: 'Cluster C — DSM-5',
      title: 'Évitement',
      startIdx: 6,
      questions: [
        "Éviter des souvenirs, des pensées ou des sentiments en lien avec l'expérience stressante.",
        "Éviter les personnes et les choses qui vous rappellent l'expérience stressante (p. ex. des gens, des lieux, des conversations, des activités, des objets ou des situations).",
      ],
    },
    {
      code: 'd',
      label: 'Cluster D — DSM-5',
      title: "Altérations cognitives et de l\u2019humeur",
      startIdx: 8,
      questions: [
        "Avoir du mal à vous rappeler d'éléments importants de l'expérience stressante.",
        "Avoir des croyances négatives sur vous-même, les autres ou sur le monde (p. ex. avoir des pensées telles que : je suis mauvais(e), il y a quelque chose qui cloche sérieusement chez moi, nul n'est digne de confiance, le monde est un endroit complètement dangereux).",
        "Vous blâmer ou blâmer les autres pour la survenue de l'expérience stressante ou ce qui est arrivé par la suite.",
        "Avoir des sentiments négatifs intenses tels que peur, horreur, colère, culpabilité ou honte.",
        "Perdre de l'intérêt pour les activités que vous aimiez auparavant.",
        "Vous sentir distant(e) ou coupé(e) des autres.",
        "Avoir du mal à éprouver des sentiments positifs (p. ex. être incapable de ressentir la joie ou de l'amour envers vos proches).",
      ],
    },
    {
      code: 'e',
      label: 'Cluster E — DSM-5',
      title: 'Hyperactivation',
      startIdx: 15,
      questions: [
        "Être irritable, avoir des bouffées de colère ou agir agressivement.",
        "Prendre des risques inconsidérés ou avoir des conduites qui pourraient vous mettre en danger.",
        "Être « super-alerte », vigilant(e) ou sur vos gardes.",
        "Sursauter facilement.",
        "Avoir du mal à vous concentrer.",
        "Avoir du mal à trouver ou garder le sommeil.",
      ],
    },
  ];

  Alpine.data('pcl5Form', () => ({
    sections: SECTIONS,
    answers: new Array(21).fill(-1),
    submitted: false,
    showWarning: false,

    sumRange(start, end) {
      let total = 0;
      for (let i = start; i <= end; i++) total += this.answers[i];
      return total;
    },

    countAboveThreshold(start, end, threshold) {
      let count = 0;
      for (let i = start; i <= end; i++) {
        if (this.answers[i] >= threshold) count++;
      }
      return count;
    },

    get answeredCount() {
      let count = 0;
      for (let i = 1; i <= 20; i++) {
        if (this.answers[i] >= 0) count++;
      }
      return count;
    },

    get progress() {
      return Math.round((this.answeredCount / 20) * 100);
    },

    get totalScore() {
      return this.sumRange(1, 20);
    },

    get clusterBScore() {
      return this.sumRange(1, 5);
    },

    get clusterCScore() {
      return this.sumRange(6, 7);
    },

    get clusterDScore() {
      return this.sumRange(8, 14);
    },

    get clusterEScore() {
      return this.sumRange(15, 20);
    },

    get provisionalPtsd() {
      return (
        this.countAboveThreshold(1, 5, 2) >= 1 &&
        this.countAboveThreshold(6, 7, 2) >= 1 &&
        this.countAboveThreshold(8, 14, 2) >= 2 &&
        this.countAboveThreshold(15, 20, 2) >= 2
      );
    },

    get severityLevel() {
      const score = this.totalScore;
      if (score <= 20) return 'minimal';
      if (score <= 32) return 'mild';
      if (score <= 37) return 'moderate';
      if (score <= 49) return 'moderately-severe';
      return 'severe';
    },

    get severityLabel() {
      const labels = {
        minimal: 'Minimal',
        mild: 'Léger',
        moderate: 'Modéré',
        'moderately-severe': 'Modérément sévère',
        severe: 'Sévère',
      };
      return labels[this.severityLevel];
    },

    get severityPercent() {
      return Math.round((this.totalScore / 80) * 100);
    },

    get severityBadgeClass() {
      const level = this.severityLevel;
      if (level === 'minimal') return 'bg-green-100 text-green-700';
      if (level === 'mild') return 'bg-lime-100 text-lime-700';
      if (level === 'moderate') return 'bg-yellow-100 text-yellow-700';
      if (level === 'moderately-severe') return 'bg-orange-100 text-orange-700';
      return 'bg-red-100 text-red-700';
    },

    get severityBarClass() {
      const level = this.severityLevel;
      if (level === 'minimal') return 'bg-green-400';
      if (level === 'mild') return 'bg-lime-400';
      if (level === 'moderate') return 'bg-yellow-400';
      if (level === 'moderately-severe') return 'bg-orange-500';
      return 'bg-red-500';
    },

    scaleClass(answer, scale) {
      return answer === scale
        ? 'border-brand bg-brand text-brand-ink-on shadow-sm'
        : 'border-border-strong text-ink-tertiary hover:border-brand hover:text-brand cursor-pointer';
    },

    saveAnswers() {
      try { localStorage.setItem('pcl-5', JSON.stringify(this.answers)); } catch (e) {}
    },

    submit() {
      if (this.answeredCount < 20) {
        this.showWarning = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      this.submitted = true;
      this.saveAnswers();
      this.$nextTick(() => {
        const el = document.getElementById('results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    },

    reset() {
      if (!confirm('Voulez-vous recommencer le questionnaire ? Toutes vos réponses seront perdues.')) return;
      this.answers = new Array(21).fill(-1);
      this.submitted = false;
      this.showWarning = false;
      try { localStorage.removeItem('pcl-5'); } catch (e) {}
      window.scrollTo({ top: 0, behavior: 'smooth' });
    },

    init() {
      try {
        const saved = localStorage.getItem('pcl-5');
        if (saved) {
          const data = JSON.parse(saved);
          if (Array.isArray(data) && data.length === 21) this.answers = data;
        }
      } catch (e) {}
    },
  }));
});
</script>

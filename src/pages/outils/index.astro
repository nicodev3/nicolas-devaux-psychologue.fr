---
import SectionHeading from "../../components/SectionHeading.astro";
import FormLayout from "../../layouts/FormLayout.astro";

interface Tool {
  href: string;
  title: string;
  description: string;
  badges: string[];
}

interface Section {
  eyebrow: string;
  title: string;
  tools: Tool[];
}

const sections: Section[] = [
  {
    eyebrow: "01 — Dépistage rapide",
    title: "Bien-être et symptômes courants",
    tools: [
      {
        href: "/outils/who-5/",
        title: "WHO-5 — Indice de bien-être",
        description:
          "Cinq questions de l'OMS pour évaluer votre bien-être mental au cours des deux dernières semaines. Un complément positif aux questionnaires de dépistage dépressif et anxieux.",
        badges: ["5 questions", "Bien-être", "~2 minutes", "Sauvegarde automatique"],
      },
      {
        href: "/outils/phq-9-gad-7/",
        title: "PHQ-9 + GAD-7",
        description:
          "Deux questionnaires validés pour évaluer les symptômes dépressifs et anxieux au cours des deux dernières semaines. Utiles en début de suivi ou pour faire le point sur votre état actuel.",
        badges: ["16 questions", "Dépression + anxiété", "~5 minutes", "Sauvegarde automatique"],
      },
    ],
  },
  {
    eyebrow: "02 — Thérapie des schémas",
    title: "Questionnaires de schémas",
    tools: [
      {
        href: "/outils/questionnaire-schemas-young/",
        title: "Questionnaire des Schémas de Young (YSQ-L3)",
        description:
          "Ce questionnaire de 232 affirmations explore 18 schémas précoces inadaptés répartis en 5 domaines. Utilisé dans le cadre de la thérapie des schémas pour identifier les croyances profondes qui influencent vos pensées, émotions et comportements.",
        badges: ["232 questions", "18 schémas", "~25 minutes", "Sauvegarde automatique"],
      },
    ],
  },
  {
    eyebrow: "03 — ACT et flexibilité psychologique",
    title: "Questionnaires ACT",
    tools: [
      {
        href: "/outils/aaq-ii/",
        title: "AAQ-II — Questionnaire d'acceptation et d'action",
        description:
          "Sept affirmations pour évaluer votre flexibilité psychologique et votre tendance à l'évitement expérientiel. Outil de référence en thérapie d'acceptation et d'engagement (ACT).",
        badges: ["7 questions", "Flexibilité psychologique", "~3 minutes", "Sauvegarde automatique"],
      },
      {
        href: "/outils/compact/",
        title: "CompACT-FR — Évaluation des processus ACT",
        description:
          "Vingt-trois affirmations couvrant les trois processus de l'ACT : ouverture à l'expérience, conscience comportementale et action guidée par les valeurs. Mesure plus complète que l'AAQ-II.",
        badges: ["23 questions", "3 sous-échelles", "~8 minutes", "Sauvegarde automatique"],
      },
    ],
  },
  {
    eyebrow: "04 — Trauma et stress post-traumatique",
    title: "Évaluation des symptômes",
    tools: [
      {
        href: "/outils/pcl-5/",
        title: "PCL-5 — Stress post-traumatique",
        description:
          "Vingt questions pour évaluer les symptômes de stress post-traumatique au cours du dernier mois, selon les critères du DSM-5. À compléter en pensant à une expérience vraiment stressante.",
        badges: ["20 questions", "TSPT", "~8 minutes", "Sauvegarde automatique"],
      },
    ],
  },
  {
    eyebrow: "05 — Compassion et autocritique",
    title: "Relation à soi",
    tools: [
      {
        href: "/outils/fscrs/",
        title: "FSCRS — Autocritique et auto-apaisement",
        description:
          "Vingt-deux affirmations pour explorer comment vous vous parlez à vous-même lorsque les choses tournent mal : sentiment d'inadéquation, hostilité envers soi et capacité à se rassurer. Outil central en thérapie fondée sur la compassion.",
        badges: ["22 questions", "3 sous-échelles", "~10 minutes", "Sauvegarde automatique"],
      },
    ],
  },
];

---

<FormLayout
  title="Outils psychologiques"
  description="Questionnaires et outils psychologiques en ligne, à réaliser avant une consultation avec Nicolas Devaux, psychologue à Sceaux."
>
  <header class="mb-10 md:mb-12">
    <p class="typo-eyebrow mb-3 md:mb-4">Ressources</p>
    <h1 class="font-display typo-h1 mb-0 text-pretty text-ink-primary">Outils psychologiques</h1>
    <p class="mt-6 leading-relaxed text-ink-secondary">
      Ces questionnaires peuvent être proposés avant ou au cours d'une thérapie, afin de soutenir le travail clinique.
      Ils peuvent aussi être réalisés simplement par curiosité personnelle pour mieux comprendre certains
      fonctionnements. Vos réponses sont sauvegardées localement dans votre navigateur et ne sont transmises à
      personne.
    </p>
  </header>

  {
    sections.map((section, index) => (
      <>
        <SectionHeading
          class:list={[index > 0 && "border-t border-border-subtle pt-10 md:pt-12"]}
          eyebrow={section.eyebrow}
          title={section.title}
        />
        <div class="grid gap-6">
          {section.tools.map((tool) => (
            <a
              href={tool.href}
              class="group block rounded-xl border border-border-subtle p-6 transition-colors hover:border-brand/35"
            >
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-secondary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 text-brand-hover"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"></path>
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="typo-display-md mb-2 text-ink-primary transition-colors group-hover:text-brand-hover">
                    {tool.title}
                  </h3>
                  <p class="mb-3 text-sm leading-relaxed text-ink-secondary">{tool.description}</p>
                  <div class="flex flex-wrap gap-2">
                    {tool.badges.map((badge) => (
                      <span class="rounded-md bg-secondary px-2 py-1 text-xs font-medium text-tertiary">{badge}</span>
                    ))}
                  </div>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="mt-1 h-5 w-5 shrink-0 text-ink-tertiary transition-colors group-hover:text-brand"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="m9 5 7 7-7 7"></path>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </>
    ))
  }

  <p class="mt-10 border-t border-border-subtle pt-8 text-sm leading-relaxed text-ink-tertiary">
    D'autres questionnaires seront ajoutés progressivement, notamment l'inventaire des modes de schéma (SMI).
  </p>
</FormLayout>

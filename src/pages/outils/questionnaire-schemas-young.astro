      }
      return count;
    },

    get progress() {
      return Math.round(this.answeredCount / 232 * 100);
    },

    schemaScore(schema) {
      let total = 0, count = 0;
      for (let i = schema.startIdx; i < schema.startIdx + schema.questions.length; i++) {
        if (this.answers[i] > 0) {
          total += this.answers[i];
          count++;
        }
      }
      return { total, count, avg: count > 0 ? total / count : 0 };
    },

    schemasInDomain(domain) {
      return this.schemas.filter(s => s.domain === domain);
    },

    scoreLabel(avg) {
      if (avg < 2) return 'Très faible';
      if (avg < 3) return 'Faible';
      if (avg < 4) return 'Modéré';
      if (avg < 5) return 'Élevé';
      return 'Très élevé';
    },

    scoreBarWidth(avg) {
      return `${Math.round((avg / 6) * 100)}%`;
    },

    scoreBarColor(avg) {
      if (avg < 2) return 'bg-green-400';
      if (avg < 3) return 'bg-lime-400';
      if (avg < 4) return 'bg-yellow-400';
      if (avg < 5) return 'bg-orange-500';
      return 'bg-red-500';
    },

    scoreTextColor(avg) {
      if (avg < 2) return 'text-green-600';
      if (avg < 3) return 'text-lime-600';
      if (avg < 4) return 'text-yellow-600';
      if (avg < 5) return 'text-orange-600';
      return 'text-red-600';
    },

    scaleClass(answer, scale) {
      return answer === scale
        ? 'border-brand bg-brand text-brand-ink-on shadow-sm'
        : 'border-border-strong text-ink-tertiary hover:border-brand hover:text-brand cursor-pointer';
    },

    scoreBadgeClass(avg) {
      if (avg < 2) return 'bg-green-100 text-green-700';
      if (avg < 3) return 'bg-lime-100 text-lime-700';
      if (avg < 4) return 'bg-yellow-100 text-yellow-700';
      if (avg < 5) return 'bg-orange-100 text-orange-700';
      return 'bg-red-100 text-red-700';
    },

    saveAnswers() {
      try { localStorage.setItem('ysq-l3', JSON.stringify(this.answers)); } catch(e) {}
    },

    submit() {
      if (this.answeredCount < 232) {
        this.showWarning = true;
        window.scrollTo({ top: 0, behavior: 'smooth' });
        return;
      }
      this.submitted = true;
      this.saveAnswers();
      this.$nextTick(() => {
        const el = document.getElementById('results');
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    },

    reset() {
      if (!confirm('Voulez-vous recommencer le questionnaire ? Toutes vos réponses seront perdues.')) return;
      this.answers = new Array(233).fill(0);
      this.submitted = false;
      this.showWarning = false;
      try { localStorage.removeItem('ysq-l3'); } catch(e) {}
      window.scrollTo({ top: 0, behavior: 'smooth' });
    },

    init() {
      // Compute uniqueDomains once
      const domains = [];
      const seen = new Set();
      this.schemas.forEach(s => {
        if (!seen.has(s.domain)) { domains.push(s.domain); seen.add(s.domain); }
      });
      this.uniqueDomains = domains;

      // Restore saved answers
      try {
        const saved = localStorage.getItem('ysq-l3');
        if (saved) {
          const data = JSON.parse(saved);
          if (Array.isArray(data) && data.length === 233) this.answers = data;
        }
      } catch(e) {}
    }

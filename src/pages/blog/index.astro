---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import { formatFrenchDate, toDateTime } from "../../utils/formatDate";
import { applyFrenchTypography } from "../../utils/frenchTypography.js";

const BLOG_INDEX_TITLE = applyFrenchTypography("Blog — articles de psychologie");
const BLOG_INDEX_DESCRIPTION =
  "Articles de psychologie, thérapies et bien-être mental par Nicolas Devaux, psychologue à Sceaux.";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={BLOG_INDEX_TITLE} description={BLOG_INDEX_DESCRIPTION} />
  </head>
  <body class="bg-surface-page">
    <Header />
    <main class="page-shell page-shell--wide">
      <Breadcrumb title={BLOG_INDEX_TITLE} />
      <header class="mb-10 md:mb-14">
        <p class="typo-eyebrow mb-3 md:mb-4">Blog</p>
        <h1 class="font-display typo-h1 mb-5 text-pretty text-ink-primary md:mb-6">
          Articles de psychologie
        </h1>
        <p class="typo-body-lg text-body-muted mb-0 max-w-2xl text-pretty">
          Découvrez mes articles sur la psychologie, les thérapies et le bien-être mental. Des conseils pratiques et des
          éclairages professionnels pour mieux comprendre l'accompagnement psychologique.
        </p>
      </header>

      <div class="grid gap-8 border-t border-border-subtle pt-10 md:grid-cols-2 md:pt-12 xl:grid-cols-4">
        {
          posts.map((post) => (
            <article class="overflow-hidden rounded-xl border border-border-subtle transition-colors hover:border-brand/35">
              <a href={`/blog/${post.id}/`} class="group block">
                <div class="aspect-video overflow-hidden bg-surface-muted">
                  {
                    post.data.heroImage && (
                      <Picture
                        src={post.data.heroImage}
                        alt={post.data.title}
                        width={720}
                        height={360}
                        formats={["avif", "webp"]}
                        fallbackFormat="webp"
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover"
                      />
                    )
                  }
                </div>
                <div class="p-6">
                  <h3 class="typo-display-md mb-2 font-semibold text-ink-primary transition-colors group-hover:text-brand">
                    {applyFrenchTypography(post.data.title)}
                  </h3>
                  <p class="font-ui typo-meta text-body-muted">
                    <time datetime={toDateTime(post.data.pubDate)}>{formatFrenchDate(post.data.pubDate)}</time>
                  </p>
                </div>
              </a>
            </article>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>

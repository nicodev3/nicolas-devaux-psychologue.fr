---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const postBody = post.body ?? "";
const plainBody = postBody
	.replace(/<script[\s\S]*?<\/script>/gi, "")
	.replace(/```[\s\S]*?```/g, "")
	.replace(/[#>*_`[\]()-]/g, " ")
	.replace(/\s+/g, " ")
	.trim();
const wordCount = plainBody ? plainBody.split(" ").length : 0;
const readingTimeMinutes = Math.max(1, Math.ceil(wordCount / 220));
const hasFaq = /^##\s+Questions fréquentes\b/mi.test(postBody);
---

<BlogPost {...post.data} blogPost={true} readingTimeMinutes={readingTimeMinutes} hasFaq={hasFaq}>
	<Content />
</BlogPost>

---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { accordionDisclosureClasses, buttonClasses } from "../../components/ui/button";

const seoTitle = "Groupes de pleine conscience et gestion du stress à Sceaux";

const meditationAccordionBtn = accordionDisclosureClasses("gap-3 px-4 py-4");
const pageTitle = "Groupes de pleine conscience et gestion du stress à Sceaux";
const description =
  "Groupes de pleine conscience et gestion du stress à Sceaux : petit groupe de 5 personnes maximum, cycles de 8 séances, respiration, attention au corps et pratiques issues de l'ACT.";

const isProd = import.meta.env.PROD;
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Faut-il avoir déjà médité ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Non. Les ateliers sont ouverts aux débutants. Les pratiques sont guidées et progressives.",
      },
    },
    {
      "@type": "Question",
      name: "Est-ce adapté si je suis anxieux ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Oui, ces ateliers sont pensés pour aider à mieux observer les pensées envahissantes, réguler le stress et revenir au présent, dans un cadre structuré.",
      },
    },
    {
      "@type": "Question",
      name: "Est-ce une thérapie ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Non. Ces groupes ne proposent pas de suivi thérapeutique individuel. Ils ne remplacent pas une psychothérapie individuelle.",
      },
    },
    {
      "@type": "Question",
      name: "Puis-je venir une seule fois ?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Non. Les ateliers sont proposés sous forme de cycles de 8 séances.",
      },
    },
  ],
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://nicolas-devaux-psychologue.fr/meditation-pleine-conscience-sceaux/#service",
  serviceType: "Ateliers de meditation de pleine conscience en groupe",
  name: "Meditation de pleine conscience et regulation du stress a Sceaux",
  description:
    "Cycles de 8 seances en petit groupe (5 participants maximum) axes sur la meditation de pleine conscience, la respiration consciente, l'attention au corps et la regulation du stress.",
  provider: {
    "@id": "https://nicolas-devaux-psychologue.fr/#cabinet",
  },
  areaServed: [
    { "@type": "City", name: "Sceaux" },
    { "@type": "City", name: "Antony" },
    { "@type": "City", name: "Bourg-la-Reine" },
    { "@type": "City", name: "Chatenay-Malabry" },
    { "@type": "AdministrativeArea", name: "Hauts-de-Seine" },
  ],
  audience: {
    "@type": "PeopleAudience",
    audienceType: "Adultes",
  },
  offers: {
    "@type": "Offer",
    price: 30,
    priceCurrency: "EUR",
    url: "https://nicolas-devaux-psychologue.fr/meditation-pleine-conscience-sceaux/",
    availability: "https://schema.org/InStock",
  },
};
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={seoTitle} description={description} />
    {isProd && (
      <>
        <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
      </>
    )}
  </head>
  <body class="bg-surface-page">
    <Header />
    <main class="page-shell">
      <article class="w-full">
        <section class="pb-12 md:pb-14">
          <p class="typo-eyebrow mb-3 md:mb-4">Groupes</p>
          <h1 class="font-display typo-h1 mb-6 text-pretty text-ink-primary md:mb-8">
            {pageTitle}
          </h1>
          <p class="text-ink-secondary leading-relaxed max-w-3xl">
            Ces ateliers collectifs vous proposent un espace guidé pour apprendre à vous poser,
            observer vos pensées et réguler le stress. Le cadre est simple, sobre et adapté à une
            pratique progressive de la pleine conscience.
          </p>
          <p class="text-ink-secondary leading-relaxed max-w-3xl mt-4">
            Les pratiques s'inspirent de la MBCT (thérapie cognitive basée sur la pleine
            conscience), de la MBSR (réduction du stress par la pleine conscience) et de l'ACT
            (thérapie d'acceptation et d'engagement).
          </p>
          <p class="text-ink-secondary leading-relaxed max-w-3xl mt-4">
            Je les anime en tant que <strong>psychologue clinicien et psychomotricien</strong>,
            avec une attention particulière à l'articulation entre vécu psychique, respiration et
            conscience corporelle.
          </p>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading class="mb-5" eyebrow="01 — Publics" title="À qui s'adressent ces groupes ?" />
          <ul class="list-disc space-y-2 pl-5 text-ink-secondary marker:text-brand-hover">
            <li>Personnes stressées ou sous tension mentale persistante</li>
            <li>Pensées envahissantes et difficulté à prendre du recul</li>
            <li>Tensions corporelles et sensation de surcharge</li>
            <li>Besoin de ralentir et de retrouver un appui dans le présent</li>
          </ul>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading class="mb-5" eyebrow="02 — Pratiques" title="Ce que nous pratiquons" />
          <div class="space-y-4 text-ink-secondary leading-relaxed">
            <h3 class="font-display typo-display-md text-ink-primary">Pratiques guidées en petit groupe</h3>
            <p>
              Les méthodes proposées s'inspirent de la MBCT (thérapie cognitive basée sur la pleine
              conscience), de la MBSR (réduction du stress par la pleine conscience) et de l'ACT
              (thérapie d'acceptation et d'engagement). Elles articulent pratique attentionnelle,
              respiration et conscience corporelle pour soutenir la régulation du stress au
              quotidien.
            </p>
            <ul class="list-disc list-inside space-y-2">
              <li>Méditation de pleine conscience</li>
              <li>Respiration consciente, cohérence cardiaque</li>
              <li>Attention au corps et aux sensations</li>
              <li>Ancrage dans le présent</li>
              <li>Régulation du stress au quotidien</li>
            </ul>
          </div>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading
            class="mb-5"
            eyebrow="03 — Cadre"
            title="Un cadre différent de la psychothérapie"
          />
          <div class="space-y-4 text-ink-secondary leading-relaxed">
            <p>
              Ces ateliers ne sont pas un espace d'analyse individuelle et ne constituent pas un
              suivi thérapeutique personnalisé.
            </p>
            <p>
              Le travail repose sur la pratique guidée et l'expérience directe. Les groupes ne
              remplacent pas une <a href="/psychotherapie/" class="text-link">psychothérapie individuelle</a>
              quand celle-ci est nécessaire. Si vous traversez une période difficile, une
              <a href="/psychologue-sceaux/" class="text-link">consultation avec un psychologue à Sceaux</a>
              ou une <a href="/psychologue-en-ligne/" class="text-link">consultation en ligne</a> peut
              être plus adaptée dans un premier temps.
            </p>
          </div>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading class="mb-5" eyebrow="04 — Format" title="Format des séances" />
          <ul class="space-y-3 text-ink-secondary leading-relaxed">
            <li><strong>Petit groupe :</strong> 5 participants maximum</li>
            <li><strong>Durée :</strong> 1 heure</li>
            <li><strong>Fréquence :</strong> cycle hebdomadaire de 8 séances</li>
            <li><strong>Horaire :</strong> le mardi à 18h30</li>
            <li><strong>Tarif :</strong> 30 € par séance</li>
            <li><strong>Cadre :</strong> calme, confidentiel et respectueux du rythme de chacun</li>
          </ul>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading class="mb-5" eyebrow="05 — Groupe" title="Pourquoi le petit groupe ?" />
          <ul class="space-y-3 text-ink-secondary leading-relaxed">
            <li>Un groupe restreint facilite l'attention et la qualité de présence.</li>
            <li>Le cadre est plus sécurisant et soutient la régularité de la pratique.</li>
            <li>L'expérience est partagée, sans obligation de parler de soi.</li>
          </ul>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14">
          <SectionHeading class="mb-5" eyebrow="06 — Inscription" title="Prochaines dates et inscription" />
          <p class="text-ink-secondary leading-relaxed">
            Vous pouvez utiliser ce formulaire pour demander une inscription, poser une question
            ou être informé des prochaines sessions.
          </p>
          <p class="text-ink-secondary leading-relaxed mt-3">
            Les séances ont lieu <strong>le mardi à 18h30</strong>, en cycle de 8 séances.
          </p>
          <form
            class="mt-6 grid gap-4"
            action="https://formspree.io/f/xkokedlw"
            method="POST"
            data-track-contact
            data-track-event="Contact Form Submit"
            data-track-location="Meditation Page"
          >
            <input
              type="hidden"
              name="_subject"
              value="Demande ateliers pleine conscience - Sceaux"
            />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="group-name" class="block text-sm font-medium text-tertiary mb-1.5">
                  Nom
                </label>
                <input
                  id="group-name"
                  name="nom"
                  type="text"
                  required
                  class="w-full rounded-lg border border-border-strong bg-surface-raised px-3 py-2.5 text-ink-primary focus:outline-none focus:ring-2 focus:ring-brand/40"
                />
              </div>
              <div>
                <label for="group-email" class="block text-sm font-medium text-tertiary mb-1.5">
                  E-mail
                </label>
                <input
                  id="group-email"
                  name="email"
                  type="email"
                  required
                  class="w-full rounded-lg border border-border-strong bg-surface-raised px-3 py-2.5 text-ink-primary focus:outline-none focus:ring-2 focus:ring-brand/40"
                />
              </div>
            </div>

            <div>
              <label for="group-phone" class="block text-sm font-medium text-tertiary mb-1.5">
                Téléphone (optionnel)
              </label>
              <input
                id="group-phone"
                name="telephone"
                type="tel"
                class="w-full rounded-lg border border-border-strong bg-surface-raised px-3 py-2.5 text-ink-primary focus:outline-none focus:ring-2 focus:ring-brand/40"
              />
            </div>

            <div>
              <label for="group-message" class="block text-sm font-medium text-tertiary mb-1.5">
                Message
              </label>
              <textarea
                id="group-message"
                name="message"
                rows="5"
                required
                class="w-full rounded-lg border border-border-strong bg-surface-raised px-3 py-2.5 text-ink-primary focus:outline-none focus:ring-2 focus:ring-brand/40"
                placeholder="Je souhaite m'inscrire / être informé des prochaines dates..."
              ></textarea>
            </div>

            <label class="flex items-start gap-3 text-sm text-ink-secondary">
              <input
                type="checkbox"
                name="etre_informe_des_prochaines_dates"
                value="oui"
                class="mt-0.5 h-4 w-4 rounded border-border-strong text-brand focus:ring-brand/40"
              />
              <span>Je souhaite être informé des prochaines dates d'ateliers.</span>
            </label>

            <div class="flex flex-col sm:flex-row gap-3">
              <button
                type="submit"
                class={buttonClasses({
                  variant: "primary",
                  size: "lg",
                  className: "w-full normal-case sm:w-auto",
                })}
              >
                Envoyer ma demande
              </button>
            </div>
          </form>
          <p class="text-sm text-ink-secondary mt-4">
            Les ateliers sont ouverts à toute personne souhaitant participer, à Sceaux et plus
            largement dans le sud des Hauts-de-Seine et les communes voisines.
          </p>
        </section>

        <section class="border-t border-border-subtle py-12 md:py-14" x-data="{ openId: 'group-faq-1' }">
          <SectionHeading class="mb-6" eyebrow="07 — FAQ" title="Questions fréquentes" />
          <div class="space-y-4">
            <article class="rounded-xl border border-border-strong bg-secondary/35 overflow-hidden">
              <button
                type="button"
                @click="openId = openId === 'group-faq-1' ? null : 'group-faq-1'"
                class={meditationAccordionBtn}
                :aria-expanded="openId === 'group-faq-1'"
                aria-controls="group-faq-content-1"
              >
                <span class="min-w-0 flex-1 pr-3 text-left">
                  <h3 class="text-left font-display typo-display-md text-ink-primary">Faut-il avoir déjà médité ?</h3>
                </span>
                <span class="shrink-0 self-start font-ui text-xl leading-none text-ink-tertiary" aria-hidden="true">+</span>
              </button>
              <div id="group-faq-content-1" x-show="openId === 'group-faq-1'" class="px-4 pb-4 pt-0 text-left">
                <p class="text-ink-secondary leading-relaxed">
                  Non. Les ateliers sont ouverts aux débutants, avec des indications progressives.
                </p>
              </div>
            </article>

            <article class="rounded-xl border border-border-strong bg-secondary/35 overflow-hidden">
              <button
                type="button"
                @click="openId = openId === 'group-faq-2' ? null : 'group-faq-2'"
                class={meditationAccordionBtn}
                :aria-expanded="openId === 'group-faq-2'"
                aria-controls="group-faq-content-2"
              >
                <span class="min-w-0 flex-1 pr-3 text-left">
                  <h3 class="text-left font-display typo-display-md text-ink-primary">
                    Est-ce adapté si je suis anxieux ?
                  </h3>
                </span>
                <span class="shrink-0 self-start font-ui text-xl leading-none text-ink-tertiary" aria-hidden="true">+</span>
              </button>
              <div id="group-faq-content-2" x-show="openId === 'group-faq-2'" class="px-4 pb-4 pt-0 text-left">
                <p class="text-ink-secondary leading-relaxed">
                  Oui, les pratiques proposées peuvent aider à mieux réguler le stress et à
                  retrouver un appui corporel dans les moments d'anxiété.
                </p>
              </div>
            </article>

            <article class="rounded-xl border border-border-strong bg-secondary/35 overflow-hidden">
              <button
                type="button"
                @click="openId = openId === 'group-faq-3' ? null : 'group-faq-3'"
                class={meditationAccordionBtn}
                :aria-expanded="openId === 'group-faq-3'"
                aria-controls="group-faq-content-3"
              >
                <span class="min-w-0 flex-1 pr-3 text-left">
                  <h3 class="text-left font-display typo-display-md text-ink-primary">Est-ce une thérapie ?</h3>
                </span>
                <span class="shrink-0 self-start font-ui text-xl leading-none text-ink-tertiary" aria-hidden="true">+</span>
              </button>
              <div id="group-faq-content-3" x-show="openId === 'group-faq-3'" class="px-4 pb-4 pt-0 text-left">
                <p class="text-ink-secondary leading-relaxed">
                  Non. Ces groupes ne remplacent pas une psychothérapie individuelle.
                </p>
              </div>
            </article>

            <article class="rounded-xl border border-border-strong bg-secondary/35 overflow-hidden">
              <button
                type="button"
                @click="openId = openId === 'group-faq-4' ? null : 'group-faq-4'"
                class={meditationAccordionBtn}
                :aria-expanded="openId === 'group-faq-4'"
                aria-controls="group-faq-content-4"
              >
                <span class="min-w-0 flex-1 pr-3 text-left">
                  <h3 class="text-left font-display typo-display-md text-ink-primary">Puis-je venir une seule fois ?</h3>
                </span>
                <span class="shrink-0 self-start font-ui text-xl leading-none text-ink-tertiary" aria-hidden="true">+</span>
              </button>
              <div id="group-faq-content-4" x-show="openId === 'group-faq-4'" class="px-4 pb-4 pt-0 text-left">
                <p class="text-ink-secondary leading-relaxed">
                  Non. Les groupes sont organisés en cycles de 8 séances, avec une continuité de
                  pratique d'une semaine à l'autre.
                </p>
              </div>
            </article>
          </div>
        </section>
      </article>
    </main>
    <Footer />
  </body>
</html>

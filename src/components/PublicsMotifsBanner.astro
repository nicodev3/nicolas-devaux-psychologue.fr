---
const publics = ["Enfants", "Adolescents", "Adultes", "Couples"];
const motifs = [
  "Difficultés parentales",
  "Conflits de couple",
  "Anxiété",
  "Stress",
  "Dépression",
  "Estime de soi",
  "Parentalité",
  "Addictions",
  "Trauma • Deuil",
  "TOC • Phobies",
  "Sommeil",
  "Burn‑out",
  "Préparation aux examens",
  "Questions liées à la vie sexuelle et au genre"
];
---

<section id="publics" class="mb-8" aria-labelledby="publics-heading">
  <div class="rounded-2xl p-6 md:p-8 bg-white border border-gray-100 shadow-md">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-8 h-8 rounded-full bg-tertiary/10 flex items-center justify-center text-tertiary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          <path fill-rule="evenodd" d="M12 14c-4.418 0-8 2.239-8 5v1a1 1 0 001 1h14a1 1 0 001-1v-1c0-2.761-3.582-5-8-5z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h2 id="publics-heading" class="text-xl font-semibold text-tertiary">Publics accueillis</h2>
    </div>
    <div class="flex flex-wrap gap-2">
      {publics.map((label) => (
        <span class="px-3 py-1 rounded-full bg-white border border-gray-200 text-gray-800 text-sm transition-colors duration-200 hover:bg-primary/10 hover:border-primary/30">{label}</span>
      ))}
    </div>
  </div>
</section>

<section id="motifs" class="mb-12" aria-labelledby="motifs-heading">
  <div class="rounded-2xl p-6 md:p-8 bg-white border border-gray-100 shadow-md">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M12 3a9 9 0 100 18 9 9 0 000-18zM11 7h2v6h-2V7zm0 8h2v2h-2v-2z"/>
        </svg>
      </div>
      <h2 id="motifs-heading" class="text-xl font-semibold text-tertiary">Motifs de consultation</h2>
    </div>
    <ul class="grid sm:grid-cols-2 gap-2 text-sm">
      {motifs.map((motif) => (
        <li class="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg transition-colors duration-200 hover:bg-primary/10 hover:border-primary/30">{motif}</li>
      ))}
    </ul>
  </div>
</section>

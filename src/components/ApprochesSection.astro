---
import SectionHeading from "./SectionHeading.astro";
import { buttonClasses } from "./ui/button";
import { applyFrenchTypography } from "../utils/frenchTypography.js";

const items = [
  {
    url: "/therapie-mosaic/",
    title: "Thérapie EMDR-MOSAIC",
    content:
      "La thérapie MOSAIC, proche de l'EMDR, aide à retraiter les souvenirs douloureux et les vécus traumatiques. Elle peut être indiquée en cas de trauma, de deuil compliqué, d'anxiété persistante ou de blocages émotionnels.",
  },
  {
    url: "/therapie-couple/",
    title: "Thérapie de couple",
    content:
      "Des consultations de couple pour travailler les conflits répétés, les difficultés de communication, les crises et l'éloignement, en s'appuyant sur les approches ACT et IBCT.",
  },
  {
    url: "/psychologue-en-ligne/",
    title: "Consultations en ligne",
    content:
      "Des consultations en visioconférence, dans le même cadre de confidentialité qu'au cabinet, pour les personnes éloignées de Sceaux ou qui préfèrent ce format.",
  },
  {
    url: "/psychotherapie/",
    title: "Psychothérapies intégratives",
    content:
      "Un accompagnement psychothérapeutique pour comprendre ce que vous traversez, mettre des mots sur vos difficultés et avancer à votre rythme dans un cadre contenant et structuré.",
  },
  {
    url: "/tcc-troisieme-vague/",
    title: "Thérapies cognitives et comportementales (TCC)",
    content:
      "Certaines approches TCC de 3e vague comme l'ACT et la CFT proposent des outils concrets pour travailler l'anxiété, les ruminations, le stress, l'autocritique ou l'évitement.",
  },
  {
    url: "/meditation-pleine-conscience-sceaux/",
    title: "Groupes de pleine conscience et gestion du stress",
    content:
      "Des ateliers en petit groupe pour apprendre à porter attention à ses pensées, apaiser le stress et se reconnecter à ses sensations corporelles, dans un cadre simple et guidé.",
  },
];
---

<section
  id="approches"
  class="py-16 md:py-24"
  aria-labelledby="approches-heading"
>
  <div class="w-full px-0">
    <div class="w-full">
      <SectionHeading
        class="mb-4 md:mb-5"
        eyebrow="01 — Consultations"
        title="Des consultations et des approches adaptées à votre situation"
        id="approches-heading"
      />
      <p class="typo-body mb-8 text-ink-secondary leading-relaxed md:mb-10">
        Je propose plusieurs types de consultations : thérapie individuelle, thérapie EMDR-MOSAIC,
        thérapie de couple, consultations en ligne et groupes de pleine conscience. Le choix se fait
        en fonction de votre demande, de votre histoire et des difficultés rencontrées. Lors du
        premier rendez-vous, nous déterminons ensemble le cadre le plus adapté.
      </p>
    </div>

    <div class="grid gap-10 md:grid-cols-2 md:gap-x-12 md:gap-y-14">
      {
        items.map((item) => (
          <article class="flex flex-col">
            <h3 class="font-display typo-display-md text-balance text-ink-primary">
              {applyFrenchTypography(item.title)}
            </h3>
            <div class="mt-4 h-px w-12 bg-brand" aria-hidden="true" />
            <p class="mt-5 text-ink-secondary leading-relaxed text-pretty">{item.content}</p>
            <a
              href={item.url}
              class={buttonClasses({ variant: "link", className: "mt-5 w-fit font-medium normal-case" })}
              aria-label={`En savoir plus sur ${item.title.toLowerCase()}`}
            >
              En savoir plus →
            </a>
          </article>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-border-subtle pt-8 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-8">
      <a href="/psychotherapie/" class={buttonClasses({ variant: "link", className: "font-medium normal-case" })}>
        Toutes les approches
      </a>
      <a href="/consulter/" class={buttonClasses({ variant: "link", className: "font-medium normal-case" })}>
        Comment ça se passe ?
      </a>
    </div>
  </div>
</section>

---
import Card from "./Card.astro";

const mosaicImage = (await import("../assets/mosaic.webp")).default;
const tccImage = (await import("../assets/tcc.webp")).default;
const psychotherapieImage = (await import("../assets/psychotherapie.webp")).default;
---

<section
  id="approches"
  class="mb-16 bg-white rounded-xl shadow-md p-8 md:p-10 border border-gray-100"
  aria-labelledby="approches-heading"
>
  <h2 id="approches-heading" class="mb-5 text-2xl md:text-3xl">
    Des approches adaptées à votre situation
  </h2>
  <p class="max-w-3xl text-gray-700 leading-relaxed mb-10 md:mb-12">
    Je m'appuie sur plusieurs approches complémentaires. Le choix se
    fait en fonction de votre demande, de votre histoire et des
    difficultés rencontrées. Lors du premier rendez-vous, nous
    déterminons ensemble le cadre le plus adapté parmi la
    psychothérapie, la thérapie MOSAIC et certaines approches TCC de
    3e vague.
  </p>
  <div class="grid xl:grid-cols-3 gap-8">
    <Card
      url="/therapie-mosaic/"
      image={mosaicImage}
      title="Thérapie MOSAIC"
      content="La thérapie MOSAIC, proche de l'EMDR, aide à retraiter les souvenirs douloureux et les vécus traumatiques. Elle peut être indiquée en cas de trauma, de deuil compliqué, d'anxiété persistante ou de blocages émotionnels."
    />

    <Card
      url="/tcc-troisieme-vague/"
      image={tccImage}
      title="TCC et thérapies de 3e vague"
      content="Certaines approches TCC de 3e vague comme l'ACT, la MBCT et la CFT proposent des outils concrets pour travailler l'anxiété, les ruminations, le stress, l'autocritique ou l'évitement."
    />

    <Card
      url="/psychotherapie/"
      image={psychotherapieImage}
      title="Psychothérapie"
      content="Un accompagnement psychothérapeutique pour comprendre ce que vous traversez, mettre des mots sur vos difficultés et avancer à votre rythme dans un cadre contenant et structuré."
    />
  </div>
  <div class="mt-8 rounded-xl border border-primary/30 bg-secondary/45 px-5 py-5">
    <p class="text-sm font-semibold text-tertiary mb-3">
      Approches de 3e vague proposees au cabinet
    </p>
    <div class="flex flex-wrap gap-3">
      <a
        href="/therapie-acceptation-et-engagement/"
        class="inline-flex items-center rounded-full border border-gray-200 bg-white px-3 py-1.5 text-sm text-tertiary no-underline transition-colors duration-200 hover:border-primary/30 hover:bg-secondary/40"
      >
        ACT
      </a>
      <a
        href="/therapie-fondee-compassion/"
        class="inline-flex items-center rounded-full border border-gray-200 bg-white px-3 py-1.5 text-sm text-tertiary no-underline transition-colors duration-200 hover:border-primary/30 hover:bg-secondary/40"
      >
        CFT
      </a>
      <a
        href="/therapie-pleine-conscience/"
        class="inline-flex items-center rounded-full border border-gray-200 bg-white px-3 py-1.5 text-sm text-tertiary no-underline transition-colors duration-200 hover:border-primary/30 hover:bg-secondary/40"
      >
        MBCT
      </a>
    </div>
  </div>
  <div class="mt-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <a
        href="/psychotherapie/"
        class="font-semibold text-accent-dark underline hover:no-underline"
      >
        Voir l'ensemble des approches proposées
      </a>
      <a
        href="/consulter/"
        class="font-semibold text-accent-dark underline hover:no-underline"
      >
        Comprendre comment se déroule un suivi
      </a>
    </div>
  </div>
</section>

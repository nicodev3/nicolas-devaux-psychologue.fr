---
import { Clock, Euro } from "lucide";
import SectionHeading from "./SectionHeading.astro";
import LucideIcon from "./LucideIcon.astro";
import { buttonClasses } from "./ui/button";
import { DOCTOLIB_BOOKING_URL } from "../consts";

const tariffs = [
  { label: "Consultation individuelle", duration: "45 min", price: "80€" },
  { label: "Consultation MOSAIC", duration: "1 h", price: "90€" },
  { label: "Consultation de couple", duration: "1 h", price: "110€" },
  { label: "Mon Soutien Psy*", duration: "30 min", price: "50€" },
  { label: "Participation aux groupes", duration: "8 séances", price: "30€ / séance" },
] as const;
---

<section
  id="horaires-tarifs"
  class="py-16 md:py-24"
  aria-labelledby="horaires-tarifs-heading"
>
  <div class="w-full min-w-0">
    <SectionHeading class="mb-10 md:mb-12" eyebrow="04 — Pratique" id="horaires-tarifs-heading">
      <a href="/tarifs/" class="text-inherit no-underline transition-colors hover:text-brand">
        Horaires et tarifs
      </a>
    </SectionHeading>

    <div class="grid min-w-0 gap-10 md:grid-cols-2 md:gap-12">
      <article class="min-w-0" aria-labelledby="tarifs-heading">
        <div class="mb-6 flex items-center gap-3">
          <div
            class="flex size-12 shrink-0 items-center justify-center rounded-full bg-surface-muted"
            aria-hidden="true"
          >
            <LucideIcon icon={Euro} size="lg" class="text-ink-secondary" />
          </div>
          <h3 id="tarifs-heading" class="font-display typo-display-md text-ink-primary">
            Tarifs des consultations
          </h3>
        </div>

        <ul class="list-none border-t border-border-strong p-0" role="list">
          {
            tariffs.map(({ label, duration, price }) => (
              <li class="border-b border-border-subtle py-4 last:border-b-0">
                <div
                  class="grid items-baseline gap-x-4 font-ui [grid-template-columns:minmax(0,1fr)_88px_112px] md:gap-x-5"
                >
                  <span class="min-w-0 text-pretty text-base leading-snug text-ink-secondary">{label}</span>
                  <span class="whitespace-nowrap text-base leading-snug tabular-nums text-ink-secondary">{duration}</span>
                  <span class="text-right text-lg font-semibold leading-snug tabular-nums text-ink-primary">{price}</span>
                </div>
              </li>
            ))
          }
        </ul>

        <div class="mt-6 border-l-2 border-info-border bg-info-surface/80 py-3 pl-4 pr-3">
          <p class="text-sm text-info-ink">
            <strong>*Mon Soutien Psy :</strong> Ces séances remboursées ne peuvent être prises qu'avec mon accord
            préalable.
            <a href="/mon-soutien-psy/" class="text-link underline hover:no-underline">
              Voir les conditions d'accès
            </a>.
          </p>
        </div>

        <div class="mt-4 border-l-2 border-border-strong py-2 pl-4">
          <p class="text-sm text-ink-secondary">
            <strong class="text-ink-primary">Paiement :</strong> Chèques, espèces et virement bancaire. Cartes
            bancaires non acceptées.
          </p>
        </div>
      </article>

      <article class="min-w-0" aria-labelledby="horaires-heading">
        <div class="mb-6 flex items-center gap-3">
          <div
            class="flex size-12 shrink-0 items-center justify-center rounded-full bg-surface-muted"
            aria-hidden="true"
          >
            <LucideIcon icon={Clock} size="lg" class="text-ink-secondary" />
          </div>
          <h3 id="horaires-heading" class="font-display typo-display-md text-ink-primary">Horaires d'ouverture</h3>
        </div>

        <div class="space-y-3">
          <div class="flex items-center justify-between gap-4 border-b border-border-subtle py-2">
            <span class="min-w-0 text-pretty text-ink-secondary">Lundi, mardi et vendredi</span>
            <span class="shrink-0 font-medium tabular-nums text-ink-primary">8h00 - 20h00</span>
          </div>
          <div class="flex items-center justify-between gap-4 py-2">
            <span class="min-w-0 text-ink-secondary">Autres jours</span>
            <span class="shrink-0 font-medium text-danger">Fermé</span>
          </div>
        </div>

        <div class="mt-6 border-l-2 border-border-strong py-2 pl-4">
          <p class="text-sm text-ink-secondary">
            <strong class="text-ink-primary">Prise de rendez-vous :</strong> Consultations sur rendez-vous uniquement.
            <a href="/consulter/" class="text-link underline hover:no-underline">Voir les modalités de consultation</a>.
          </p>
        </div>

        <div class="mt-6 flex max-w-md flex-col gap-3">
          <a
            href={DOCTOLIB_BOOKING_URL}
            target="_blank"
            rel="noopener noreferrer"
            class={buttonClasses({
              variant: "primary",
              size: "lg",
              fullWidth: true,
              className: "justify-center normal-case",
            })}
            aria-label="Prendre rendez-vous sur Doctolib"
            data-track-doctolib
            data-track-location="Bloc horaires accueil"
          >
            Prendre rendez-vous
          </a>
          <a
            href="/consulter/"
            class={buttonClasses({
              variant: "secondary",
              size: "lg",
              fullWidth: true,
              className: "justify-center font-normal normal-case",
            })}
          >
            En savoir plus →
          </a>
          <p class="text-sm text-ink-tertiary">
            Les créneaux et la réservation se font sur Doctolib ; la page Consulter détaille le déroulé et les modalités
            avant le premier rendez-vous.
          </p>
        </div>
      </article>
    </div>
  </div>
</section>

---
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  author?: string;
  heroImage?: ImageMetadata;
}

const { title, description, pubDate, slug, author = "Nicolas Devaux", heroImage } = Astro.props;
const url = new URL(`/blog/${slug}/`, Astro.site);
const image = heroImage
  ? {
      "@type": "ImageObject",
      "url": new URL(heroImage.src, Astro.site).toString(),
      "width": heroImage.width,
      "height": heroImage.height,
    }
  : undefined;

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": url.toString(),
  ...(image ? { image } : {}),
  "datePublished": pubDate.toISOString(),
  "dateModified": pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "@id": "https://nicolas-devaux-psychologue.fr/#nicolas",
    name: author,
  },
  publisher: {
    "@id": "https://nicolas-devaux-psychologue.fr/#cabinet",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": url.toString(),
  },
  image: {
    "@type": "ImageObject",
    url: "https://nicolas-devaux-psychologue.fr/nicolas_devaux.jpg",
  },
  inLanguage: "fr-FR",
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />

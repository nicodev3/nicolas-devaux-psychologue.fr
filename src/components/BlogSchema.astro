---
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  author?: string;
  heroImage?: ImageMetadata;
}

const { title, description, pubDate, slug, author = "Nicolas Devaux", heroImage } = Astro.props;
const url = new URL(`/blog/${slug}/`, Astro.site);
const image = heroImage
  ? {
      "@type": "ImageObject",
      "url": new URL(heroImage.src, Astro.site).toString(),
      "width": heroImage.width,
      "height": heroImage.height,
    }
  : undefined;

const blogJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": url.toString(),
  ...(image ? { image } : {}),
  "datePublished": pubDate.toISOString(),
  "dateModified": pubDate.toISOString(),
  "author": {
    "@type": "Person",
    "name": author,
    "jobTitle": "Psychologue clinicien",
    "worksFor": {
      "@type": "MedicalBusiness",
      "name": "Nicolas Devaux - Psychologue"
    }
  },
  "publisher": {
    "@type": "MedicalBusiness",
    "name": "Nicolas Devaux - Psychologue",
    "url": "https://nicolas-devaux-psychologue.fr",
    "logo": {
      "@type": "ImageObject",
      "url": "https://nicolas-devaux-psychologue.fr/logo-300.jpg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": url.toString()
  },
  "keywords": [
    "psychologie",
    "psychothérapie",
    "thérapie cognitive et comportementale",
    "TCC",
    "thérapie d'acceptation et d'engagement",
    "ACT",
    "pleine conscience",
    "MBCT",
    "anxiété",
    "dépression",
    "santé mentale"
  ],
  "about": [
    {
      "@type": "MedicalCondition",
      "name": "Troubles anxieux"
    },
    {
      "@type": "MedicalCondition",
      "name": "Dépression"
    },
    {
      "@type": "MedicalCondition",
      "name": "Troubles de l'humeur"
    }
  ],
  "mentions": [
    {
      "@type": "MedicalBusiness",
      "name": "Nicolas Devaux - Psychologue",
      "url": "https://nicolas-devaux-psychologue.fr"
    }
  ]
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(blogJsonLd)} />

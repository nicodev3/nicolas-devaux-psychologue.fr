---
interface Props {
  title?: string;
}

const { title } = Astro.props;

const SITE_URL = "https://nicolas-devaux-psychologue.fr";

const LABEL_MAP: Record<string, string> = {
  consulter: "Consulter",
  psychotherapie: "Approches thérapeutiques",
  "therapie-mosaic": "Thérapie MOSAIC",
  "tcc-troisieme-vague": "TCC de 3e vague",
  "therapie-cognitive-et-comportementale": "Thérapie cognitive et comportementale",
  "therapie-acceptation-et-engagement": "ACT (TCC de 3e vague)",
  "therapie-pleine-conscience": "MBCT/MBSR (TCC de 3e vague)",
  "therapie-fondee-compassion": "Thérapie fondée sur la compassion",
  "mon-soutien-psy": "Mon Soutien Psy",
  "nicolas-devaux-psychologue": "À propos",
  "mentions-legales": "Mentions légales",
  blog: "Articles",
  outils: "Outils",
  "meditation-pleine-conscience-sceaux": "Méditation (groupes)",
};

const pathname = Astro.url.pathname;

const isHome = pathname === "/" || pathname === "";
if (isHome) {
  // Pas de rendu
}

const segments = pathname.replace(/^\/|\/$/g, "").split("/").filter(Boolean);

interface Crumb {
  label: string;
  href: string;
}

const crumbs: Crumb[] = [{ label: "Accueil", href: "/" }];

let cumulativePath = "";
segments.forEach((segment, index) => {
  cumulativePath += `/${segment}`;
  const isLast = index === segments.length - 1;

  let label: string;
  if (isLast && title && !LABEL_MAP[segment]) {
    label = title;
  } else {
    label = LABEL_MAP[segment] ?? segment.replace(/-/g, " ");
  }

  crumbs.push({ label, href: `${cumulativePath}/` });
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: crumbs.map((crumb, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: crumb.label,
    item: `${SITE_URL}${crumb.href}`,
  })),
};
---

{
  !isHome && (
    <>
      <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      <nav aria-label="Fil d'Ariane" class="mb-6 md:mb-8">
        <ol class="flex flex-wrap items-center gap-x-2 gap-y-1 typo-meta text-ink-tertiary">
          {crumbs.map((crumb, index) => {
            const isLast = index === crumbs.length - 1;
            return (
              <li class="flex items-center gap-x-2">
                {index > 0 && <span aria-hidden="true">/</span>}
                {isLast ? (
                  <span class="text-ink-primary" aria-current="page">
                    {crumb.label}
                  </span>
                ) : (
                  <a href={crumb.href} class="text-link transition-colors hover:text-brand-hover">
                    {crumb.label}
                  </a>
                )}
              </li>
            );
          })}
        </ol>
      </nav>
    </>
  )
}

---
import { Link, Share2 } from "lucide";
import LucideIcon from "./LucideIcon.astro";

interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);

const shareLinks = [
  {
    label: "LinkedIn",
    href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
    external: true,
  },
  {
    label: "Facebook",
    href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
    external: true,
  },
  {
    label: "X",
    href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
    external: true,
  },
] as const;
---

<nav class="article-share" aria-label="Partager cet article">
  <p class="article-share__label">
    <LucideIcon icon={Share2} size="sm" />
    <span>Partager</span>
  </p>
  <ul class="article-share__list">
    {
      shareLinks.map((item) => (
        <li>
          <a
            href={item.href}
            class="article-share__link"
            target="_blank"
            rel="noopener noreferrer"
          >
            {item.label}
          </a>
        </li>
      ))
    }
    <li>
      <button
        type="button"
        class="article-share__link"
        data-share-email
        data-share-subject={title}
        data-share-body={`${title}\n\n${url}`}
      >
        Email
      </button>
    </li>
    <li>
      <button type="button" class="article-share__link article-share__copy" data-share-copy={url}>
        <LucideIcon icon={Link} size="sm" />
        <span>Copier le lien</span>
      </button>
    </li>
  </ul>
</nav>

<script is:inline>
  document.querySelectorAll("[data-share-copy]").forEach(function (button) {
    if (!(button instanceof HTMLButtonElement)) return;
    var defaultText = (button.textContent || "").trim() || "Copier le lien";

    button.addEventListener("click", function () {
      var url = button.getAttribute("data-share-copy");
      if (!url || !navigator.clipboard) return;

      navigator.clipboard.writeText(url).then(function () {
        var label = button.querySelector("span");
        if (!label) return;
        label.textContent = "Lien copié";
        window.setTimeout(function () {
          label.textContent = defaultText;
        }, 1800);
      });
    });
  });

  document.querySelectorAll("[data-share-email]").forEach(function (button) {
    if (!(button instanceof HTMLButtonElement)) return;

    button.addEventListener("click", function () {
      var subject = button.getAttribute("data-share-subject");
      var body = button.getAttribute("data-share-body");
      if (!subject || !body) return;

      window.location.href =
        "mailto:?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
    });
  });
</script>

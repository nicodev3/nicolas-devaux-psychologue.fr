---
import { LayoutList } from "lucide";
import LucideIcon from "./LucideIcon.astro";
import { buttonClasses } from "./ui/button";
import {
  ADELI_NUMBER,
  DOCTOLIB_BOOKING_URL,
  LEGAL_ENTITY_NAME,
  RPPS_NUMBER,
  SIRET_NUMBER,
} from "../consts";

const footerBookingClasses = buttonClasses({
  variant: "primary",
  size: "lg",
  className:
    "inline-flex w-full max-w-sm items-center justify-center normal-case md:w-auto md:min-w-[240px]",
});

const siteMap = [
  {
    title: "Pages principales",
    links: [
      { href: "/", label: "Accueil" },
      { href: "/psychologue-sceaux/", label: "Psychologue à Sceaux" },
      { href: "/therapie-couple/", label: "Thérapie de couple" },
      { href: "/psychologue-en-ligne/", label: "Psychologue en ligne" },
      { href: "/meditation-pleine-conscience-sceaux/", label: "Groupes de pleine conscience" },
      { href: "/consulter/", label: "Consulter" },
      { href: "/tarifs/", label: "Tarifs" },
      { href: "/nicolas-devaux-psychologue/", label: "À propos" },
      { href: "/psychotherapie/", label: "Approches thérapeutiques" },
      { href: "/blog/", label: "Articles" },
    ],
  },
  {
    title: "Approches thérapeutiques",
    links: [
      { href: "/therapie-mosaic/", label: "Thérapie EMDR-MOSAIC" },
      {
        href: "/therapie-cognitive-et-comportementale/",
        label: "Thérapie cognitive et comportementale",
      },
      { href: "/tcc-troisieme-vague/", label: "TCC de 3e vague" },
      { href: "/therapie-acceptation-et-engagement/", label: "ACT (TCC de 3e vague)" },
      { href: "/therapie-pleine-conscience/", label: "MBCT/MBSR (TCC de 3e vague)" },
      { href: "/therapie-fondee-compassion/", label: "Thérapie fondée sur la compassion" },
    ],
  },
  {
    title: "Informations",
    links: [
      { href: "/mon-soutien-psy/", label: "Mon Soutien Psy" },
      { href: "/mentions-legales/", label: "Mentions légales" },
    ],
  },
];

const rgpdHref = "/mentions-legales/#protection-des-donnees-personnelles";
---

<footer class="bg-surface-footer text-brand-ink-on">
  <div class="container py-12 md:py-16">
    <div class="min-w-0">
      <h3 class="footer-section-label mb-8 flex items-center gap-2 sm:mb-10">
        <LucideIcon icon={LayoutList} size="lg" class="text-brand-ink-on/85" />
        Plan du site
      </h3>
      <div
        class="grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2 sm:gap-x-5 sm:gap-y-10 lg:grid-cols-3 lg:gap-x-6 lg:gap-y-10"
      >
        {
          siteMap.map((group) => (
            <div class="min-w-0">
              <h4 class="footer-section-label mb-4">{group.title}</h4>
              <ul class="space-y-1.5 font-ui">
                {group.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm font-medium text-brand-ink-on underline decoration-brand-ink-on/35 underline-offset-2 transition-colors hover:text-brand-ink-on hover:decoration-brand-ink-on"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-12 flex justify-center border-t border-brand-ink-on/15 px-4 pt-10">
      <a
        href={DOCTOLIB_BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class={footerBookingClasses}
        aria-label="Prendre rendez-vous sur Doctolib"
        data-track-doctolib
        data-track-location="Footer"
      >
        Prendre rendez-vous
      </a>
    </div>

    <div class="mt-12 border-t border-brand-ink-on/15 pt-8">
      <p class="mx-auto mb-6 max-w-3xl text-center text-sm font-ui leading-relaxed text-brand-ink-on/90">
        Les informations échangées dans le cadre des consultations sont protégées par le secret professionnel ; les
        traitements de données liés au site sont décrits dans les mentions légales (RGPD).
      </p>
      <div class="flex flex-col items-center gap-4 md:flex-row md:justify-between md:gap-6">
        <p class="text-center text-sm text-brand-ink-on/90 md:text-left">
          © {new Date().getFullYear()} {LEGAL_ENTITY_NAME} · Psychologue à Sceaux. Tous droits réservés.
        </p>
        <div
          class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm font-ui md:justify-end"
        >
          <a
            href="/mentions-legales/"
            class="font-semibold text-brand-ink-on underline decoration-brand-ink-on/45 underline-offset-2 transition-colors hover:decoration-brand-ink-on"
          >
            Mentions légales
          </a>
          <span class="text-brand-ink-on/35" aria-hidden="true">·</span>
          <a
            href={rgpdHref}
            class="font-semibold text-brand-ink-on underline decoration-brand-ink-on/45 underline-offset-2 transition-colors hover:decoration-brand-ink-on"
          >
            Secret professionnel & RGPD
          </a>
          <span class="text-brand-ink-on/35" aria-hidden="true">·</span>
          <span class="tabular-nums text-brand-ink-on/90">SIRET : {SIRET_NUMBER}</span>
          <span class="text-brand-ink-on/35" aria-hidden="true">·</span>
          <span class="tabular-nums text-brand-ink-on/90">RPPS : {RPPS_NUMBER}</span>
          {
            ADELI_NUMBER ? (
              <span class="inline-flex items-center gap-x-4">
                <span class="text-brand-ink-on/35" aria-hidden="true">
                  ·
                </span>
                <span class="tabular-nums text-brand-ink-on/90">ADELI : {ADELI_NUMBER}</span>
              </span>
            ) : null
          }
        </div>
      </div>
    </div>
  </div>
</footer>

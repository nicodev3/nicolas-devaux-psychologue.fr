---
import SectionHeading from "./SectionHeading.astro";
import { Picture } from "astro:assets";
import cabinet1 from "../assets/cabinet-1.webp";
import cabinet2 from "../assets/cabinet-2.webp";

const shots = [
  {
    src: cabinet1,
    alt: "Cabinet de psychologie Nicolas Devaux à Sceaux - Vue du bureau de consultation pour thérapie individuelle et de couple",
  },
  {
    src: cabinet2,
    alt: "Salle d'attente du cabinet de psychologie à Sceaux - Espace d'accueil calme et confidentiel",
  },
] as const;
---

<section
  class="py-16 md:py-24"
  aria-labelledby="cabinet-gallery-heading"
>
  <div class="w-full px-0">
    <SectionHeading class="mb-3 md:mb-4" eyebrow="02 — Cabinet" title="Le cabinet à Sceaux" id="cabinet-gallery-heading" />
    <p class="font-body typo-body max-w-measure text-pretty text-ink-secondary">
      Le cabinet de psychologie est situé au <strong>63 rue Houdan à Sceaux</strong> (92330), facilement accessible depuis
      Antony, Bourg-la-Reine, Châtenay-Malabry et Fontenay-aux-Roses. Un espace simple et calme, pensé pour échanger en toute
      confidentialité.
    </p>
    <div class="mt-8 grid gap-3 sm:grid-cols-2">
      {
        shots.map(({ src, alt }) => (
          <figure class="overflow-hidden rounded-xl border border-border-subtle bg-surface-muted shadow-(--shadow-soft)">
            <Picture
              src={src}
              formats={["avif", "webp"]}
              fallbackFormat="webp"
              widths={[320, 480, 640]}
              sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, 480px"
              alt={alt}
              loading="lazy"
              decoding="async"
              class="aspect-4/3 h-auto w-full object-cover"
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

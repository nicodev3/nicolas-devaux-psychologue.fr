---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { buttonClasses } from "./ui/button";

interface Props {
  title: string;
  content: string;
  url: string;
  image: ImageMetadata;
}

const { title, content, url, image }: Props = Astro.props;
const ctaLabel = "Découvrir →";
const ctaAriaLabel = `Découvrir ${title}`;

const cardCta = buttonClasses({
  variant: "primary",
  size: "lg",
  fullWidth: true,
  className: "pointer-events-none normal-case",
});
---

<a
  href={url}
  class:list={[
    "group relative flex h-full flex-col overflow-hidden rounded-2xl border border-border-strong/90 bg-surface-raised shadow-sm transition-colors duration-200 hover:border-brand/35 focus-visible:border-brand/35",
  ]}
  aria-label={ctaAriaLabel}
>
  <!-- En-tête avec titre -->
  <header class="flex min-h-32 flex-col justify-start p-6 pb-3 md:min-h-36 md:p-7">
    <h3 class="text-xl md:text-2xl font-medium text-tertiary text-balance">
      {title}
    </h3>
    <div class="mt-3 h-0.5 w-10 rounded-full bg-brand"></div>
  </header>

  <!-- Container image -->
  <div class="px-6 md:px-7">
    <div class="flex h-44 items-center justify-center rounded-xl border border-border-subtle bg-surface-muted p-4 shadow-inner md:h-48">
      <Picture
        src={image}
        alt={title}
        width={220}
        height={140}
        formats={["avif", "webp"]}
        fallbackFormat="webp"
        loading="lazy"
        decoding="async"
        fit="contain"
        class="h-auto max-h-full w-auto max-w-full rounded-lg object-contain"
      />
    </div>
  </div>

  <!-- Contenu principal -->
  <div class="grow px-6 py-5 md:px-7">
    <p class="text-ink-secondary leading-relaxed text-base text-pretty">
      {content}
    </p>
  </div>

  <!-- Footer avec bouton -->
  <footer class="mt-auto p-6 pt-2 md:px-7 md:pb-7">
    <span class:list={[cardCta, "transition-opacity duration-200 group-hover:opacity-95"]}>
      {ctaLabel}
    </span>
  </footer>
</a>

---
import { Image } from "astro:assets";

interface Props {
  title: string;
  content: string;
  url: string;
  image: ImageMetadata;
  featured?: boolean;
}

const { title, content, url, image, featured = false } = Astro.props;
---

<article
  class:list={[
    "group bg-white rounded-xl transition-shadow duration-300 overflow-hidden flex flex-col h-full",
    featured
      ? "border-2 border-accent shadow-lg hover:shadow-xl"
      : "border border-gray-100 shadow-md hover:shadow-lg",
  ]}
>
  <!-- En-tête avec titre -->
  <header class="p-6 pb-4">
    <h3 class="text-2xl font-bold text-tertiary leading-tight">
      {title}
    </h3>
    <div class="w-8 h-0.5 bg-accent rounded-full mt-3"></div>
  </header>

  <!-- Container image -->
  <div class="px-6 flex justify-center">
    <div class="bg-secondary/30 p-4 rounded-lg">
      <Image
        src={image}
        alt={title}
        width={174}
        height={174}
        class="rounded-lg"
      />
    </div>
  </div>

  <!-- Contenu principal -->
  <div class="flex-grow px-6 py-4">
    <p class="text-gray-700 leading-relaxed text-base">
      {content}
    </p>
  </div>

  <!-- Footer avec bouton -->
  <footer class="p-6 pt-4 mt-auto">
    <div class="flex">
      <a
        href={url}
        class="btn-modern w-full min-h-[3.25rem]"
        aria-label={`En savoir plus sur ${title}`}
      >
        En savoir plus sur {title}
      </a>
    </div>
  </footer>
</article>

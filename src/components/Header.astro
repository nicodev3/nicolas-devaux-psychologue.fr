---
import HeaderLink from "./HeaderLink.astro";
import BrandSpiralMark from "./BrandSpiralMark.astro";
import ApproachesDropdown from "./ApproachesDropdown.tsx";
import { buttonClasses } from "./ui/button";
import { DOCTOLIB_BOOKING_URL } from "../consts";

interface Props {
  /** Masque la barre pleine largeur « Prendre rendez-vous » sous le menu (ex. accueil avec FAB). */
  suppressMobileBookingCta?: boolean;
}

const { suppressMobileBookingCta = false } = Astro.props;

const burgerBtn = buttonClasses({
  variant: "ghost",
  size: "md",
  className:
    "shrink-0 xl:hidden !h-10 !min-h-[40px] !w-10 !min-w-[40px] !rounded-lg !p-0 hover:bg-surface-muted",
});

const desktopNavLink =
  "font-ui rounded-md px-3 py-2.5 text-sm font-medium text-body-muted transition-colors duration-200 hover:bg-surface-muted hover:text-brand md:hover:bg-transparent";

const sheetLink =
  "font-ui block rounded-lg px-4 py-3 text-sm font-medium text-body-muted transition-colors hover:bg-surface-muted hover:text-brand";
---

<header class="sticky top-0 z-30 border-b border-border-subtle bg-surface-raised shadow-sm">
  <nav
    class="container relative py-3 md:py-4"
    aria-label="Navigation principale"
    x-data="{ open: false }"
    x-init="matchMedia('(min-width: 1280px)').addEventListener('change', (e) => { if (e.matches) open = false })"
    x-effect="document.documentElement.classList.toggle('overflow-hidden', open)"
    @keydown.escape.window="open = false"
  >
    <div class="flex items-center justify-between gap-4">
      <a href="/" class="group flex shrink-0 items-center gap-2 md:gap-2.5">
        <BrandSpiralMark class="h-8 w-8 shrink-0 text-brand/75 md:h-9 md:w-9" />
        <div class="text-logo font-ui">
          <span class="text-lg font-medium tracking-tight text-ink-primary">Nicolas</span>
          <span class="ml-1 text-lg font-medium text-brand">Devaux</span>
          <div class="-mt-1 text-xs font-medium tracking-wide text-body-muted">Psychologue</div>
        </div>
      </a>

      <div class="hidden min-w-0 xl:flex xl:flex-1 xl:items-center xl:justify-end xl:gap-1 xl:pl-6">
        <ApproachesDropdown client:load />
        <HeaderLink class={desktopNavLink} href="/psychologue-sceaux/">Sceaux</HeaderLink>
        <HeaderLink class={desktopNavLink} href="/consulter/">Consulter</HeaderLink>
        <HeaderLink class={desktopNavLink} href="/tarifs/">Tarifs</HeaderLink>
        <HeaderLink class={desktopNavLink} href="/nicolas-devaux-psychologue/">À propos</HeaderLink>
        <HeaderLink class={desktopNavLink} href="/blog/">Articles</HeaderLink>
        <HeaderLink class={desktopNavLink} href="/outils/">Outils</HeaderLink>
        <a
          href={DOCTOLIB_BOOKING_URL}
          target="_blank"
          class={buttonClasses({
            variant: "primary",
            size: "sm",
            className: "ml-2 shrink-0 whitespace-nowrap",
          })}
          aria-label="Prendre rendez-vous sur Doctolib"
          data-track-doctolib
          data-track-location="Header Desktop"
          rel="noopener noreferrer"
        >
          Prendre rendez-vous
        </a>
      </div>

      <button
        type="button"
        class={burgerBtn}
        x-on:click="open = !open"
        :aria-label="open ? 'Fermer le menu' : 'Ouvrir le menu'"
        :aria-expanded="open"
        aria-controls="site-navigation"
      >
        <span class="nav-burger" :class="open ? 'nav-burger--open' : ''" aria-hidden="true">
          <span class="nav-burger__bar"></span>
          <span class="nav-burger__bar"></span>
          <span class="nav-burger__bar"></span>
        </span>
      </button>
    </div>

    <!-- Panneau mobile : même easing que le menu « Approches » (Prompt 7). -->
    <div class="xl:hidden">
      <div
        x-show="open"
        x-transition:enter="transition-opacity duration-300 nav-sheet-ease"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition-opacity duration-300 nav-sheet-ease"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed inset-0 z-80 bg-ink-primary/40"
        aria-hidden="true"
        x-on:click="open = false"
      >
      </div>

      <div
        id="site-navigation"
        role="dialog"
        aria-modal="true"
        aria-label="Menu du site"
        tabindex="-1"
        x-show="open"
        x-transition:enter="transition-transform duration-300 nav-sheet-ease"
        x-transition:enter-start="translate-x-full"
        x-transition:enter-end="translate-x-0"
        x-transition:leave="transition-transform duration-300 nav-sheet-ease"
        x-transition:leave-start="translate-x-0"
        x-transition:leave-end="translate-x-full"
        class="nav-mobile-sheet fixed inset-y-0 right-0 z-90 flex h-dvh w-[min(20rem,calc(100vw-1rem))] max-w-full flex-col border-l border-border-subtle bg-surface-raised shadow-2xl outline-none"
        x-on:click.stop
      >
        <div class="flex shrink-0 items-center justify-between border-b border-border-subtle px-4 py-3">
          <span class="font-ui text-sm font-semibold text-ink-primary">Menu</span>
          <button
            type="button"
            class={buttonClasses({
              variant: "ghost",
              size: "sm",
              className: "min-h-9! text-ink-secondary hover:text-brand",
            })}
            x-on:click="open = false"
          >
            Fermer
          </button>
        </div>

        <div class="flex min-h-0 flex-1 flex-col gap-1 overflow-y-auto overscroll-y-contain p-3 pb-10">
          <HeaderLink class={sheetLink} href="/psychotherapie/" x-on:click="open = false"
            >Vue d’ensemble — Approches</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/therapie-mosaic/" x-on:click="open = false"
            >Thérapie EMDR-MOSAIC</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/therapie-couple/" x-on:click="open = false"
            >Thérapie de couple</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/psychologue-en-ligne/" x-on:click="open = false"
            >Consultations en ligne</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/tcc-troisieme-vague/" x-on:click="open = false"
            >TCC de 3e vague</HeaderLink
          >
          <HeaderLink
            class={sheetLink}
            href="/meditation-pleine-conscience-sceaux/"
            x-on:click="open = false">Méditation (groupes)</HeaderLink
          >
          <div class="my-2 h-px bg-border-subtle" aria-hidden="true"></div>
          <HeaderLink class={sheetLink} href="/psychologue-sceaux/" x-on:click="open = false"
            >Psychologue à Sceaux</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/consulter/" x-on:click="open = false">Consulter</HeaderLink>
          <HeaderLink class={sheetLink} href="/tarifs/" x-on:click="open = false">Tarifs</HeaderLink>
          <HeaderLink class={sheetLink} href="/nicolas-devaux-psychologue/" x-on:click="open = false"
            >À propos</HeaderLink
          >
          <HeaderLink class={sheetLink} href="/blog/" x-on:click="open = false">Articles</HeaderLink>
          <HeaderLink class={sheetLink} href="/outils/" x-on:click="open = false">Outils</HeaderLink>
        </div>
      </div>
    </div>
  </nav>
</header>
{
  !suppressMobileBookingCta && (
    <a
      href={DOCTOLIB_BOOKING_URL}
      target="_blank"
      class={buttonClasses({
        variant: "primary",
        size: "md",
        fullWidth: true,
        className: "xl:hidden",
      })}
      aria-label="Prendre rendez-vous Doctolib"
      data-track-doctolib
      data-track-location="Header Mobile"
      rel="noopener noreferrer"
    >
      Prendre rendez-vous
    </a>
  )
}

<style>
  h2 a,
  h2 a.active {
    text-decoration: none;
  }

  .nav-burger {
    position: relative;
    display: block;
    width: 1.5rem;
    height: 1.125rem;
  }

  .nav-burger__bar {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    border-radius: 1px;
    background-color: var(--color-ink-secondary);
    transition:
      transform 0.3s ease,
      opacity 0.2s ease,
      top 0.3s ease;
  }

  .nav-burger__bar:nth-child(1) {
    top: 0;
  }

  .nav-burger__bar:nth-child(2) {
    top: 8px;
  }

  .nav-burger__bar:nth-child(3) {
    top: 16px;
  }

  .nav-burger--open .nav-burger__bar:nth-child(1) {
    top: 8px;
    transform: rotate(45deg);
  }

  .nav-burger--open .nav-burger__bar:nth-child(2) {
    opacity: 0;
  }

  .nav-burger--open .nav-burger__bar:nth-child(3) {
    top: 8px;
    transform: rotate(-45deg);
  }

  /* cubic-bezier(0.16, 1, 0.3, 1) — aligné sur ApproachesDropdown / Framer easeMenu */
  :global(.nav-sheet-ease) {
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.nav-sheet-ease) {
      transition-duration: 1ms !important;
    }
  }
</style>


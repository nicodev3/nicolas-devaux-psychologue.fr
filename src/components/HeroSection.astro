---
import AuthorCard from "./AuthorCard.astro";
import BrandSpiralMark from "./BrandSpiralMark.astro";
import HomeTrustStrip from "./HomeTrustStrip.astro";
import { buttonClasses } from "./ui/button";
import { DOCTOLIB_BOOKING_URL } from "../consts";

const approachTeaserLink = buttonClasses({
  variant: "link",
  className: "font-medium normal-case",
});
---

<section id="hero" class="w-full pb-16 pt-2 md:pb-24 md:pt-6" aria-labelledby="hero-heading">
  <div class="flex w-full flex-col gap-6 md:gap-8">
    <header class="max-w-none">
      <div class="flex flex-col gap-8 lg:flex-row lg:flex-wrap lg:items-start lg:justify-between lg:gap-6">
        <div class="min-w-0 flex-1">
          <h1
            id="hero-heading"
            class="font-display hero-heading-display mb-3 whitespace-nowrap text-ink-primary md:mb-4"
          >
            Psychologue à Sceaux
          </h1>
          <AuthorCard class="mt-5" />
        </div>
        <div class="shrink-0 pt-1 md:pt-2">
          <BrandSpiralMark class="h-24 w-24 text-brand/65 md:h-[7.5rem] md:w-[7.5rem]" />
        </div>
      </div>

      <p class="typo-body-lg text-body-muted mb-0 mt-6 md:mt-7">
        <strong class="font-medium text-ink-primary">Consultations pour adultes, adolescents et couples</strong>, au
        cabinet ou en visioconférence.
      </p>
    </header>

    <p class="typo-body max-w-none">
      Psychologue diplômé de l'Université Paris Cité, je vous accueille à
      <a href="/psychologue-sceaux/" class="text-link">Sceaux</a> dans un cadre bienveillant et confidentiel. Mon
      approche est intégrative et s'adapte à votre situation, à votre rythme et à vos objectifs.
    </p>

    <nav class="flex max-w-none flex-wrap gap-x-6 gap-y-2" aria-label="Liens vers les approches">
      <a href="/therapie-mosaic/" class={approachTeaserLink}>Thérapie MOSAIC →</a>
      <a href="/psychotherapie/" class={approachTeaserLink}>Psychothérapies intégratives →</a>
      <a href="/tcc-troisieme-vague/" class={approachTeaserLink}>TCC de troisième vague →</a>
    </nav>

    <div class="flex flex-col items-start gap-2">
      <a
        href={DOCTOLIB_BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class={buttonClasses({ variant: "primary", size: "lg", className: "shrink-0" })}
        aria-label="Prendre rendez-vous sur Doctolib"
        data-track-doctolib
        data-track-location="Hero"
      >
        Prendre rendez-vous
      </a>
      <p class="font-ui typo-meta max-w-measure text-pretty text-ink-tertiary">
        Vos données restent confidentielles. Messagerie sécurisée via Doctolib.
      </p>
      <p class="text-sm leading-snug">
        <strong class="font-semibold text-ink-primary">
          Je ne prends plus de nouveaux patients dans le dispositif Mon Soutien Psy.
        </strong>
        <span class="text-ink-tertiary">
          {' '}
          Pour le cadre du dispositif (séances à tarif conventionné sous conditions, critères d'éligibilité), voir la
          page{' '}
          <a href="/mon-soutien-psy/" class={buttonClasses({ variant: "link", className: "font-medium" })}
            >Mon Soutien Psy</a
          >.
        </span>
      </p>
    </div>

    <HomeTrustStrip />
  </div>
</section>

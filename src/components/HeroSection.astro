---
import { Image } from "astro:assets";
import PsychologueImage from "../assets/psychologie.webp";
---

<section
  id="hero"
  class="bg-white rounded-xl shadow-md p-8 md:p-10 mb-16 border border-gray-100"
  aria-labelledby="hero-heading"
>
  <div class="grid lg:grid-cols-4 gap-8 items-center">
    <!-- Contenu textuel -->
    <div class="lg:col-span-3">
      <h1
        id="hero-heading"
        class="text-4xl md:text-5xl font-bold text-tertiary mb-3 leading-tight"
      >
        Psychologue à Sceaux
      </h1>
      <p class="text-xl text-gray-600 mb-5 italic">
        Consultations pour adultes, adolescents et couples, au cabinet
        ou en visioconférence.
      </p>
      <p class="text-gray-700 leading-relaxed mb-6 max-w-3xl">
        <strong class="text-tertiary">Psychologue</strong> diplômé de l'Université
        Paris Cité, je vous accueille à Sceaux dans un cadre bienveillant
        et confidentiel. Mon approche est intégrative et s'adapte à votre
        situation, à votre rythme et à vos objectifs.
      </p>
      <ul
        class="grid sm:grid-cols-3 gap-3 text-sm text-gray-700 mb-8 max-w-4xl"
      >
        <li
          class="bg-secondary/50 border border-primary/20 rounded-lg px-4 py-3"
        >
          Cabinet au 63 rue Houdan, Sceaux
        </li>
        <li
          class="bg-secondary/50 border border-primary/20 rounded-lg px-4 py-3"
        >
          Du lundi au samedi, de 8h à 20h
        </li>
        <li
          class="bg-secondary/50 border border-primary/20 rounded-lg px-4 py-3"
        >
          Psychothérapie, thérapie MOSAIC, ACT, MBCT, CFT
        </li>
      </ul>
      <div class="mt-8 flex flex-col gap-4">
        <a
          href="https://www.doctolib.fr/psychologue/sceaux/nicolas-devaux-sceaux/booking?utm_campaign=website-button&utm_source=nicolas-devaux-sceaux-website-button&utm_medium=referral&utm_content=withpreview-white-inlined&utm_term=nicolas-devaux-sceaux"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full sm:w-auto gap-2 items-center justify-center px-6 py-3 h-12 bg-[#107ACA] hover:bg-[#0E6BAD] text-white font-bold text-sm uppercase rounded-lg transition-colors duration-200 no-underline"
          aria-label="Prendre rendez-vous sur Doctolib"
          data-umami-event="Doctolib Click"
          data-umami-event-location="Hero"
        >
          <svg
            xml:space="preserve"
            width="18"
            height="18"
            fill="currentColor"
            viewBox="0 0 16 16"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
            focusable="false"
            ><path
              d="M12.8 7.8c.3-1.6.3-4.8-4.8-5.3-1.3-.1-3.4.2-4.8.5v.1c0 .1.2.3.4.4.1.1.4 0 .5 0 4.6-.4 7.9.6 7.3 4-.3 1.9-1.6 4.4-5.1 4.4-.7 0-.8-.1-.7-.6 0-.1 1.1-5.9 1.2-6.5 0 0-.8-.2-1 .6 0 .2-1.9 7-2 7.4-.1.5.2.8 2.5.8 5.5-.1 6.3-4.8 6.5-5.8"
            ></path></svg
          >
          Prendre rendez-vous
        </a>

        <nav
          aria-label="Parcours de consultation"
          class="grid gap-3 sm:grid-cols-2 max-w-2xl"
        >
          <a
            href="/psychotherapie/"
            class="group rounded-xl border border-gray-200 bg-secondary/35 px-4 py-4 no-underline transition-colors duration-200 hover:bg-secondary/60 hover:border-primary/30"
          >
            <span class="block text-sm font-semibold text-tertiary">
              Choisir une approche
            </span>
            <span class="mt-1 block text-sm text-gray-600">
              Psychothérapie, MOSAIC, ACT, MBCT, CFT
            </span>
          </a>
          <a
            href="/consulter/"
            class="group rounded-xl border border-gray-200 bg-secondary/35 px-4 py-4 no-underline transition-colors duration-200 hover:bg-secondary/60 hover:border-primary/30"
          >
            <span class="block text-sm font-semibold text-tertiary">
              Préparer une consultation
            </span>
            <span class="mt-1 block text-sm text-gray-600">
              Déroulement, tarifs, rythme et modalités pratiques
            </span>
          </a>
        </nav>
      </div>
    </div>

    <!-- Image du psychologue -->
    <div
      class="lg:col-span-1 flex justify-center lg:justify-end flex-col h-full"
    >
      <div class="rounded-2xl max-w-xs mt-auto">
        <Image
          src={PsychologueImage}
          alt="Nicolas Devaux, Psychologue à Sceaux"
          class="rounded-xl w-full"
          widths={[320, 550, 800]}
          sizes="(min-width: 1280px) 22vw, (min-width: 1024px) 33vw, 320px"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

---
import AuthorCard from "./AuthorCard.astro";
import BrandSpiralMark from "./BrandSpiralMark.astro";
import HomeTrustStrip from "./HomeTrustStrip.astro";
import { buttonClasses } from "./ui/button";
import { DOCTOLIB_BOOKING_URL } from "../consts";

const approachTeaserLink = buttonClasses({
  variant: "link",
  className: "font-medium normal-case",
});
---

<section id="hero" class="w-full pb-16 pt-2 md:pb-24 md:pt-6" aria-labelledby="hero-heading">
  <div class="flex w-full flex-col gap-6 md:gap-8">
    <header class="max-w-none">
      <div class="flex flex-col gap-8 lg:flex-row lg:flex-wrap lg:items-start lg:justify-between lg:gap-6">
        <div class="min-w-0 flex-1">
          <h1 id="hero-heading" class="font-display hero-heading-display mb-2 text-ink-primary md:mb-3">
            Nicolas Devaux
          </h1>
          <p class="typo-eyebrow mb-0 text-ink-secondary">Psychologue clinicien à Sceaux et en ligne</p>
          <AuthorCard class="mt-5" />
        </div>
        <div class="shrink-0 pt-1 md:pt-2">
          <BrandSpiralMark class="h-24 w-24 text-brand/65 md:h-30 md:w-30" />
        </div>
      </div>

      <p class="typo-body-lg text-body-muted mb-0 mt-6 md:mt-7">
        <strong class="font-medium text-ink-primary">Consultations pour adultes, adolescents et couples</strong>, au
        cabinet ou en visioconférence.
      </p>
    </header>

    <p class="typo-body max-w-none">
      Psychologue diplômé de l'Université Paris Cité, j'exerce comme
      <a href="/psychologue-sceaux/" class="text-link">psychologue à Sceaux</a>
      dans un cadre bienveillant et confidentiel, et en visioconférence. Je propose des <strong>thérapies cognitives et comportementales (TCC)</strong>,
      de l'<strong>EMDR-MOSAIC</strong> pour les traumatismes, et de la <strong>thérapie de couple</strong>.
      Mon approche intégrative s'adapte à votre situation, à votre rythme et à vos objectifs.
    </p>

    <nav class="flex max-w-none flex-wrap gap-x-6 gap-y-2" aria-label="Liens utiles">
      <a href="/psychologue-sceaux/" class={approachTeaserLink}>Psychologue au cabinet de Sceaux →</a>
      <a href="/therapie-mosaic/" class={approachTeaserLink}>Thérapie EMDR-MOSAIC pour les traumatismes →</a>
      <a href="/therapie-couple/" class={approachTeaserLink}>Thérapie de couple et relation →</a>
      <a href="/psychologue-en-ligne/" class={approachTeaserLink}>Consultations en ligne par visio →</a>
      <a href="/meditation-pleine-conscience-sceaux/" class={approachTeaserLink}>Groupes de méditation pleine conscience →</a>
    </nav>

    <div class="flex flex-col items-start gap-2">
      <a
        href={DOCTOLIB_BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class={buttonClasses({ variant: "primary", size: "lg", className: "shrink-0" })}
        aria-label="Prendre rendez-vous sur Doctolib"
        data-track-doctolib
        data-track-location="Hero"
      >
        Prendre rendez-vous
      </a>
      <p class="font-ui typo-meta max-w-measure text-pretty text-ink-tertiary">
        Vos données restent confidentielles. Messagerie sécurisée via Doctolib.
      </p>
      <p class="text-sm leading-snug text-ink-tertiary">
        Je ne prends plus de nouveaux patients dans le dispositif
        <a href="/mon-soutien-psy/" class="text-link">Mon Soutien Psy</a>.
      </p>
    </div>

    <HomeTrustStrip />
  </div>
</section>

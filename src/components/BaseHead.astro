---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";
import { SITE_NAME } from "../consts";
import { pathnameToOgSlug } from "../utils/pathname-to-og-slug";
import { applyFrenchTypography } from "../utils/frenchTypography.js";

interface Props {
	title: string;
	description: string;
	/** Surcharge du fichier `/og/{slug}.png` (cas rare). */
	ogImageSlug?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, ogImageSlug } = Astro.props;
const formattedTitle = applyFrenchTypography(title);
const formattedDescription = applyFrenchTypography(description);
const pageTitle =
  formattedTitle === "Psychologue à Sceaux"
    ? "Psychologue à Sceaux | Nicolas Devaux"
    : formattedTitle.includes(SITE_NAME) || formattedTitle.includes("Nicolas Devaux")
      ? formattedTitle
      : `${formattedTitle} | ${SITE_NAME}`;
const siteBase = Astro.site ?? Astro.url.origin;
const ogSlug = ogImageSlug ?? pathnameToOgSlug(Astro.url.pathname);
const ogImagePath = `/og/${ogSlug}.png`;
const ogImageAbsolute = new URL(ogImagePath, siteBase).href;
const OG_RW = 1200;
const OG_RH = 630;
const umamiId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const umamiUrl = import.meta.env.PUBLIC_UMAMI_URL;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Polices : Inter Variable (axe opsz) et Source Serif 4 Variable via CSS bundlé -->

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{pageTitle}</title>
<meta name="description" content={formattedDescription} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={formattedDescription} />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content={String(OG_RW)} />
<meta property="og:image:height" content={String(OG_RH)} />
<meta property="og:image:alt" content={pageTitle} />
<meta property="og:locale" content="fr_FR" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={formattedDescription} />
<meta name="twitter:image" content={ogImageAbsolute} />


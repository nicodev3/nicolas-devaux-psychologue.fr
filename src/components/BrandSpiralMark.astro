---
/**
 * Motif marque — spirale ouverte (trait 1,5 px).
 * Réemployée dans le header, le hero et les séparateurs de section pour une lecture cohérente.
 * Couleur : `currentColor` (classes utilitaires `text-brand`, etc.).
 */
interface Props {
  class?: string;
}

const { class: className = "h-28 w-28 text-brand/70 md:h-32 md:w-32" } = Astro.props;
---

<svg
  class:list={[className]}
  viewBox="0 0 120 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <path
    d="M60 22c21 0 38 17 38 38 0 17-11 31-26 36-13 5-28 2-38-8-9-9-12-23-7-35 5-11 17-18 29-16 11 2 19 12 18 24-1 10-9 18-19 19-9 1-17-5-19-14"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>

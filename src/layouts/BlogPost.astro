---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import BlogSchema from "../components/BlogSchema.astro";
import Header from "../components/Header.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import "../styles/global.css";
import "../styles/content.css";
import { formatFrenchDate, toDateTime } from "../utils/formatDate";

type Props = CollectionEntry<"blog">["data"] & {
  blogPost?: boolean;
  showDate?: boolean;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  blogPost = false,
  showDate = true,
} = Astro.props;

const slug = Astro.url.pathname.replace(/^\/blog\//, "").replace(/\/$/, "");
---

<html lang="fr">
  <head>
    <BaseHead title={title} description={description} image={heroImage?.src} />
    {blogPost && <BlogSchema title={title} description={description} pubDate={pubDate} slug={slug} />}
  </head>

  <body class="bg-linear-to-r from-secondary to-white">
    <Header />
    <Breadcrumb title={title} />
    <main class="container flex flex-col xl:flex-row gap-8 xl:gap-12 xl:items-start pb-8 xl:pb-10">
      <article class="xl:flex-1 xl:min-w-0">
        <!-- Section Hero -->
        <div class="bg-white rounded-xl shadow-md p-8 mb-12 border border-gray-100">
          {
            heroImage && (
              <div class="mb-8 mx-auto flex max-h-[min(40vh,320px)] w-full max-w-[min(100%,560px)] items-center justify-center overflow-hidden rounded-xl sm:max-h-[min(45vh,380px)]">
                <Image
                  src={heroImage}
                  alt={title}
                  width={heroImage.width}
                  height={heroImage.height}
                  class="h-auto max-h-[min(40vh,320px)] w-auto max-w-full object-contain sm:max-h-[min(45vh,380px)]"
                />
              </div>
            )
          }
          <header class="text-center">
            <h1 class="text-4xl md:text-5xl font-bold text-tertiary mb-4 leading-tight">
              {title}
            </h1>
            {
              showDate && (
                <p class="text-sm text-gray-500 font-medium">
                  <time datetime={toDateTime(pubDate)}>{formatFrenchDate(pubDate)}</time>
                  {updatedDate && (
                    <span class="italic ml-2">
                      - Mis à jour le{" "}
                      <time datetime={toDateTime(updatedDate)}>
                        {formatFrenchDate(updatedDate)}
                      </time>
                    </span>
                  )}
                </p>
              )
            }
          </header>
        </div>

        <!-- Contenu -->
        <div
          class={`bg-white rounded-xl shadow-md p-8 border border-gray-100 ${
            blogPost
              ? "c-prose"
              : "c-wysiwig"
          }`}
        >
          <slot />
        </div>
      </article>
      <SideBar showPsyInfo={false} />
    </main>
    <Footer />
  </body>
</html>

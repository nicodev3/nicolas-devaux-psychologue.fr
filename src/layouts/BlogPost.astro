---
import type { CollectionEntry } from "astro:content";
import { Picture } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import BlogSchema from "../components/BlogSchema.astro";
import Header from "../components/Header.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import ArticleScrollProgress from "../components/ArticleScrollProgress.astro";
import ArticleShareLinks from "../components/ArticleShareLinks.astro";
import authorPortrait from "../assets/nicolas_devaux.jpg";
import "../styles/global.css";
import "../styles/content.css";
import { formatFrenchDate, toDateTime } from "../utils/formatDate";
import { applyFrenchTypography } from "../utils/frenchTypography.js";

type Props = CollectionEntry<"blog">["data"] & {
  blogPost?: boolean;
  showDate?: boolean;
  readingTimeMinutes?: number;
  hasFaq?: boolean;
};

const {
  title,
  seoTitle,
  description,
  pubDate,
  updatedDate,
  heroImage,
  blogPost = false,
  showDate = true,
  readingTimeMinutes,
  hasFaq = false,
} = Astro.props;

const formattedTitle = applyFrenchTypography(title);

const slug = Astro.url.pathname.replace(/^\/blog\//, "").replace(/\/$/, "");
const isBlogArticle = blogPost && Astro.url.pathname.startsWith("/blog/");
const readingTimeLabel = readingTimeMinutes ? `${readingTimeMinutes} min de lecture` : "Lecture";
const articleUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;

function getArticleKicker(articleSlug: string, articleTitle: string): string {
  const normalized = `${articleSlug} ${articleTitle}`.toLowerCase();

  if (normalized.includes("coherence") || normalized.includes("outil")) {
    return "Santé mentale · Outils";
  }

  if (normalized.includes("therapie") || normalized.includes("psychotherapie") || normalized.includes("hypno")) {
    return "Psychothérapie · Approches";
  }

  if (normalized.includes("choisir") || normalized.includes("consulter")) {
    return "Psychologie · Repères";
  }

  return "Santé mentale · Article";
}

const articleKicker = getArticleKicker(slug, title);
---

<html lang="fr">
  <head>
    <BaseHead title={seoTitle ?? title} description={description} />
    {blogPost && <BlogSchema title={title} description={description} pubDate={pubDate} slug={slug} heroImage={heroImage} />}
  </head>

  <body class="bg-surface-page">
    <ArticleScrollProgress enabled={blogPost} />
    <Header />
    <main class:list={["page-shell", isBlogArticle && "page-shell--article"]}>
      <div class:list={[isBlogArticle && "mx-auto max-w-[980px]"]}>
        <Breadcrumb title={title} />
      </div>
      <article class="w-full">
        {
          isBlogArticle ? (
            <header class="mx-auto mb-12 grid max-w-[980px] items-start gap-8 border-b border-border-subtle pb-10 md:mb-14 md:pb-12 lg:grid-cols-[minmax(0,560px)_minmax(280px,360px)] lg:gap-12">
              <div class="min-w-0 pt-1 lg:pt-4">
                <p class="typo-meta-caps mb-5 text-brand">{articleKicker}</p>
                <h1 class="font-display mb-5 max-w-[14em] text-pretty text-[clamp(2.1rem,4.2vw,2.8rem)] font-semibold leading-[1.06] tracking-normal text-ink-primary md:mb-6">
                  {formattedTitle}
                </h1>
                <p class="typo-body-lg mb-7 max-w-[58ch] text-pretty text-ink-secondary">
                  {description}
                </p>

                <div class="flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-border-subtle pt-4 font-ui text-sm text-ink-tertiary">
                  <div class="flex min-w-0 items-center gap-2.5">
                    <div class="size-8 shrink-0 overflow-hidden rounded-full bg-surface-muted ring-1 ring-border-subtle">
                      <Picture
                        src={authorPortrait}
                        alt=""
                        width={64}
                        height={64}
                        formats={["avif", "webp"]}
                        fallbackFormat="webp"
                        densities={[1, 2]}
                        loading="eager"
                        fetchpriority="high"
                        class="size-full object-cover object-center"
                      />
                    </div>
                    <p class="min-w-0 leading-snug">
                      <span class="font-semibold text-ink-primary">Nicolas Devaux</span>
                      <span class="text-border-strong" aria-hidden="true"> · </span>
                      <span>Psychologue à Sceaux</span>
                    </p>
                  </div>

                  {showDate && (
                    <p class="leading-snug">
                      <time datetime={toDateTime(pubDate)}>{formatFrenchDate(pubDate)}</time>
                      <span class="mx-2 text-border-strong" aria-hidden="true">
                        ·
                      </span>
                      <span>{readingTimeLabel}</span>
                      {updatedDate && (
                        <span class="block font-medium">
                          Mis à jour le{" "}
                          <time datetime={toDateTime(updatedDate)}>
                            {formatFrenchDate(updatedDate)}
                          </time>
                        </span>
                      )}
                    </p>
                  )}
                  <a
                    href="/consulter/"
                    class="font-semibold text-brand transition-colors hover:text-brand-hover"
                  >
                    Consulter
                  </a>
                </div>

                {hasFaq && (
                  <a
                    href="#faq"
                    class="mt-5 inline-flex items-center gap-2 font-ui text-sm font-semibold text-brand transition-colors hover:text-brand-hover"
                  >
                    Aller aux questions fréquentes
                    <span aria-hidden="true">↓</span>
                  </a>
                )}

                <ArticleShareLinks title={title} url={articleUrl} />
              </div>

              {heroImage && (
                <figure class="lg:sticky lg:top-24">
                  <div class="relative overflow-hidden rounded-lg border border-border-subtle bg-surface-muted">
                    <Picture
                      src={heroImage}
                      alt={title}
                      width={heroImage.width}
                      height={heroImage.height}
                      formats={["avif", "webp"]}
                      fallbackFormat="webp"
                      loading="eager"
                      decoding="async"
                      fetchpriority="high"
                      class="aspect-[4/3] w-full object-cover"
                    />
                    <div
                      class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-surface-page/95 to-transparent"
                      aria-hidden="true"
                    />
                  </div>
                </figure>
              )}
            </header>
          ) : (
            <header class="mb-10 md:mb-12">
          {
            heroImage && (
              <div class="mb-8 w-full overflow-hidden rounded-xl border border-border-subtle">
                <Picture
                  src={heroImage}
                  alt={title}
                  width={heroImage.width}
                  height={heroImage.height}
                  formats={["avif", "webp"]}
                  fallbackFormat="webp"
                  loading="lazy"
                  decoding="async"
                  class="h-auto w-full max-w-full"
                />
              </div>
            )
          }
          <h1 class="font-display typo-h1 mb-6 text-pretty text-ink-primary md:mb-8">
            {formattedTitle}
          </h1>
          {
            showDate && (
              <p class="font-ui typo-meta text-body-muted">
                <time datetime={toDateTime(pubDate)}>{formatFrenchDate(pubDate)}</time>
                {updatedDate && (
                  <span class="ml-2 font-medium">
                    — Mis à jour le{" "}
                    <time datetime={toDateTime(updatedDate)}>
                      {formatFrenchDate(updatedDate)}
                    </time>
                  </span>
                )}
              </p>
            )
          }
            </header>
          )
        }

        <div
          class:list={[
            blogPost ? "c-prose" : "c-wysiwig",
            isBlogArticle ? "article-prose" : "border-t border-border-subtle pt-10 md:pt-12",
          ]}
        >
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
